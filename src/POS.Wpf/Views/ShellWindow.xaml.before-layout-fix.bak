<Window
    x:Class="POS.Wpf.Views.ShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="POS Enterprise"
    Width="1366"
    Height="768"
    MinWidth="1100"
    MinHeight="650"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="SingleBorderWindow"
    ResizeMode="CanResize"
    SizeToContent="Manual"
    Background="{StaticResource AppBackgroundBrush}"
    FontFamily="Segoe UI"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <Window.Resources>

        <!-- Nút điều chỉnh kho màu vàng đồng -->

        <Style
            x:Key="InventoryActionButtonStyle"
            TargetType="{x:Type Button}"
            BasedOn="{StaticResource SecondaryButtonStyle}">

            <Setter
                Property="Background"
                Value="{StaticResource GoldSoftBrush}" />

            <Setter
                Property="Foreground"
                Value="#8C611D" />

            <Setter
                Property="BorderBrush"
                Value="{StaticResource GoldBorderBrush}" />

            <Setter
                Property="MinWidth"
                Value="142" />
        </Style>

        <!-- Nút lịch sử kho màu đỏ rượu vang -->

        <Style
            x:Key="InventoryHistoryButtonStyle"
            TargetType="{x:Type Button}">

            <Setter
                Property="Background"
                Value="{StaticResource AccentSoftBrush}" />

            <Setter
                Property="Foreground"
                Value="{StaticResource AccentBrush}" />

            <Setter
                Property="BorderBrush"
                Value="{StaticResource AccentBorderBrush}" />

            <Setter
                Property="BorderThickness"
                Value="1" />

            <Setter
                Property="Padding"
                Value="16,0" />

            <Setter
                Property="Height"
                Value="42" />

            <Setter
                Property="MinWidth"
                Value="132" />

            <Setter
                Property="FontFamily"
                Value="Segoe UI" />

            <Setter
                Property="FontSize"
                Value="13" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />

            <Setter
                Property="Cursor"
                Value="Hand" />

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate
                        TargetType="{x:Type Button}">

                        <Border
                            x:Name="HistoryButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9"
                            Padding="{TemplateBinding Padding}">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger
                                Property="IsMouseOver"
                                Value="True">

                                <Setter
                                    TargetName="HistoryButtonBorder"
                                    Property="Background"
                                    Value="{StaticResource AccentBrush}" />

                                <Setter
                                    TargetName="HistoryButtonBorder"
                                    Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}" />

                                <Setter
                                    Property="Foreground"
                                    Value="White" />
                            </Trigger>

                            <Trigger
                                Property="IsPressed"
                                Value="True">

                                <Setter
                                    TargetName="HistoryButtonBorder"
                                    Property="Background"
                                    Value="{StaticResource AccentPressedBrush}" />
                            </Trigger>

                            <Trigger
                                Property="IsEnabled"
                                Value="False">

                                <Setter
                                    TargetName="HistoryButtonBorder"
                                    Property="Opacity"
                                    Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- =================================================
             SIDEBAR
             ================================================= -->

        <Border
            Grid.Column="0"
            Background="{StaticResource SidebarBrush}">

            <Grid Margin="20,20,20,18">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand -->

                <StackPanel HorizontalAlignment="Center">

                    <Grid
                        Width="72"
                        Height="72">

                        <Ellipse
                            Margin="4"
                            Stroke="{StaticResource GoldBrush}"
                            StrokeThickness="1.5" />

                        <Border
                            Width="47"
                            Height="47"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderBrush="{StaticResource GoldHoverBrush}"
                            BorderThickness="1.2"
                            CornerRadius="5"
                            RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <RotateTransform Angle="45" />
                            </Border.RenderTransform>
                        </Border>

                        <TextBlock
                            Text="P"
                            FontFamily="Georgia"
                            FontSize="30"
                            Foreground="{StaticResource GoldGradientBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock
                        Text="P O S   E N T E R P R I S E"
                        Foreground="{StaticResource GoldHoverBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0" />

                    <TextBlock
                        Text="R E S T A U R A N T   S O L U T I O N S"
                        Foreground="{StaticResource SidebarMutedBrush}"
                        FontSize="7"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Margin="0,5,0,0" />

                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0">

                        <Border
                            Width="40"
                            Height="1"
                            Background="#705E47"
                            VerticalAlignment="Center" />

                        <TextBlock
                            Text="◆"
                            Foreground="{StaticResource GoldBrush}"
                            FontSize="8"
                            Margin="7,0" />

                        <Border
                            Width="40"
                            Height="1"
                            Background="#705E47"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- Navigation -->

                <ScrollViewer
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    Margin="0,27,0,18">

                    <StackPanel>

                        <Grid Margin="7,0,0,10">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Text="MENU CHÍNH"
                                Foreground="{StaticResource SidebarMutedBrush}"
                                FontSize="10"
                                FontWeight="SemiBold" />

                            <Border
                                Grid.Column="1"
                                Height="1"
                                Margin="10,0,0,0"
                                Background="#4A423D"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Button
                            Style="{StaticResource NavigationButtonStyle}"
                            IsEnabled="False">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE80F;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="17"
                                    Width="32"
                                    VerticalAlignment="Center" />

                                <TextBlock
                                    Text="Tổng quan"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button
                            Style="{StaticResource SelectedNavigationButtonStyle}">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE719;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="17"
                                    Width="32"
                                    VerticalAlignment="Center" />

                                <TextBlock
                                    Text="Sản phẩm và kho"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button
                            Style="{StaticResource NavigationButtonStyle}"
                            IsEnabled="False">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE8D4;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="17"
                                    Width="32"
                                    VerticalAlignment="Center" />

                                <TextBlock
                                    Text="Khách hàng"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button
                            Style="{StaticResource NavigationButtonStyle}"
                            IsEnabled="False">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE8A1;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="17"
                                    Width="32"
                                    VerticalAlignment="Center" />

                                <TextBlock
                                    Text="Bán hàng"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button
                            Style="{StaticResource NavigationButtonStyle}"
                            IsEnabled="False">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE9D2;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="17"
                                    Width="32"
                                    VerticalAlignment="Center" />

                                <TextBlock
                                    Text="Báo cáo"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Quote -->

                        <Border
                            Margin="7,34,7,0"
                            Padding="15"
                            Background="{StaticResource SidebarSurfaceBrush}"
                            BorderBrush="#6A4C27"
                            BorderThickness="1"
                            CornerRadius="12">

                            <StackPanel>

                                <TextBlock
                                    Text="◆"
                                    Foreground="{StaticResource GoldBrush}"
                                    FontSize="10"
                                    HorizontalAlignment="Center" />

                                <TextBlock
                                    Text="“Chất lượng tạo nên thương hiệu, dịch vụ làm nên khác biệt.”"
                                    FontFamily="Georgia"
                                    FontSize="12"
                                    FontStyle="Italic"
                                    Foreground="#E5D3B5"
                                    TextWrapping="Wrap"
                                    TextAlignment="Center"
                                    LineHeight="20"
                                    Margin="0,10,0,10" />

                                <StackPanel
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                                    <Border
                                        Width="26"
                                        Height="1"
                                        Background="#785C34"
                                        VerticalAlignment="Center" />

                                    <TextBlock
                                        Text="✦"
                                        Foreground="{StaticResource GoldBrush}"
                                        FontSize="8"
                                        Margin="7,0" />

                                    <Border
                                        Width="26"
                                        Height="1"
                                        Background="#785C34"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->

                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Center">

                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">

                        <Ellipse
                            Width="7"
                            Height="7"
                            Fill="{StaticResource SuccessBrush}"
                            Margin="0,0,7,0"
                            VerticalAlignment="Center" />

                        <TextBlock
                            Text="SQLite đã kết nối"
                            Foreground="{StaticResource SidebarMutedBrush}"
                            FontSize="10" />
                    </StackPanel>

                    <TextBlock
                        Text="© 2026 POS Enterprise"
                        Foreground="#91867D"
                        FontSize="9"
                        HorizontalAlignment="Center"
                        Margin="0,9,0,0" />

                    <TextBlock
                        Text="Phiên bản 2.0.0"
                        Foreground="#756B64"
                        FontSize="9"
                        HorizontalAlignment="Center"
                        Margin="0,3,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- =================================================
             MAIN WORKSPACE
             ================================================= -->

        <Grid
            Grid.Column="1"
            Margin="24,18,24,20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>

                    <TextBlock
                        Text="Sản phẩm và tồn kho"
                        Style="{StaticResource PageTitleTextStyle}" />

                    <TextBlock
                        Text="Quản lý danh mục, giá bán và toàn bộ biến động kho."
                        Style="{StaticResource SecondaryTextStyle}"
                        Margin="0,5,0,0" />

                    <StackPanel
                        Orientation="Horizontal"
                        Margin="0,10,0,0">

                        <Border
                            Width="105"
                            Height="1"
                            Background="{StaticResource GoldBorderBrush}"
                            VerticalAlignment="Center" />

                        <TextBlock
                            Text="◆"
                            Foreground="{StaticResource GoldBrush}"
                            FontSize="8"
                            Margin="7,0" />

                        <Border
                            Width="105"
                            Height="1"
                            Background="{StaticResource GoldBorderBrush}"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="10,8,14,8"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="13">

                    <Border.Effect>
                        <DropShadowEffect
                            Color="#463026"
                            BlurRadius="12"
                            ShadowDepth="2"
                            Opacity="0.08" />
                    </Border.Effect>

                    <StackPanel Orientation="Horizontal">

                        <Border
                            Width="38"
                            Height="38"
                            Background="{StaticResource AccentGradientBrush}"
                            CornerRadius="19">

                            <TextBlock
                                Text="A"
                                FontFamily="Georgia"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <StackPanel
                            Margin="11,0,14,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                Text="Quản trị viên"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                FontSize="12"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding LastUpdatedText}"
                                Foreground="{StaticResource TextMutedBrush}"
                                FontSize="9"
                                Margin="0,2,0,0" />
                        </StackPanel>

                        <TextBlock
                            Text="&#xE70D;"
                            FontFamily="Segoe MDL2 Assets"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="11"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- KPI -->

            <UniformGrid
                Grid.Row="1"
                Columns="4"
                Margin="0,18,0,16">

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,10,0"
                    Padding="17">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="43"
                            Height="43"
                            Background="{StaticResource GoldSoftBrush}"
                            BorderBrush="{StaticResource GoldBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22">

                            <TextBlock
                                Text="&#xE719;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="{StaticResource GoldBrush}"
                                FontSize="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <StackPanel
                            Grid.Column="1"
                            Margin="13,0,0,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                Text="TỔNG SẢN PHẨM"
                                Style="{StaticResource CaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding TotalProductsText}"
                                Style="{StaticResource CardValueTextStyle}"
                                Margin="0,4,0,0" />

                            <TextBlock
                                Text="Toàn bộ kết quả tìm kiếm"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="4,0,6,0"
                    Padding="17">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="43"
                            Height="43"
                            Background="{StaticResource GoldSoftBrush}"
                            BorderBrush="{StaticResource GoldBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22">

                            <TextBlock
                                Text="&#xE73E;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="{StaticResource GoldBrush}"
                                FontSize="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <StackPanel
                            Grid.Column="1"
                            Margin="13,0,0,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                Text="ĐANG BÁN TRÊN TRANG"
                                Style="{StaticResource CaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding ActiveProductsOnPageText}"
                                Style="{StaticResource CardValueTextStyle}"
                                Margin="0,4,0,0" />

                            <TextBlock
                                Text="Sản phẩm đang hoạt động"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="6,0,4,0"
                    Padding="17">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="43"
                            Height="43"
                            Background="{StaticResource WarningSoftBrush}"
                            BorderBrush="{StaticResource GoldBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22">

                            <TextBlock
                                Text="!"
                                Foreground="{StaticResource WarningBrush}"
                                FontSize="20"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <StackPanel
                            Grid.Column="1"
                            Margin="13,0,0,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                Text="SẮP HẾT TRÊN TRANG"
                                Style="{StaticResource CaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding LowStockProductsOnPageText}"
                                Style="{StaticResource CardValueTextStyle}"
                                Margin="0,4,0,0" />

                            <TextBlock
                                Text="Cần kiểm tra nhập hàng"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="10,0,0,0"
                    Padding="17">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="43"
                            Height="43"
                            Background="{StaticResource GoldSoftBrush}"
                            BorderBrush="{StaticResource GoldBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22">

                            <TextBlock
                                Text="₫"
                                Foreground="{StaticResource GoldBrush}"
                                FontSize="18"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <StackPanel
                            Grid.Column="1"
                            Margin="13,0,0,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                Text="GIÁ TRỊ VỐN TRÊN TRANG"
                                Style="{StaticResource CaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding InventoryValueOnPageText}"
                                FontFamily="Georgia"
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Margin="0,5,0,0" />

                            <TextBlock
                                Text="Tồn dương × giá vốn"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Product workspace -->

            <Border
                Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Padding="0"
                ClipToBounds="True">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Product title and actions -->

                    <Grid Margin="20,14,20,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">

                            <Border
                                Width="42"
                                Height="42"
                                Background="{StaticResource GoldSoftBrush}"
                                BorderBrush="{StaticResource GoldBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="21">

                                <TextBlock
                                    Text="&#xE719;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Foreground="{StaticResource GoldBrush}"
                                    FontSize="18"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>

                            <StackPanel
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">

                                <TextBlock
                                    Text="Danh mục sản phẩm"
                                    Style="{StaticResource SectionTitleTextStyle}" />

                                <TextBlock
                                    Text="Quản lý thông tin và trạng thái bán."
                                    Style="{StaticResource CaptionTextStyle}"
                                    Margin="0,3,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal">

                            <Button
                                Command="{Binding AddProductCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                MinWidth="138">

                                <StackPanel Orientation="Horizontal">

                                    <TextBlock
                                        Text="&#xE710;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="13"
                                        Margin="0,0,7,0"
                                        VerticalAlignment="Center" />

                                    <TextBlock
                                        Text="Thêm sản phẩm"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button
                                Command="{Binding EditProductCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="82"
                                Margin="9,0,0,0">

                                <StackPanel Orientation="Horizontal">

                                    <TextBlock
                                        Text="&#xE70F;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="12"
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center" />

                                    <TextBlock
                                        Text="Sửa"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button
                                Content="{Binding ToggleProductButtonText}"
                                Command="{Binding ToggleProductActiveCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="104"
                                Margin="9,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <!-- Inventory operation rail -->

                    <Border
                        Margin="20,12,20,14"
                        Padding="13"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Width="40"
                                Height="40"
                                Background="{StaticResource GoldSoftBrush}"
                                BorderBrush="{StaticResource GoldBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="11">

                                <TextBlock
                                    Text="±"
                                    FontFamily="Georgia"
                                    Foreground="{StaticResource GoldBrush}"
                                    FontSize="20"
                                    FontWeight="Bold"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>

                            <StackPanel
                                Grid.Column="1"
                                Margin="12,0,16,0"
                                VerticalAlignment="Center">

                                <TextBlock
                                    Text="{Binding SelectedProductHint}"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis" />

                                <WrapPanel Margin="0,7,0,0">

                                    <Border
                                        Padding="8,4"
                                        Margin="0,0,7,4"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7">

                                        <StackPanel Orientation="Horizontal">

                                            <TextBlock
                                                Text="Mã: "
                                                Foreground="{StaticResource TextMutedBrush}"
                                                FontSize="9" />

                                            <TextBlock
                                                Text="{Binding SelectedProductCodeText}"
                                                Foreground="{StaticResource GoldBrush}"
                                                FontSize="9"
                                                FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Padding="8,4"
                                        Margin="0,0,7,4"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7">

                                        <StackPanel Orientation="Horizontal">

                                            <TextBlock
                                                Text="Tồn: "
                                                Foreground="{StaticResource TextMutedBrush}"
                                                FontSize="9" />

                                            <TextBlock
                                                Text="{Binding SelectedProductStockText}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                FontSize="9"
                                                FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Padding="8,4"
                                        Margin="0,0,7,4"
                                        Background="{StaticResource WarningSoftBrush}"
                                        BorderBrush="{StaticResource GoldBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7">

                                        <TextBlock
                                            Text="{Binding SelectedProductStockStateText}"
                                            Foreground="{StaticResource WarningBrush}"
                                            FontSize="9"
                                            FontWeight="SemiBold" />
                                    </Border>

                                    <Border
                                        Padding="8,4"
                                        Margin="0,0,0,4"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7">

                                        <TextBlock
                                            Text="{Binding SelectedProductPolicyText}"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            FontSize="9"
                                            FontWeight="SemiBold" />
                                    </Border>
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel
                                Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                                <Button
                                    Command="{Binding AdjustInventoryCommand}"
                                    Style="{StaticResource InventoryActionButtonStyle}"
                                    ToolTip="{Binding InventoryActionHint}"
                                    ToolTipService.ShowOnDisabled="True">

                                    <StackPanel Orientation="Horizontal">

                                        <TextBlock
                                            Text="±"
                                            FontFamily="Georgia"
                                            FontSize="17"
                                            FontWeight="Bold"
                                            Margin="0,0,7,0"
                                            VerticalAlignment="Center" />

                                        <TextBlock
                                            Text="Điều chỉnh kho"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button
                                    Command="{Binding ViewInventoryHistoryCommand}"
                                    Style="{StaticResource InventoryHistoryButtonStyle}"
                                    Margin="9,0,0,0"
                                    ToolTip="{Binding InventoryHistoryActionHint}">

                                    <StackPanel Orientation="Horizontal">

                                        <TextBlock
                                            Text="&#xE81C;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="14"
                                            Margin="0,0,7,0"
                                            VerticalAlignment="Center" />

                                        <TextBlock
                                            Text="Lịch sử kho"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Search toolbar -->

                    <Border
                        Grid.Row="1"
                        Padding="20,11"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,1">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid
                                Width="420"
                                HorizontalAlignment="Left">

                                <TextBox
                                    x:Name="SearchBox"
                                    Text="{Binding SearchTerm,
                                        UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource SearchBoxWithIconStyle}" />

                                <TextBlock
                                    Text="&#xE721;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    FontSize="14"
                                    Margin="15,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False" />

                                <TextBlock
                                    Text="Tìm theo mã, tên hoặc barcode..."
                                    Foreground="{StaticResource TextMutedBrush}"
                                    FontSize="12"
                                    Margin="42,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False">

                                    <TextBlock.Style>

                                        <Style
                                            TargetType="{x:Type TextBlock}">

                                            <Setter
                                                Property="Visibility"
                                                Value="Collapsed" />

                                            <Style.Triggers>

                                                <MultiDataTrigger>

                                                    <MultiDataTrigger.Conditions>

                                                        <Condition
                                                            Binding="{Binding Text.Length,
                                                                ElementName=SearchBox}"
                                                            Value="0" />

                                                        <Condition
                                                            Binding="{Binding IsKeyboardFocusWithin,
                                                                ElementName=SearchBox}"
                                                            Value="False" />
                                                    </MultiDataTrigger.Conditions>

                                                    <Setter
                                                        Property="Visibility"
                                                        Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal">

                                <Button
                                    Command="{Binding SearchCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    MinWidth="100"
                                    IsDefault="True">

                                    <StackPanel Orientation="Horizontal">

                                        <TextBlock
                                            Text="&#xE721;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="12"
                                            Margin="0,0,7,0"
                                            VerticalAlignment="Center" />

                                        <TextBlock
                                            Text="Tìm kiếm"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button
                                    Content="Tải lại"
                                    Command="{Binding RefreshCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinWidth="88"
                                    Margin="9,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Data table -->

                    <Grid Grid.Row="2">

                        <DataGrid
                            ItemsSource="{Binding Products}"
                            SelectedItem="{Binding SelectedProduct,
                                Mode=TwoWay}"
                            Style="{StaticResource ModernDataGridStyle}"
                            EnableRowVirtualization="True"
                            EnableColumnVirtualization="True"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling"
                            ScrollViewer.CanContentScroll="True"
                            ScrollViewer.IsDeferredScrollingEnabled="True">

                            <DataGrid.Columns>

                                <DataGridTemplateColumn
                                    Header="SẢN PHẨM"
                                    Width="2.4*">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Grid>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border
                                                    Width="34"
                                                    Height="34"
                                                    Background="{StaticResource GoldSoftBrush}"
                                                    BorderBrush="{StaticResource GoldBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="9">

                                                    <TextBlock
                                                        Text="&#xE719;"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        Foreground="{StaticResource GoldBrush}"
                                                        FontSize="14"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="9,0,0,0"
                                                    VerticalAlignment="Center">

                                                    <TextBlock
                                                        Text="{Binding Name}"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        FontSize="13"
                                                        FontWeight="SemiBold" />

                                                    <StackPanel
                                                        Orientation="Horizontal"
                                                        Margin="0,3,0,0">

                                                        <TextBlock
                                                            Text="{Binding Code}"
                                                            Foreground="{StaticResource GoldBrush}"
                                                            FontSize="10"
                                                            FontWeight="SemiBold" />

                                                        <TextBlock
                                                            Text="  •  "
                                                            Foreground="{StaticResource TextMutedBrush}"
                                                            FontSize="10" />

                                                        <TextBlock
                                                            Text="{Binding UnitName}"
                                                            Foreground="{StaticResource TextSecondaryBrush}"
                                                            FontSize="10" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn
                                    Header="DANH MỤC"
                                    Binding="{Binding CategoryName}"
                                    Width="1.25*" />

                                <DataGridTextColumn
                                    Header="GIÁ BÁN"
                                    Binding="{Binding SalePriceText}"
                                    Width="1*" />

                                <DataGridTemplateColumn
                                    Header="TỒN KHO"
                                    Width="1.3*">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <StackPanel VerticalAlignment="Center">

                                                <TextBlock
                                                    Text="{Binding StockDisplay}"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    FontSize="12"
                                                    FontWeight="SemiBold" />

                                                <Border
                                                    HorizontalAlignment="Left"
                                                    Padding="7,2"
                                                    CornerRadius="7"
                                                    Margin="0,3,0,0">

                                                    <Border.Style>

                                                        <Style TargetType="{x:Type Border}">

                                                            <Setter
                                                                Property="Background"
                                                                Value="{StaticResource SuccessSoftBrush}" />

                                                            <Style.Triggers>

                                                                <DataTrigger
                                                                    Binding="{Binding TrackInventory}"
                                                                    Value="False">

                                                                    <Setter
                                                                        Property="Background"
                                                                        Value="{StaticResource SurfaceMutedBrush}" />
                                                                </DataTrigger>

                                                                <DataTrigger
                                                                    Binding="{Binding IsLowStock}"
                                                                    Value="True">

                                                                    <Setter
                                                                        Property="Background"
                                                                        Value="{StaticResource WarningSoftBrush}" />
                                                                </DataTrigger>

                                                                <DataTrigger
                                                                    Binding="{Binding IsOutOfStock}"
                                                                    Value="True">

                                                                    <Setter
                                                                        Property="Background"
                                                                        Value="{StaticResource DangerSoftBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <TextBlock
                                                        Text="{Binding StockStateText}"
                                                        FontSize="9"
                                                        FontWeight="SemiBold">

                                                        <TextBlock.Style>

                                                            <Style TargetType="{x:Type TextBlock}">

                                                                <Setter
                                                                    Property="Foreground"
                                                                    Value="{StaticResource SuccessBrush}" />

                                                                <Style.Triggers>

                                                                    <DataTrigger
                                                                        Binding="{Binding TrackInventory}"
                                                                        Value="False">

                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{StaticResource TextSecondaryBrush}" />
                                                                    </DataTrigger>

                                                                    <DataTrigger
                                                                        Binding="{Binding IsLowStock}"
                                                                        Value="True">

                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{StaticResource WarningBrush}" />
                                                                    </DataTrigger>

                                                                    <DataTrigger
                                                                        Binding="{Binding IsOutOfStock}"
                                                                        Value="True">

                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{StaticResource DangerBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn
                                    Header="TRẠNG THÁI"
                                    Width="1*">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Border
                                                HorizontalAlignment="Left"
                                                Padding="10,4"
                                                CornerRadius="7">

                                                <Border.Style>

                                                    <Style TargetType="{x:Type Border}">

                                                        <Setter
                                                            Property="Background"
                                                            Value="{StaticResource SurfaceMutedBrush}" />

                                                        <Style.Triggers>

                                                            <DataTrigger
                                                                Binding="{Binding IsActive}"
                                                                Value="True">

                                                                <Setter
                                                                    Property="Background"
                                                                    Value="{StaticResource SuccessSoftBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <TextBlock
                                                    Text="{Binding StatusText}"
                                                    FontSize="10"
                                                    FontWeight="SemiBold">

                                                    <TextBlock.Style>

                                                        <Style TargetType="{x:Type TextBlock}">

                                                            <Setter
                                                                Property="Foreground"
                                                                Value="{StaticResource TextSecondaryBrush}" />

                                                            <Style.Triggers>

                                                                <DataTrigger
                                                                    Binding="{Binding IsActive}"
                                                                    Value="True">

                                                                    <Setter
                                                                        Property="Foreground"
                                                                        Value="{StaticResource SuccessBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty state -->

                        <Border Background="{StaticResource SurfaceBrush}">

                            <Border.Style>

                                <Style TargetType="{x:Type Border}">

                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />

                                    <Style.Triggers>

                                        <MultiDataTrigger>

                                            <MultiDataTrigger.Conditions>

                                                <Condition
                                                    Binding="{Binding Products.Count}"
                                                    Value="0" />

                                                <Condition
                                                    Binding="{Binding IsLoading}"
                                                    Value="False" />
                                            </MultiDataTrigger.Conditions>

                                            <Setter
                                                Property="Visibility"
                                                Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                                <Border
                                    Width="62"
                                    Height="62"
                                    Background="{StaticResource GoldSoftBrush}"
                                    BorderBrush="{StaticResource GoldBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20">

                                    <TextBlock
                                        Text="&#xE719;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="26"
                                        Foreground="{StaticResource GoldBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>

                                <TextBlock
                                    Text="Chưa có sản phẩm phù hợp"
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,14,0,0" />

                                <TextBlock
                                    Text="Thử thay đổi từ khóa hoặc tạo sản phẩm mới."
                                    Style="{StaticResource SecondaryTextStyle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,5,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Loading -->

                        <Border
                            Background="#D9FFFEFB"
                            Visibility="{Binding IsLoading,
                                Converter={StaticResource BooleanToVisibilityConverter}}">

                            <StackPanel
                                Width="255"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                                <ProgressBar
                                    Height="5"
                                    IsIndeterminate="True"
                                    Foreground="{StaticResource AccentBrush}" />

                                <TextBlock
                                    Text="Đang tải dữ liệu sản phẩm..."
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="12"
                                    HorizontalAlignment="Center"
                                    Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Footer -->

                    <Grid
                        Grid.Row="3"
                        Margin="20,11">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Text="{Binding StatusMessage}"
                            Style="{StaticResource CaptionTextStyle}"
                            VerticalAlignment="Center" />

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal">

                            <Button
                                Content="Trước"
                                Command="{Binding PreviousPageCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="78" />

                            <Border
                                Height="42"
                                Padding="15,0"
                                Margin="9,0"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="8">

                                <TextBlock
                                    Text="{Binding PageText}"
                                    Foreground="White"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center" />
                            </Border>

                            <Button
                                Content="Sau"
                                Command="{Binding NextPageCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="78" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>