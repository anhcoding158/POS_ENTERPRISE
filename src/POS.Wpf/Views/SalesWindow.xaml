<Window
    x:Class="POS.Wpf.Views.SalesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Language="vi-VN"
    Title="POS Enterprise - Quầy bán hàng"
    Width="1440"
    Height="860"
    MinWidth="1180"
    MinHeight="700"
    WindowStartupLocation="CenterOwner"
    WindowState="Maximized"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    Background="{StaticResource AppBackgroundBrush}"
    FontFamily="Segoe UI"
    FontSize="12"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <Window.Resources>

        <!-- =================================================
             SEARCH INPUT
             ================================================= -->
        <Style x:Key="SalesSearchTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource SearchTextBoxStyle}">
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="46,0,14,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- =================================================
             CATEGORY CHIP
             ================================================= -->
        <Style x:Key="SalesCategoryChipStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ChipBorder" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="19">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="{StaticResource GoldSoftBrush}" />
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{StaticResource GoldBorderBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource GoldBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =================================================
             PRODUCT CARD BUTTON
             ================================================= -->
        <Style x:Key="SalesProductCardStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="220" />
            <Setter Property="Height" Value="216" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ProductBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="15" Padding="16">
                            <Border.Effect>
                                <DropShadowEffect Color="#4B3327" BlurRadius="13" ShadowDepth="2" Direction="270" Opacity="0.07" />
                            </Border.Effect>
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ProductBorder" Property="BorderBrush" Value="{StaticResource GoldBrush}" />
                                <Setter TargetName="ProductBorder" Property="Background" Value="#FFFFFCF6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ProductBorder" Property="Background" Value="{StaticResource GoldSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ProductBorder" Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =================================================
             SMALL CART ACTION BUTTON
             ================================================= -->
        <Style x:Key="CartQuantityButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="QuantityBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="QuantityBorder" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="QuantityBorder" Property="BorderBrush" Value="{StaticResource AccentBorderBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="QuantityBorder" Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =================================================
             QUICK CASH BUTTON
             ================================================= -->
        <Style x:Key="QuickCashButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="70" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,7,0" />
        </Style>

        <!-- =================================================
             CHECKOUT BUTTON
             ================================================= -->
        <Style x:Key="LuxuryCheckoutButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="68" />
            <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="CheckoutBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="13" Padding="18,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#661015" BlurRadius="17" ShadowDepth="3" Direction="270" Opacity="0.23" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckoutBorder" Property="Background" Value="{StaticResource AccentPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CheckoutBorder" Property="Opacity" Value="0.43" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="94" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- =================================================
             LUXURY HEADER
             ================================================= -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBrush}" BorderBrush="#745630" BorderThickness="0,0,0,1">
            <Grid Margin="26,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="58" Height="58">
                        <Ellipse Stroke="{StaticResource GoldBrush}" StrokeThickness="1.3" />
                        <Border Width="39" Height="39" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="{StaticResource GoldHoverBrush}" BorderThickness="1" CornerRadius="5" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <RotateTransform Angle="45" />
                            </Border.RenderTransform>
                        </Border>
                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource GoldHoverBrush}" FontSize="23" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="QUẦY BÁN HÀNG" Foreground="{StaticResource GoldHoverBrush}" FontFamily="Georgia" FontSize="25" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Text="POS ENTERPRISE" Foreground="{StaticResource SidebarMutedBrush}" FontSize="10.5" FontWeight="SemiBold" />
                            <TextBlock Text="  ◆  " Foreground="{StaticResource GoldBrush}" FontSize="10" />
                            <TextBlock Text="CASHIER TERMINAL" Foreground="{StaticResource SidebarMutedBrush}" FontSize="10.5" FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Padding="13,9" Margin="0,0,12,0" Background="{StaticResource SidebarSurfaceBrush}" BorderBrush="#684D30" BorderThickness="1" CornerRadius="11">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentCashierName}" Foreground="{StaticResource SidebarTextBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding CurrentRoleText}" Foreground="{StaticResource GoldBrush}" FontSize="10.5" Margin="0,3,0,0" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Border>
                    <Border Padding="12,8" Background="#221E1B" BorderBrush="#4D433C" BorderThickness="1" CornerRadius="11">
                        <StackPanel>
                            <TextBlock Text="F2 Tìm kiếm  •  F4 Tiền đủ  •  F6 Nhập tiền  •  F8 Thanh toán" Foreground="{StaticResource SidebarMutedBrush}" FontSize="10.5" />
                            <TextBlock Text="ESC đóng quầy" Foreground="#9F958B" FontSize="10" Margin="0,3,0,0" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- =================================================
             MAIN SALES WORKSPACE
             ================================================= -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="450" />
            </Grid.ColumnDefinitions>

            <!-- =================================================
                 PRODUCT CATALOG (Cột Trái)
                 ================================================= -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="20,16" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="THỰC ĐƠN BÁN HÀNG" Style="{StaticResource SectionTitleTextStyle}" FontFamily="Georgia" FontSize="19" />
                                <TextBlock Text="{Binding ProductResultText}" Style="{StaticResource CaptionTextStyle}" FontSize="11" Margin="0,4,0,0" />
                            </StackPanel>

                            <Grid Grid.Column="1" Width="510">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="104" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="88" />
                                </Grid.ColumnDefinitions>

                                <Grid>
                                    <TextBox x:Name="ProductSearchBox" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesSearchTextBoxStyle}" />
                                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource GoldBrush}" FontSize="15" Margin="16,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" />
                                    <TextBlock Text="Mã, tên hoặc quét barcode..." Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="45,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Text.Length, ElementName=ProductSearchBox}" Value="0" />
                                                            <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=ProductSearchBox}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <Button Grid.Column="2" Command="{Binding SearchCommand}" Style="{StaticResource PrimaryButtonStyle}" Content="Tìm sản phẩm" />
                                <Button Grid.Column="4" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" Content="Tải lại" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Padding="20,12" Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding CategoryFilters}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Name}" Command="{Binding SelectCommand}" Style="{StaticResource SalesCategoryChipStyle}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20,18,8,14">
                            <ItemsControl ItemsSource="{Binding ProductCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding AddToCartCommand}" IsEnabled="{Binding CanSell}" ToolTip="{Binding AvailabilityText}" ToolTipService.InitialShowDelay="220" Style="{StaticResource SalesProductCardStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Grid>
                                                    <Border HorizontalAlignment="Left" Padding="8,4" Background="{StaticResource GoldSoftBrush}" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="1" CornerRadius="7">
                                                        <TextBlock Text="{Binding CategoryName}" Foreground="{StaticResource GoldBrush}" FontSize="10.5" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="118" />
                                                    </Border>
                                                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Padding="7,4" CornerRadius="7">
                                                        <Border.Style>
                                                            <Style TargetType="{x:Type Border}">
                                                                <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding CanSell}" Value="False">
                                                                        <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding AvailabilityText}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="82">
                                                            <TextBlock.Style>
                                                                <Style TargetType="{x:Type TextBlock}">
                                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding CanSell}" Value="False">
                                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>

                                                <StackPanel Grid.Row="1" Margin="0,12,0,8">
                                                    <Border Width="52" Height="52" HorizontalAlignment="Left" Background="{StaticResource AccentSoftBrush}" BorderBrush="{StaticResource AccentBorderBrush}" BorderThickness="1" CornerRadius="15">
                                                        <TextBlock Text="{Binding ProductInitial}" FontFamily="Georgia" Foreground="{StaticResource AccentBrush}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="42" Margin="0,9,0,0" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding Code}" Foreground="{StaticResource GoldBrush}" FontSize="10.5" FontWeight="SemiBold" />
                                                        <TextBlock Text="  •  " Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" />
                                                        <TextBlock Text="{Binding UnitName}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" />
                                                    </StackPanel>
                                                </StackPanel>

                                                <Grid Grid.Row="2">
                                                    <StackPanel VerticalAlignment="Bottom">
                                                        <TextBlock Text="GIÁ BÁN" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding SalePriceText}" Foreground="{StaticResource AccentBrush}" FontFamily="Georgia" FontSize="18" FontWeight="Bold" Margin="0,2,0,0" />
                                                    </StackPanel>
                                                    <!-- Đã chỉnh lại Margin cho cụm nút bấm bên trong Card -->
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,2">
                                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource GoldBrush}" FontSize="13" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding AddButtonText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty States & Loading cho Catalog -->
                        <Border Background="{StaticResource SurfaceBrush}">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ProductCards.Count}" Value="0" />
                                                <Condition Binding="{Binding IsLoadingProducts}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="66" Height="66" Background="{StaticResource GoldSoftBrush}" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="1" CornerRadius="20">
                                    <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource GoldBrush}" FontSize="27" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Không có món phù hợp" Style="{StaticResource SectionTitleTextStyle}" FontSize="17" HorizontalAlignment="Center" Margin="0,14,0,0" />
                                <TextBlock Text="Thử đổi danh mục, từ khóa hoặc kiểm tra trạng thái sản phẩm." Style="{StaticResource SecondaryTextStyle}" FontSize="11.5" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Background="#E8FFFEFB" Visibility="{Binding IsLoadingProducts, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Width="280" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressBar Height="5" IsIndeterminate="True" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="Đang chuẩn bị thực đơn..." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Center" Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3" Padding="20,10" Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Grid>
                            <TextBlock Text="Giá trên catalog là tạm tính. Hệ thống xác nhận lại giá và tồn kho khi thanh toán." Style="{StaticResource CaptionTextStyle}" FontSize="10.5" VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Ellipse Width="7" Height="7" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,7,0" />
                                <TextBlock Text="Checkout transaction sẵn sàng" Foreground="{StaticResource SuccessBrush}" FontSize="10.5" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- =================================================
                 ORDER AND PAYMENT PANEL (Cột Phải)
                 ================================================= -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header Đơn hàng hiện tại -->
                    <Border Padding="18,15" Background="{StaticResource SidebarBrush}" BorderBrush="#745630" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="41" Height="41" Background="{StaticResource SidebarSurfaceBrush}" BorderBrush="{StaticResource GoldBrush}" BorderThickness="1" CornerRadius="12">
                                    <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource GoldHoverBrush}" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="ĐƠN HÀNG HIỆN TẠI" Foreground="{StaticResource GoldHoverBrush}" FontFamily="Georgia" FontSize="18" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <TextBlock Text="{Binding CartItemCountText}" Foreground="{StaticResource SidebarMutedBrush}" FontSize="10.5" />
                                        <TextBlock Text="  •  " Foreground="{StaticResource GoldBrush}" FontSize="10" />
                                        <TextBlock Text="{Binding CartLineCountText}" Foreground="{StaticResource SidebarMutedBrush}" FontSize="10.5" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding ClearCartCommand}" Content="Làm trống" Style="{StaticResource SecondaryButtonStyle}" Height="38" Padding="12,0" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Danh sách món trong đơn -->
                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14,13">
                            <ItemsControl ItemsSource="{Binding CartLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" Padding="13" Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding ProductName}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13.5" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <TextBlock Text="{Binding ProductCode}" Foreground="{StaticResource GoldBrush}" FontSize="10.5" FontWeight="SemiBold" />
                                                            <TextBlock Text="  •  " Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" />
                                                            <TextBlock Text="{Binding UnitPriceText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Command="{Binding RemoveCommand}" Width="32" Height="32" Background="{StaticResource DangerSoftBrush}" BorderBrush="#EDC3C6" BorderThickness="1" ToolTip="Xóa khỏi đơn" Cursor="Hand">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource DangerBrush}" FontSize="12" />
                                                    </Button>
                                                </Grid>

                                                <Grid Grid.Row="1" Margin="0,11,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="−" Command="{Binding DecreaseCommand}" Style="{StaticResource CartQuantityButtonStyle}" />
                                                        <Border MinWidth="44" Height="32" Margin="6,0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" CornerRadius="8">
                                                            <TextBlock Text="{Binding QuantityText}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <Button Content="+" Command="{Binding IncreaseCommand}" Style="{StaticResource CartQuantityButtonStyle}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding QuantityLimitText}" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="10,0" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2" Text="{Binding LineTotalText}" Foreground="{StaticResource AccentBrush}" FontFamily="Georgia" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty State Đơn hàng -->
                        <Border Background="{StaticResource SurfaceBrush}">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CartLines.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Width="300" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid Width="72" Height="72" HorizontalAlignment="Center">
                                    <Ellipse Stroke="{StaticResource GoldBorderBrush}" StrokeThickness="1.2" />
                                    <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource GoldBrush}" FontSize="29" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                                <TextBlock Text="Đơn hàng đang trống" Style="{StaticResource SectionTitleTextStyle}" FontSize="17" HorizontalAlignment="Center" Margin="0,14,0,0" />
                                <TextBlock Text="Chọn món bên trái hoặc quét barcode để bắt đầu bán hàng." Style="{StaticResource SecondaryTextStyle}" FontSize="11.5" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,7,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- =================================================
                         KHU VỰC THANH TOÁN BÊN DƯỚI
                         ================================================= -->
                    <Border Grid.Row="2" Padding="16,14,16,16" Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <StackPanel>

                            <!-- Banner Giao dịch thành công -->
                            <Border Margin="0,0,0,14" Padding="13" Background="{StaticResource SuccessSoftBrush}" BorderBrush="#B4DCC4" BorderThickness="1" CornerRadius="12" Visibility="{Binding HasLastOrder, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="38" Height="38" Background="#F7FFFA" BorderBrush="#A6D4B8" BorderThickness="1" CornerRadius="11" VerticalAlignment="Top">
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource SuccessBrush}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="11,0,10,0" VerticalAlignment="Center">
                                        <TextBlock Text="GIAO DỊCH VỪA HOÀN TẤT" Foreground="{StaticResource SuccessBrush}" FontSize="10.5" FontWeight="Bold" />
                                        <TextBlock Text="{Binding LastOrderCode}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" ToolTip="{Binding LastOrderCode}" />
                                        <TextBlock Text="{Binding LastOrderSummary}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="2" Padding="8,4" Background="#E6F5EC" BorderBrush="#B4DCC4" BorderThickness="1" CornerRadius="8" VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" Margin="0,0,5,0" VerticalAlignment="Center" />
                                            <TextBlock Text="TỰ ẨN 7 GIÂY" Foreground="{StaticResource SuccessBrush}" FontSize="9.5" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <TextBlock Text="Ghi chú đơn hàng" Foreground="{StaticResource TextPrimaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="1,0,0,6" />
                            <TextBox Text="{Binding OrderNotes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchTextBoxStyle}" Height="40" Padding="11,0" MaxLength="500" FontSize="12" VerticalContentAlignment="Center" ToolTip="Ghi chú sẽ được lưu cùng đơn hàng." />

                            <!-- TỔNG THANH TOÁN -->
                            <Border Margin="0,16,0,0" Padding="14,12" Background="{StaticResource SidebarBrush}" BorderBrush="#745630" BorderThickness="1" CornerRadius="11">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="TỔNG THANH TOÁN" Foreground="{StaticResource SidebarMutedBrush}" FontSize="10.5" FontWeight="SemiBold" />
                                        <TextBlock Text="Tiền mặt" Foreground="#AAA097" FontSize="10" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding EstimatedTotalText}" Foreground="{StaticResource GoldHoverBrush}" FontFamily="Georgia" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <!-- TIỀN KHÁCH ĐƯA: Đã sửa lại Layout bằng Grid 2 Row -->
                            <Grid Margin="0,16,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="116" />
                                </Grid.ColumnDefinitions>

                                <!-- Nhãn (Row 0) -->
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Tiền khách đưa" Foreground="{StaticResource TextPrimaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="1,0,0,6" />

                                <!-- TextBox và Nút F4 nằm ngang nhau ở Row 1 -->
                                <TextBox Grid.Row="1" Grid.Column="0" x:Name="CashReceivedTextBox" Text="{Binding CashReceivedText, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="OnCashPreviewTextInput" TextChanged="OnCashTextChanged" InputMethod.IsInputMethodEnabled="False" Style="{StaticResource SearchTextBoxStyle}" Height="48" Padding="13,0" FontSize="17" FontWeight="SemiBold" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" MaxLength="24" ToolTip="Chỉ nhập chữ số. F6 để chuyển nhanh tới ô này." />

                                <Button Grid.Row="1" Grid.Column="2" Command="{Binding ExactCashCommand}" Style="{StaticResource SecondaryButtonStyle}" Height="48" Content="F4 • Tiền đủ" />
                            </Grid>

                            <!-- GỢI Ý TIỀN NHANH -->
                            <Grid Margin="1,12,1,0">
                                <TextBlock Text="GỢI Ý TIỀN NHANH" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="SemiBold" />
                                <TextBlock Text="Thay đổi theo số đang nhập" Foreground="{StaticResource GoldBrush}" FontSize="10" HorizontalAlignment="Right" />
                            </Grid>

                            <UniformGrid Columns="4" Margin="0,6,0,0">
                                <Button Content="{Binding QuickCash1Text}" Command="{Binding QuickCash1Command}" Style="{StaticResource QuickCashButtonStyle}" Margin="0,0,5,0" />
                                <Button Content="{Binding QuickCash2Text}" Command="{Binding QuickCash2Command}" Style="{StaticResource QuickCashButtonStyle}" Margin="2,0,3,0" />
                                <Button Content="{Binding QuickCash3Text}" Command="{Binding QuickCash3Command}" Style="{StaticResource QuickCashButtonStyle}" Margin="3,0,2,0" />
                                <Button Content="{Binding QuickCash4Text}" Command="{Binding QuickCash4Command}" Style="{StaticResource QuickCashButtonStyle}" Margin="5,0,0,0" />
                            </UniformGrid>

                            <!-- TIỀN THỪA -->
                            <Grid Margin="1,14,1,0">
                                <StackPanel>
                                    <TextBlock Text="Tiền khách đưa" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" />
                                    <TextBlock Text="{Binding CashPreviewText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,2,0,0" />
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right">
                                    <TextBlock Text="Tiền trả lại" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding ChangePreviewText}" FontFamily="Georgia" FontSize="18" FontWeight="Bold" Margin="0,2,0,0" HorizontalAlignment="Right">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasEnoughCash}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="{Binding CashHintText}" Style="{StaticResource CaptionTextStyle}" FontSize="10.5" TextWrapping="Wrap" Margin="1,9,0,0" />

                            <Border Margin="0,12,0,0" Padding="11,9" BorderThickness="1" CornerRadius="9" Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border.Style>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="Background" Value="{StaticResource GoldSoftBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource GoldBorderBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                                <Setter Property="BorderBrush" Value="#EAC0C3" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                                                <Setter Property="BorderBrush" Value="#BBDCC8" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="11" TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Foreground" Value="{StaticResource GoldBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <Button Command="{Binding CheckoutCommand}" Style="{StaticResource LuxuryCheckoutButtonStyle}" Margin="0,16,0,0">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <StackPanel>
                                            <TextBlock Text="THANH TOÁN TIỀN MẶT" FontSize="14.5" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="F8 • Xác nhận giá và tồn kho" FontSize="10.5" Foreground="#F5D9D9" Margin="0,3,0,0" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                    <ProgressBar Width="76" Height="4" HorizontalAlignment="Right" VerticalAlignment="Center" IsIndeterminate="True" Foreground="White" Background="#40FFFFFF" Visibility="{Binding IsCheckingOut, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- =================================================
             CHECKOUT TRANSACTION LOCK
             ================================================= -->
        <Border Grid.RowSpan="2" Panel.ZIndex="999" Background="#C7F7F2EA" Visibility="{Binding IsCheckingOut, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="390" Padding="28" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="1" CornerRadius="18">
                <Border.Effect>
                    <DropShadowEffect Color="#332015" BlurRadius="28" ShadowDepth="4" Direction="270" Opacity="0.24" />
                </Border.Effect>
                <StackPanel>
                    <Grid Width="72" Height="72" HorizontalAlignment="Center">
                        <Ellipse Stroke="{StaticResource GoldBorderBrush}" StrokeThickness="1.5" />
                        <Border Width="47" Height="47" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{StaticResource GoldSoftBrush}" BorderBrush="{StaticResource GoldBrush}" BorderThickness="1" CornerRadius="14">
                            <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource GoldBrush}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <TextBlock Text="ĐANG HOÀN TẤT GIAO DỊCH" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Georgia" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" Margin="0,18,0,0" />
                    <TextBlock Text="Hệ thống đang xác nhận giá, tồn kho và lưu đơn hàng trong một transaction an toàn." Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextAlignment="Center" TextWrapping="Wrap" LineHeight="18" Margin="12,9,12,0" />
                    <ProgressBar Height="6" Margin="18,20,18,0" IsIndeterminate="True" Foreground="{StaticResource AccentBrush}" Background="{StaticResource AccentSoftBrush}" />
                    <TextBlock Text="Không đóng ứng dụng hoặc thao tác thêm trong lúc này." Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" TextAlignment="Center" Margin="0,12,0,0" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>