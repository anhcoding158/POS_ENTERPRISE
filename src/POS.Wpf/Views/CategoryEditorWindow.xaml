<Window
    x:Class="POS.Wpf.Views.CategoryEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Language="vi-VN"
    Title="{Binding WindowTitle}"
    Width="720"
    Height="660"
    MinWidth="620"
    MinHeight="560"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    Background="{StaticResource AppBackgroundBrush}"
    FontFamily="Segoe UI"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <Window.Resources>

        <Style
            x:Key="CategoryEditorLabelStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}" />

            <Setter
                Property="FontSize"
                Value="12" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />

            <Setter
                Property="Margin"
                Value="0,0,0,7" />

            <Setter
                Property="TextWrapping"
                Value="Wrap" />
        </Style>

        <Style
            x:Key="CategoryEditorTextBoxStyle"
            TargetType="{x:Type TextBox}"
            BasedOn="{StaticResource SearchTextBoxStyle}">

            <Setter
                Property="Height"
                Value="44" />

            <Setter
                Property="Padding"
                Value="13,0" />

            <Setter
                Property="FontSize"
                Value="13" />
        </Style>

        <Style
            x:Key="CategoryEditorErrorStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="{StaticResource DangerBrush}" />

            <Setter
                Property="FontSize"
                Value="10" />

            <Setter
                Property="TextWrapping"
                Value="Wrap" />

            <Setter
                Property="Margin"
                Value="2,5,0,0" />

            <Style.Triggers>

                <Trigger
                    Property="Text"
                    Value="">

                    <Setter
                        Property="Visibility"
                        Value="Collapsed" />
                </Trigger>

                <Trigger
                    Property="Text"
                    Value="{x:Null}">

                    <Setter
                        Property="Visibility"
                        Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>

            <!-- Header -->
            <RowDefinition Height="104" />

            <!-- Form -->
            <RowDefinition Height="*" />

            <!-- Footer -->
            <RowDefinition Height="76" />

        </Grid.RowDefinitions>

        <!-- Header -->

        <Border
            Grid.Row="0"
            Background="{StaticResource SidebarBrush}"
            BorderBrush="#6A4C27"
            BorderThickness="0,0,0,1">

            <Grid Margin="26,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <Border
                        Width="50"
                        Height="50"
                        Background="{StaticResource SidebarSurfaceBrush}"
                        BorderBrush="{StaticResource GoldBrush}"
                        BorderThickness="1"
                        CornerRadius="14">

                        <TextBlock
                            Text="&#xE8EC;"
                            FontFamily="Segoe MDL2 Assets"
                            Foreground="{StaticResource GoldHoverBrush}"
                            FontSize="22"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>

                    <StackPanel
                        Margin="14,0,0,0"
                        VerticalAlignment="Center">

                        <TextBlock
                            Text="{Binding HeaderTitle}"
                            Foreground="{StaticResource GoldHoverBrush}"
                            FontFamily="Georgia"
                            FontSize="21"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="{Binding HeaderDescription}"
                            Foreground="{StaticResource SidebarMutedBrush}"
                            FontSize="11"
                            TextWrapping="Wrap"
                            MaxWidth="470"
                            Margin="0,5,0,0" />
                    </StackPanel>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="10,5"
                    Background="{StaticResource SidebarSurfaceBrush}"
                    BorderBrush="{StaticResource GoldBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    VerticalAlignment="Center">

                    <TextBlock
                        Text="{Binding ModeBadgeText}"
                        Foreground="{StaticResource GoldHoverBrush}"
                        FontSize="9"
                        FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <!-- Form -->

        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="24,20,24,24">

                <Border
                    Style="{StaticResource CardStyle}"
                    Padding="22">

                    <StackPanel>

                        <TextBlock
                            Text="Thông tin danh mục"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <TextBlock
                            Text="Tên danh mục cần rõ ràng, dễ hiểu và không trùng với danh mục khác."
                            Style="{StaticResource CaptionTextStyle}"
                            TextWrapping="Wrap"
                            Margin="0,5,0,20" />

                        <!-- Name -->

                        <TextBlock
                            Text="Tên danh mục *"
                            Style="{StaticResource CategoryEditorLabelStyle}" />

                        <TextBox
                            Text="{Binding Name,
                                UpdateSourceTrigger=PropertyChanged,
                                ValidatesOnNotifyDataErrors=True}"
                            Style="{StaticResource CategoryEditorTextBoxStyle}"
                            MaxLength="100" />

                        <TextBlock
                            Text="{Binding NameError}"
                            Style="{StaticResource CategoryEditorErrorStyle}" />

                        <!-- Display order -->

                        <TextBlock
                            Text="Thứ tự hiển thị *"
                            Style="{StaticResource CategoryEditorLabelStyle}"
                            Margin="0,18,0,7" />

                        <TextBox
                            Text="{Binding DisplayOrderText,
                                UpdateSourceTrigger=PropertyChanged,
                                ValidatesOnNotifyDataErrors=True}"
                            Style="{StaticResource CategoryEditorTextBoxStyle}"
                            MaxLength="10" />

                        <TextBlock
                            Text="{Binding DisplayOrderError}"
                            Style="{StaticResource CategoryEditorErrorStyle}" />

                        <TextBlock
                            Text="Số nhỏ hơn sẽ được hiển thị trước. Các danh mục cùng thứ tự sẽ được sắp theo tên."
                            Style="{StaticResource CaptionTextStyle}"
                            TextWrapping="Wrap"
                            Margin="2,6,0,0" />

                        <!-- Description -->

                        <Grid Margin="0,18,0,7">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Text="Mô tả"
                                Style="{StaticResource CategoryEditorLabelStyle}"
                                Margin="0" />

                            <TextBlock
                                Grid.Column="1"
                                Text="{Binding DescriptionLengthText}"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="12,0,0,0" />
                        </Grid>

                        <TextBox
                            Text="{Binding Description,
                                UpdateSourceTrigger=PropertyChanged,
                                ValidatesOnNotifyDataErrors=True}"
                            Height="112"
                            MinHeight="90"
                            MaxLength="500"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalContentAlignment="Top"
                            VerticalScrollBarVisibility="Auto"
                            Padding="13,10"
                            FontSize="13"
                            Background="{StaticResource SurfaceBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource BorderStrongBrush}"
                            BorderThickness="1" />

                        <TextBlock
                            Text="{Binding DescriptionError}"
                            Style="{StaticResource CategoryEditorErrorStyle}" />

                        <!-- Active -->

                        <Border
                            Margin="0,20,0,0"
                            Padding="14"
                            Background="{StaticResource SurfaceMutedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock
                                        Text="Trạng thái hoạt động"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        FontSize="12"
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Text="Danh mục ngừng hoạt động sẽ không xuất hiện trong danh sách chọn của sản phẩm mới."
                                        Style="{StaticResource CaptionTextStyle}"
                                        TextWrapping="Wrap"
                                        MaxWidth="470"
                                        Margin="0,5,12,0" />
                                </StackPanel>

                                <CheckBox
                                    Grid.Column="1"
                                    Content="Đang hoạt động"
                                    IsChecked="{Binding IsActive,
                                        Mode=TwoWay}"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Status -->

                <Border
                    Margin="0,16,0,0"
                    Padding="13,11"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding HasStatusMessage,
                        Converter={StaticResource BooleanToVisibilityConverter}}">

                    <Border.Style>
                        <Style TargetType="{x:Type Border}">

                            <Setter
                                Property="Background"
                                Value="{StaticResource GoldSoftBrush}" />

                            <Setter
                                Property="BorderBrush"
                                Value="{StaticResource GoldBorderBrush}" />

                            <Style.Triggers>

                                <DataTrigger
                                    Binding="{Binding IsStatusError}"
                                    Value="True">

                                    <Setter
                                        Property="Background"
                                        Value="{StaticResource DangerSoftBrush}" />

                                    <Setter
                                        Property="BorderBrush"
                                        Value="#F0C8CA" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <TextBlock
                        Text="{Binding StatusMessage}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontSize="11"
                        TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->

        <Border
            Grid.Row="2"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">

            <Grid Margin="24,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Text="Các trường có dấu * là bắt buộc."
                    Style="{StaticResource CaptionTextStyle}"
                    VerticalAlignment="Center" />

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <Button
                        Content="Hủy"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="100"
                        IsCancel="True" />

                    <Button
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinWidth="150"
                        IsDefault="True"
                        Margin="10,0,0,0">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock
                                Text="&#xE74E;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="13"
                                Margin="0,0,8,0" />

                            <TextBlock
                                Text="{Binding SaveButtonText}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Busy overlay -->

        <Border
            Grid.RowSpan="3"
            Background="#BFFFFFFB"
            Visibility="{Binding IsBusy,
                Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border
                Width="290"
                Padding="24"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource GoldBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <StackPanel>

                    <ProgressBar
                        Height="5"
                        IsIndeterminate="True"
                        Foreground="{StaticResource AccentBrush}" />

                    <TextBlock
                        Text="Đang xử lý danh mục..."
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="12"
                        HorizontalAlignment="Center"
                        Margin="0,14,0,0" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>