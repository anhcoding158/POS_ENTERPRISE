<Window
    x:Class="POS.Wpf.Views.ReceiptPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Language="vi-VN"
    Title="POS Enterprise - Xem trước hóa đơn"
    Width="1120"
    Height="790"
    MinWidth="940"
    MinHeight="680"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    Background="{StaticResource AppBackgroundBrush}"
    FontFamily="Segoe UI"
    FontSize="12"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
    PreviewKeyDown="OnPreviewKeyDown"
    Closing="OnWindowClosing"
    Closed="OnWindowClosed">

    <Window.Resources>

        <Style
            x:Key="PreviewInfoLabelStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="#AFA49A" />

            <Setter
                Property="FontSize"
                Value="10.5" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />
        </Style>

        <Style
            x:Key="PreviewInfoValueStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="#FFF8EE" />

            <Setter
                Property="FontSize"
                Value="13" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />

            <Setter
                Property="TextWrapping"
                Value="Wrap" />

            <Setter
                Property="Margin"
                Value="0,4,0,0" />
        </Style>

        <Style
            x:Key="PreviewMetricCardStyle"
            TargetType="{x:Type Border}">

            <Setter
                Property="Background"
                Value="#28221E" />

            <Setter
                Property="BorderBrush"
                Value="#58493D" />

            <Setter
                Property="BorderThickness"
                Value="1" />

            <Setter
                Property="CornerRadius"
                Value="12" />

            <Setter
                Property="Padding"
                Value="14,12" />
        </Style>

        <Style
            x:Key="PreviewCloseButtonStyle"
            TargetType="{x:Type Button}"
            BasedOn="{StaticResource SecondaryButtonStyle}">

            <Setter
                Property="Height"
                Value="48" />

            <Setter
                Property="MinWidth"
                Value="126" />

            <Setter
                Property="Padding"
                Value="22,0" />

            <Setter
                Property="FontSize"
                Value="12.5" />
        </Style>

        <Style
            x:Key="PreviewPrintButtonStyle"
            TargetType="{x:Type Button}"
            BasedOn="{StaticResource PrimaryButtonStyle}">

            <Setter
                Property="Height"
                Value="48" />

            <Setter
                Property="MinWidth"
                Value="174" />

            <Setter
                Property="Padding"
                Value="24,0" />

            <Setter
                Property="FontSize"
                Value="12.5" />
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="88" />
            <RowDefinition Height="*" />
            <RowDefinition Height="82" />
        </Grid.RowDefinitions>

        <!-- Header -->

        <Border
            Grid.Row="0"
            Background="{StaticResource SidebarBrush}"
            BorderBrush="#745630"
            BorderThickness="0,0,0,1">

            <Grid Margin="26,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <Grid
                        Width="54"
                        Height="54">

                        <Ellipse
                            Stroke="{StaticResource GoldBrush}"
                            StrokeThickness="1.2" />

                        <Border
                            Width="36"
                            Height="36"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#302923"
                            BorderBrush="{StaticResource GoldBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="11">

                            <TextBlock
                                Text="&#xE749;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="{StaticResource GoldHoverBrush}"
                                FontSize="20"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <StackPanel
                        Margin="15,0,0,0"
                        VerticalAlignment="Center">

                        <TextBlock
                            Text="XEM TRƯỚC HÓA ĐƠN"
                            Foreground="{StaticResource GoldHoverBrush}"
                            FontFamily="Georgia"
                            FontSize="22"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="Bản xem trước khổ K80 từ dữ liệu giao dịch đã chốt"
                            Foreground="{StaticResource SidebarMutedBrush}"
                            FontSize="10.5"
                            Margin="0,5,0,0" />
                    </StackPanel>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="12,8"
                    Background="#28221E"
                    BorderBrush="#594B3F"
                    BorderThickness="1"
                    CornerRadius="10"
                    VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal">

                        <Ellipse
                            Width="7"
                            Height="7"
                            Fill="{StaticResource SuccessBrush}"
                            Margin="0,0,7,0"
                            VerticalAlignment="Center" />

                        <TextBlock
                            x:Name="CopyKindBadgeText"
                            Text="BẢN GỐC"
                            Foreground="{StaticResource GoldHoverBrush}"
                            FontSize="10.5"
                            FontWeight="Bold"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main -->

        <Grid
            Grid.Row="1"
            Margin="18">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="316" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Transaction summary -->

            <Border
                Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="#674F39"
                BorderThickness="1"
                CornerRadius="16"
                Padding="20">

                <Border.Effect>
                    <DropShadowEffect
                        Color="#3A2418"
                        BlurRadius="18"
                        ShadowDepth="3"
                        Direction="270"
                        Opacity="0.15" />
                </Border.Effect>

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>

                        <TextBlock
                            Text="THÔNG TIN GIAO DỊCH"
                            Foreground="{StaticResource GoldBrush}"
                            FontSize="10.5"
                            FontWeight="Bold" />

                        <TextBlock
                            Text="Hóa đơn vừa hoàn tất"
                            Foreground="#FFF8EE"
                            FontFamily="Georgia"
                            FontSize="19"
                            FontWeight="SemiBold"
                            Margin="0,7,0,0" />

                        <TextBlock
                            Text="Dữ liệu bên dưới không đọc lại từ sản phẩm hiện tại."
                            Foreground="#AFA49A"
                            FontSize="10.5"
                            TextWrapping="Wrap"
                            LineHeight="17"
                            Margin="0,7,0,0" />
                    </StackPanel>

                    <Border
                        Grid.Row="1"
                        Style="{StaticResource PreviewMetricCardStyle}"
                        Margin="0,18,0,0">

                        <StackPanel>

                            <TextBlock
                                Text="MÃ ĐƠN"
                                Style="{StaticResource PreviewInfoLabelStyle}" />

                            <TextBlock
                                x:Name="OrderCodeText"
                                Text="—"
                                Style="{StaticResource PreviewInfoValueStyle}"
                                Foreground="{StaticResource GoldHoverBrush}"
                                FontFamily="Consolas"
                                FontSize="14" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="2"
                        Style="{StaticResource PreviewMetricCardStyle}"
                        Margin="0,10,0,0">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>

                                <TextBlock
                                    Text="THỜI GIAN"
                                    Style="{StaticResource PreviewInfoLabelStyle}" />

                                <TextBlock
                                    x:Name="PaidAtText"
                                    Text="—"
                                    Style="{StaticResource PreviewInfoValueStyle}"
                                    FontSize="11.5" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="1"
                                Margin="12,0,0,0">

                                <TextBlock
                                    Text="THU NGÂN"
                                    Style="{StaticResource PreviewInfoLabelStyle}" />

                                <TextBlock
                                    x:Name="CashierText"
                                    Text="—"
                                    Style="{StaticResource PreviewInfoValueStyle}"
                                    FontSize="11.5" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Row="3"
                        Style="{StaticResource PreviewMetricCardStyle}"
                        Margin="0,10,0,0">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>

                                <TextBlock
                                    Text="SỐ LƯỢNG"
                                    Style="{StaticResource PreviewInfoLabelStyle}" />

                                <TextBlock
                                    x:Name="ItemCountText"
                                    Text="—"
                                    Style="{StaticResource PreviewInfoValueStyle}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="1"
                                Margin="12,0,0,0">

                                <TextBlock
                                    Text="THANH TOÁN"
                                    Style="{StaticResource PreviewInfoLabelStyle}" />

                                <TextBlock
                                    x:Name="PaymentMethodText"
                                    Text="—"
                                    Style="{StaticResource PreviewInfoValueStyle}"
                                    FontSize="11.5" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Row="4"
                        Margin="0,12,0,0"
                        Padding="15,13"
                        Background="#3A1719"
                        BorderBrush="#7A3035"
                        BorderThickness="1"
                        CornerRadius="12">

                        <Grid>

                            <StackPanel>

                                <TextBlock
                                    Text="TỔNG THANH TOÁN"
                                    Foreground="#D8BBB9"
                                    FontSize="10.5"
                                    FontWeight="SemiBold" />

                                <TextBlock
                                    Text="Đã được transaction xác nhận"
                                    Foreground="#A98B8A"
                                    FontSize="9.5"
                                    Margin="0,4,0,0" />
                            </StackPanel>

                            <TextBlock
                                x:Name="TotalAmountText"
                                Text="0 ₫"
                                Foreground="#FFE2A8"
                                FontFamily="Georgia"
                                FontSize="23"
                                FontWeight="Bold"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <StackPanel
                        Grid.Row="6"
                        Margin="0,18,0,0">

                        <Border
                            Height="1"
                            Background="#4C4038"
                            Margin="0,0,0,14" />

                        <StackPanel Orientation="Horizontal">

                            <TextBlock
                                Text="&#xE72E;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="{StaticResource SuccessBrush}"
                                FontSize="13"
                                Margin="0,0,8,0"
                                VerticalAlignment="Top" />

                            <TextBlock
                                Text="Lỗi xem trước hoặc lỗi máy in không làm đảo ngược giao dịch đã lưu."
                                Foreground="#AFA49A"
                                FontSize="10"
                                TextWrapping="Wrap"
                                LineHeight="16"
                                Width="235" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Receipt paper preview -->

            <Border
                Grid.Column="2"
                Background="#E8E0D4"
                BorderBrush="#D1C4B3"
                BorderThickness="1"
                CornerRadius="16"
                Padding="20">

                <Border.Effect>
                    <DropShadowEffect
                        Color="#4B3327"
                        BlurRadius="18"
                        ShadowDepth="3"
                        Direction="270"
                        Opacity="0.12" />
                </Border.Effect>

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="2,0,2,13">

                        <StackPanel>

                            <TextBlock
                                Text="BẢN XEM TRƯỚC KHỔ K80"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                FontSize="11"
                                FontWeight="Bold" />

                            <TextBlock
                                Text="Nội dung hiển thị bên dưới chính là tài liệu được gửi tới máy in."
                                Foreground="{StaticResource TextSecondaryBrush}"
                                FontSize="10.5"
                                Margin="0,4,0,0" />
                        </StackPanel>

                        <Border
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Padding="9,5"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderStrongBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE8A5;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Foreground="{StaticResource GoldBrush}"
                                    FontSize="12"
                                    Margin="0,0,6,0" />

                                <TextBlock
                                    Text="80 MM"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="10"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border
                        Grid.Row="1"
                        Width="430"
                        MaxWidth="510"
                        HorizontalAlignment="Center"
                        Background="White"
                        BorderBrush="#D3CCC2"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="1">

                        <Border.Effect>
                            <DropShadowEffect
                                Color="#584536"
                                BlurRadius="18"
                                ShadowDepth="4"
                                Direction="270"
                                Opacity="0.18" />
                        </Border.Effect>

                        <FlowDocumentScrollViewer
                            x:Name="ReceiptViewer"
                            Background="White"
                            BorderThickness="0"
                            IsToolBarVisible="False"
                            IsSelectionEnabled="True"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            Zoom="100"
                            MinZoom="80"
                            MaxZoom="160" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Action bar -->

        <Border
            Grid.Row="2"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">

            <Grid Margin="24,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="StatusBorder"
                    MaxWidth="630"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Padding="12,9"
                    Background="{StaticResource GoldSoftBrush}"
                    BorderBrush="{StaticResource GoldBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="StatusIcon"
                            Text="&#xE946;"
                            FontFamily="Segoe MDL2 Assets"
                            Foreground="{StaticResource GoldBrush}"
                            FontSize="14"
                            VerticalAlignment="Center" />

                        <StackPanel
                            Grid.Column="1"
                            Margin="9,0,0,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                x:Name="StatusText"
                                Text="Kiểm tra nội dung trước khi gửi tới máy in."
                                Foreground="{StaticResource GoldBrush}"
                                FontSize="10.5"
                                TextWrapping="Wrap" />

                            <ProgressBar
                                x:Name="PrintingProgress"
                                Height="3"
                                Margin="0,7,0,0"
                                IsIndeterminate="True"
                                Foreground="{StaticResource AccentBrush}"
                                Background="{StaticResource AccentSoftBrush}"
                                Visibility="Collapsed" />
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <Button
                        x:Name="CloseButton"
                        Content="ĐÓNG"
                        Style="{StaticResource PreviewCloseButtonStyle}"
                        Click="OnCloseClick"
                        Margin="0,0,10,0" />

                    <Button
                        x:Name="PrintButton"
                        Style="{StaticResource PreviewPrintButtonStyle}"
                        Click="OnPrintClick">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock
                                Text="&#xE749;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                Margin="0,0,9,0"
                                VerticalAlignment="Center" />

                            <StackPanel>

                                <TextBlock
                                    x:Name="PrintButtonTitleText"
                                    Text="IN HÓA ĐƠN"
                                    FontSize="12.5"
                                    FontWeight="SemiBold"
                                    HorizontalAlignment="Center" />

                                <TextBlock
                                    Text="Ctrl+P"
                                    FontSize="9.5"
                                    Foreground="#F5D9D9"
                                    Margin="0,2,0,0"
                                    HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Printing lock -->

        <Border
            x:Name="PrintingOverlay"
            Grid.RowSpan="3"
            Panel.ZIndex="999"
            Background="#91F7F2EA"
            Visibility="Collapsed">

            <Border
                Width="350"
                Padding="25"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource GoldBorderBrush}"
                BorderThickness="1"
                CornerRadius="17">

                <Border.Effect>
                    <DropShadowEffect
                        Color="#392317"
                        BlurRadius="28"
                        ShadowDepth="4"
                        Direction="270"
                        Opacity="0.25" />
                </Border.Effect>

                <StackPanel>

                    <Border
                        Width="58"
                        Height="58"
                        HorizontalAlignment="Center"
                        Background="{StaticResource GoldSoftBrush}"
                        BorderBrush="{StaticResource GoldBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="17">

                        <TextBlock
                            Text="&#xE749;"
                            FontFamily="Segoe MDL2 Assets"
                            Foreground="{StaticResource GoldBrush}"
                            FontSize="25"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>

                    <TextBlock
                        Text="ĐANG GỬI HÓA ĐƠN"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontFamily="Georgia"
                        FontSize="17"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Margin="0,16,0,0" />

                    <TextBlock
                        Text="Vui lòng không đóng cửa sổ hoặc bấm in lần nữa."
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="10.5"
                        TextAlignment="Center"
                        TextWrapping="Wrap"
                        Margin="0,8,0,0" />

                    <ProgressBar
                        Height="5"
                        Margin="16,18,16,0"
                        IsIndeterminate="True"
                        Foreground="{StaticResource AccentBrush}"
                        Background="{StaticResource AccentSoftBrush}" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>