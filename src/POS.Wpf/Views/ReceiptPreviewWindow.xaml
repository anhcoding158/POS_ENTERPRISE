<Window
    x:Class="POS.Wpf.Views.ReceiptPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Language="vi-VN"
    Title="POS Enterprise - Xem trước hóa đơn"
    Width="1380"
    Height="900"
    MinWidth="1100"
    MinHeight="720"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    Background="#F4EFE7"
    FontFamily="Segoe UI"
    FontSize="12"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
    PreviewKeyDown="OnPreviewKeyDown"
    Closing="OnWindowClosing"
    Closed="OnWindowClosed">

    <Window.Resources>

        <LinearGradientBrush
            x:Key="ReceiptPreviewHeaderBrush"
            StartPoint="0,0"
            EndPoint="1,0">

            <GradientStop
                Color="#151311"
                Offset="0" />

            <GradientStop
                Color="#1E1B18"
                Offset="0.58" />

            <GradientStop
                Color="#171513"
                Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush
            x:Key="ReceiptPreviewPanelBrush"
            StartPoint="0,0"
            EndPoint="1,1">

            <GradientStop
                Color="#1B1815"
                Offset="0" />

            <GradientStop
                Color="#211D19"
                Offset="0.6" />

            <GradientStop
                Color="#181512"
                Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush
            x:Key="ReceiptPreviewTotalBrush"
            StartPoint="0,0"
            EndPoint="1,0">

            <GradientStop
                Color="#3A1719"
                Offset="0" />

            <GradientStop
                Color="#4B1B1E"
                Offset="0.55" />

            <GradientStop
                Color="#321517"
                Offset="1" />
        </LinearGradientBrush>

        <Style
            x:Key="PreviewInfoLabelStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="#AFA49A" />

            <Setter
                Property="FontSize"
                Value="10.5" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />

            <Setter
                Property="TextOptions.TextFormattingMode"
                Value="Display" />
        </Style>

        <Style
            x:Key="PreviewInfoValueStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="#FFF9F0" />

            <Setter
                Property="FontSize"
                Value="13" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />

            <Setter
                Property="TextWrapping"
                Value="Wrap" />

            <Setter
                Property="Margin"
                Value="0,5,0,0" />
        </Style>

        <Style
            x:Key="PreviewMetricCardStyle"
            TargetType="{x:Type Border}">

            <Setter
                Property="Background"
                Value="#2A2521" />

            <Setter
                Property="BorderBrush"
                Value="#55483D" />

            <Setter
                Property="BorderThickness"
                Value="1" />

            <Setter
                Property="CornerRadius"
                Value="13" />

            <Setter
                Property="Padding"
                Value="15,13" />
        </Style>

        <Style
            x:Key="PreviewCloseButtonStyle"
            TargetType="{x:Type Button}"
            BasedOn="{StaticResource SecondaryButtonStyle}">

            <Setter
                Property="Height"
                Value="50" />

            <Setter
                Property="MinWidth"
                Value="142" />

            <Setter
                Property="Padding"
                Value="24,0" />

            <Setter
                Property="FontSize"
                Value="12.5" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />
        </Style>

        <Style
            x:Key="PreviewPrintButtonStyle"
            TargetType="{x:Type Button}">

            <Setter
                Property="Height"
                Value="50" />

            <Setter
                Property="MinWidth"
                Value="204" />

            <Setter
                Property="Padding"
                Value="25,0" />

            <Setter
                Property="Foreground"
                Value="White" />

            <Setter
                Property="Background"
                Value="#A51119" />

            <Setter
                Property="BorderBrush"
                Value="#D2A84B" />

            <Setter
                Property="BorderThickness"
                Value="1" />

            <Setter
                Property="Cursor"
                Value="Hand" />

            <Setter
                Property="Template">

                <Setter.Value>

                    <ControlTemplate
                        TargetType="{x:Type Button}">

                        <Border
                            x:Name="PrintButtonBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">

                            <Border.Effect>

                                <DropShadowEffect
                                    Color="#6C0E14"
                                    BlurRadius="15"
                                    ShadowDepth="3"
                                    Direction="270"
                                    Opacity="0.25" />
                            </Border.Effect>

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger
                                Property="IsMouseOver"
                                Value="True">

                                <Setter
                                    TargetName="PrintButtonBorder"
                                    Property="Background"
                                    Value="#BD1721" />

                                <Setter
                                    TargetName="PrintButtonBorder"
                                    Property="BorderBrush"
                                    Value="#E4BF68" />
                            </Trigger>

                            <Trigger
                                Property="IsPressed"
                                Value="True">

                                <Setter
                                    TargetName="PrintButtonBorder"
                                    Property="Background"
                                    Value="#861017" />
                            </Trigger>

                            <Trigger
                                Property="IsEnabled"
                                Value="False">

                                <Setter
                                    TargetName="PrintButtonBorder"
                                    Property="Opacity"
                                    Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="102" />
            <RowDefinition Height="*" />
            <RowDefinition Height="86" />
        </Grid.RowDefinitions>

        <!-- =====================================================
             PREMIUM HEADER
             ===================================================== -->

        <Border
            Grid.Row="0"
            Background="{StaticResource ReceiptPreviewHeaderBrush}"
            BorderBrush="#8A6834"
            BorderThickness="0,0,0,1">

            <Grid Margin="30,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <Grid
                        Width="64"
                        Height="64">

                        <Ellipse
                            Stroke="#B98A31"
                            StrokeThickness="1.4" />

                        <Ellipse
                            Width="48"
                            Height="48"
                            Stroke="#765823"
                            StrokeThickness="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />

                        <Border
                            Width="39"
                            Height="39"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#2B251F"
                            BorderBrush="#B98A31"
                            BorderThickness="1"
                            CornerRadius="12">

                            <TextBlock
                                Text="&#xE749;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="#E4B956"
                                FontSize="21"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <StackPanel
                        Margin="17,0,0,0"
                        VerticalAlignment="Center">

                        <TextBlock
                            Text="XEM TRƯỚC HÓA ĐƠN"
                            Foreground="#E4B956"
                            FontFamily="Georgia"
                            FontSize="27"
                            FontWeight="Bold" />

                        <TextBlock
                            Text="Bản xem trước khổ K80 từ dữ liệu giao dịch đã chốt"
                            Foreground="#B8AEA3"
                            FontSize="11"
                            Margin="0,6,0,0" />
                    </StackPanel>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="15,10"
                    Background="#28231F"
                    BorderBrush="#574A3E"
                    BorderThickness="1"
                    CornerRadius="11"
                    VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal">

                        <Ellipse
                            Width="8"
                            Height="8"
                            Fill="#3AA86C"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />

                        <TextBlock
                            x:Name="CopyKindBadgeText"
                            Text="BẢN GỐC"
                            Foreground="#E4B956"
                            FontSize="11"
                            FontWeight="Bold"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- =====================================================
             MAIN WORKSPACE
             ===================================================== -->

        <Grid
            Grid.Row="1"
            Margin="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- =================================================
                 TRANSACTION PANEL
                 ================================================= -->

            <Border
                Grid.Column="0"
                Background="{StaticResource ReceiptPreviewPanelBrush}"
                BorderBrush="#6B5137"
                BorderThickness="1"
                CornerRadius="18"
                Padding="24">

                <Border.Effect>

                    <DropShadowEffect
                        Color="#39251A"
                        BlurRadius="20"
                        ShadowDepth="4"
                        Direction="270"
                        Opacity="0.18" />
                </Border.Effect>

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>

                        <TextBlock
                            Text="THÔNG TIN GIAO DỊCH"
                            Foreground="#D5A33E"
                            FontSize="11"
                            FontWeight="Bold" />

                        <TextBlock
                            Text="Hóa đơn vừa hoàn tất"
                            Foreground="#FFF9F0"
                            FontFamily="Georgia"
                            FontSize="23"
                            FontWeight="Bold"
                            Margin="0,8,0,0" />

                        <TextBlock
                            Text="Dữ liệu bên dưới không đọc lại từ sản phẩm hiện tại."
                            Foreground="#AFA49A"
                            FontSize="10.5"
                            TextWrapping="Wrap"
                            LineHeight="17"
                            Margin="0,8,0,0" />
                    </StackPanel>

                    <Border
                        Grid.Row="1"
                        Style="{StaticResource PreviewMetricCardStyle}"
                        Margin="0,20,0,0">

                        <StackPanel>

                            <TextBlock
                                Text="MÃ ĐƠN"
                                Style="{StaticResource PreviewInfoLabelStyle}" />

                            <TextBlock
                                x:Name="OrderCodeText"
                                Text="—"
                                Style="{StaticResource PreviewInfoValueStyle}"
                                Foreground="#E6B856"
                                FontFamily="Consolas"
                                FontSize="14"
                                TextTrimming="CharacterEllipsis"
                                ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="2"
                        Style="{StaticResource PreviewMetricCardStyle}"
                        Margin="0,11,0,0">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>

                                <TextBlock
                                    Text="THỜI GIAN"
                                    Style="{StaticResource PreviewInfoLabelStyle}" />

                                <TextBlock
                                    x:Name="PaidAtText"
                                    Text="—"
                                    Style="{StaticResource PreviewInfoValueStyle}"
                                    FontSize="12" />
                            </StackPanel>

                            <Border
                                Grid.Column="1"
                                Width="1"
                                Background="#50443A"
                                HorizontalAlignment="Left"
                                Margin="0,0,14,0" />

                            <StackPanel
                                Grid.Column="1"
                                Margin="15,0,0,0">

                                <TextBlock
                                    Text="THU NGÂN"
                                    Style="{StaticResource PreviewInfoLabelStyle}" />

                                <TextBlock
                                    x:Name="CashierText"
                                    Text="—"
                                    Style="{StaticResource PreviewInfoValueStyle}"
                                    FontSize="12" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Row="3"
                        Style="{StaticResource PreviewMetricCardStyle}"
                        Margin="0,11,0,0">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>

                                <TextBlock
                                    Text="SỐ LƯỢNG"
                                    Style="{StaticResource PreviewInfoLabelStyle}" />

                                <TextBlock
                                    x:Name="ItemCountText"
                                    Text="—"
                                    Style="{StaticResource PreviewInfoValueStyle}" />
                            </StackPanel>

                            <Border
                                Grid.Column="1"
                                Width="1"
                                Background="#50443A"
                                HorizontalAlignment="Left"
                                Margin="0,0,14,0" />

                            <StackPanel
                                Grid.Column="1"
                                Margin="15,0,0,0">

                                <TextBlock
                                    Text="THANH TOÁN"
                                    Style="{StaticResource PreviewInfoLabelStyle}" />

                                <TextBlock
                                    x:Name="PaymentMethodText"
                                    Text="—"
                                    Style="{StaticResource PreviewInfoValueStyle}"
                                    FontSize="12" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Row="4"
                        Margin="0,14,0,0"
                        Padding="17,15"
                        Background="{StaticResource ReceiptPreviewTotalBrush}"
                        BorderBrush="#803138"
                        BorderThickness="1"
                        CornerRadius="13">

                        <Grid>

                            <StackPanel>

                                <TextBlock
                                    Text="TỔNG THANH TOÁN"
                                    Foreground="#D8BBB9"
                                    FontSize="10.5"
                                    FontWeight="SemiBold" />

                                <TextBlock
                                    Text="Đã được transaction xác nhận"
                                    Foreground="#A98B8A"
                                    FontSize="9.5"
                                    Margin="0,5,0,0" />
                            </StackPanel>

                            <TextBlock
                                x:Name="TotalAmountText"
                                Text="0 ₫"
                                Foreground="#FFE2A8"
                                FontFamily="Georgia"
                                FontSize="26"
                                FontWeight="Bold"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <StackPanel
                        Grid.Row="6"
                        Margin="0,18,0,0">

                        <Border
                            Height="1"
                            Background="#4E433A"
                            Margin="0,0,0,15" />

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Width="31"
                                Height="31"
                                Background="#153A29"
                                BorderBrush="#2B7652"
                                BorderThickness="1"
                                CornerRadius="9"
                                VerticalAlignment="Top">

                                <TextBlock
                                    Text="&#xE72E;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Foreground="#4BC47F"
                                    FontSize="13"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>

                            <TextBlock
                                Grid.Column="1"
                                Text="Lỗi xem trước hoặc lỗi máy in không làm đảo ngược giao dịch đã lưu."
                                Foreground="#AFA49A"
                                FontSize="10.5"
                                TextWrapping="Wrap"
                                LineHeight="17"
                                Margin="11,0,0,0"
                                VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- =================================================
                 RECEIPT PREVIEW CANVAS
                 ================================================= -->

            <Border
                Grid.Column="2"
                Background="#EDE5DA"
                BorderBrush="#D4C7B6"
                BorderThickness="1"
                CornerRadius="18"
                Padding="24">

                <Border.Effect>

                    <DropShadowEffect
                        Color="#4B3327"
                        BlurRadius="20"
                        ShadowDepth="3"
                        Direction="270"
                        Opacity="0.12" />
                </Border.Effect>

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="3,0,3,16">

                        <StackPanel>

                            <TextBlock
                                Text="BẢN XEM TRƯỚC KHỔ K80"
                                Foreground="#2D2925"
                                FontSize="12"
                                FontWeight="Bold" />

                            <TextBlock
                                Text="Nội dung hiển thị bên dưới chính là tài liệu được gửi tới máy in."
                                Foreground="#756C64"
                                FontSize="10.5"
                                Margin="0,5,0,0" />
                        </StackPanel>

                        <Border
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Padding="11,7"
                            Background="#FFFDFC"
                            BorderBrush="#D9CCBC"
                            BorderThickness="1"
                            CornerRadius="9">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE8A5;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Foreground="#C39232"
                                    FontSize="13"
                                    Margin="0,0,7,0"
                                    VerticalAlignment="Center" />

                                <TextBlock
                                    Text="80 MM"
                                    Foreground="#6E655D"
                                    FontSize="10.5"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border
                        Grid.Row="1"
                        Width="510"
                        MaxWidth="570"
                        HorizontalAlignment="Center"
                        Background="White"
                        BorderBrush="#D1C8BD"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="2">

                        <Border.Effect>

                            <DropShadowEffect
                                Color="#5B4737"
                                BlurRadius="22"
                                ShadowDepth="5"
                                Direction="270"
                                Opacity="0.2" />
                        </Border.Effect>

                        <FlowDocumentScrollViewer
                            x:Name="ReceiptViewer"
                            Background="White"
                            BorderThickness="0"
                            IsToolBarVisible="False"
                            IsSelectionEnabled="True"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            Zoom="125"
                            MinZoom="90"
                            MaxZoom="180" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- =====================================================
             ACTION BAR
             ===================================================== -->

        <Border
            Grid.Row="2"
            Background="#FFFEFC"
            BorderBrush="#DED3C5"
            BorderThickness="0,1,0,0">

            <Grid Margin="28,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="StatusBorder"
                    MaxWidth="680"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Padding="13,10"
                    Background="{StaticResource GoldSoftBrush}"
                    BorderBrush="{StaticResource GoldBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="StatusIcon"
                            Text="&#xE946;"
                            FontFamily="Segoe MDL2 Assets"
                            Foreground="{StaticResource GoldBrush}"
                            FontSize="15"
                            VerticalAlignment="Center" />

                        <StackPanel
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                x:Name="StatusText"
                                Text="Kiểm tra nội dung trước khi gửi tới máy in."
                                Foreground="{StaticResource GoldBrush}"
                                FontSize="10.5"
                                TextWrapping="Wrap" />

                            <ProgressBar
                                x:Name="PrintingProgress"
                                Height="3"
                                Margin="0,7,0,0"
                                IsIndeterminate="True"
                                Foreground="{StaticResource AccentBrush}"
                                Background="{StaticResource AccentSoftBrush}"
                                Visibility="Collapsed" />
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <Button
                        x:Name="CloseButton"
                        Content="ĐÓNG"
                        Style="{StaticResource PreviewCloseButtonStyle}"
                        Click="OnCloseClick"
                        Margin="0,0,12,0" />

                    <Button
                        x:Name="PrintButton"
                        Style="{StaticResource PreviewPrintButtonStyle}"
                        Click="OnPrintClick">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock
                                Text="&#xE749;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="17"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center" />

                            <StackPanel>

                                <TextBlock
                                    x:Name="PrintButtonTitleText"
                                    Text="IN HÓA ĐƠN"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    HorizontalAlignment="Center" />

                                <TextBlock
                                    Text="Ctrl+P"
                                    FontSize="9.5"
                                    Foreground="#F5D9D9"
                                    Margin="0,2,0,0"
                                    HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- =====================================================
             PRINTING OVERLAY
             ===================================================== -->

        <Border
            x:Name="PrintingOverlay"
            Grid.RowSpan="3"
            Panel.ZIndex="999"
            Background="#A8F7F2EA"
            Visibility="Collapsed">

            <Border
                Width="370"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#FFFEFC"
                BorderBrush="#C9A451"
                BorderThickness="1"
                CornerRadius="18">

                <Border.Effect>

                    <DropShadowEffect
                        Color="#392317"
                        BlurRadius="30"
                        ShadowDepth="5"
                        Direction="270"
                        Opacity="0.27" />
                </Border.Effect>

                <StackPanel>

                    <Border
                        Width="62"
                        Height="62"
                        HorizontalAlignment="Center"
                        Background="#FFF5DD"
                        BorderBrush="#D8B45F"
                        BorderThickness="1"
                        CornerRadius="18">

                        <TextBlock
                            Text="&#xE749;"
                            FontFamily="Segoe MDL2 Assets"
                            Foreground="#B88427"
                            FontSize="27"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>

                    <TextBlock
                        Text="ĐANG GỬI HÓA ĐƠN"
                        Foreground="#2B2723"
                        FontFamily="Georgia"
                        FontSize="19"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        Margin="0,17,0,0" />

                    <TextBlock
                        Text="Vui lòng không đóng cửa sổ hoặc bấm in lần nữa."
                        Foreground="#746B63"
                        FontSize="10.5"
                        TextAlignment="Center"
                        TextWrapping="Wrap"
                        Margin="0,9,0,0" />

                    <ProgressBar
                        Height="5"
                        Margin="18,20,18,0"
                        IsIndeterminate="True"
                        Foreground="#A51119"
                        Background="#F0D9DA" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>