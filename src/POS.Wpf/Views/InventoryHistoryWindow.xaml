<Window
    x:Class="POS.Wpf.Views.InventoryHistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Lịch sử tồn kho"
    Width="1240"
    Height="790"
    MinWidth="1080"
    MinHeight="680"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    Background="{StaticResource AppBackgroundBrush}"
    FontFamily="Segoe UI"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <Window.Resources>

        <Style
            x:Key="HistoryFormLabelStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}" />

            <Setter
                Property="FontSize"
                Value="11" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />

            <Setter
                Property="Margin"
                Value="0,0,0,6" />
        </Style>

        <Style
            x:Key="HistoryTextBoxStyle"
            TargetType="{x:Type TextBox}"
            BasedOn="{StaticResource SearchTextBoxStyle}">

            <Setter
                Property="Height"
                Value="41" />

            <Setter
                Property="Padding"
                Value="12,0" />

            <Setter
                Property="FontSize"
                Value="12" />
        </Style>

        <Style
            x:Key="HistoryComboBoxStyle"
            TargetType="{x:Type ComboBox}">

            <Setter
                Property="Height"
                Value="41" />

            <Setter
                Property="Padding"
                Value="10,5" />

            <Setter
                Property="Background"
                Value="{StaticResource SurfaceBrush}" />

            <Setter
                Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}" />

            <Setter
                Property="BorderBrush"
                Value="{StaticResource BorderStrongBrush}" />

            <Setter
                Property="BorderThickness"
                Value="1" />

            <Setter
                Property="FontSize"
                Value="12" />

            <Setter
                Property="VerticalContentAlignment"
                Value="Center" />
        </Style>

        <Style
            x:Key="HistoryDatePickerStyle"
            TargetType="{x:Type DatePicker}">

            <Setter
                Property="Height"
                Value="41" />

            <Setter
                Property="Background"
                Value="{StaticResource SurfaceBrush}" />

            <Setter
                Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}" />

            <Setter
                Property="BorderBrush"
                Value="{StaticResource BorderStrongBrush}" />

            <Setter
                Property="BorderThickness"
                Value="1" />

            <Setter
                Property="FontSize"
                Value="12" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="90" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- =================================================
             HEADER
             ================================================= -->

        <Border
            Grid.Row="0"
            Background="{StaticResource SidebarBrush}"
            BorderBrush="#6A4C27"
            BorderThickness="0,0,0,1">

            <Grid Margin="28,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <Border
                        Width="46"
                        Height="46"
                        Background="{StaticResource SidebarSurfaceBrush}"
                        BorderBrush="{StaticResource GoldBrush}"
                        BorderThickness="1"
                        CornerRadius="13">

                        <TextBlock
                            Text="&#xE9D2;"
                            FontFamily="Segoe MDL2 Assets"
                            Foreground="{StaticResource GoldHoverBrush}"
                            FontSize="21"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>

                    <StackPanel
                        Margin="14,0,0,0"
                        VerticalAlignment="Center">

                        <TextBlock
                            Text="LỊCH SỬ TỒN KHO"
                            Foreground="{StaticResource GoldHoverBrush}"
                            FontFamily="Georgia"
                            FontSize="21"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="Theo dõi toàn bộ biến động, chứng từ và số tồn trước – sau."
                            Foreground="{StaticResource SidebarMutedBrush}"
                            FontSize="11"
                            Margin="0,4,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right">

                    <TextBlock
                        Text="AUDIT TRAIL"
                        Foreground="{StaticResource GoldHoverBrush}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Right" />

                    <TextBlock
                        Text="{Binding LastUpdatedText}"
                        Foreground="{StaticResource SidebarMutedBrush}"
                        FontSize="10"
                        Margin="0,5,0,0"
                        HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- =================================================
             BODY
             ================================================= -->

        <Grid
            Grid.Row="1"
            Margin="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- =================================================
                 FILTER PANEL
                 ================================================= -->

            <Border
                Grid.Column="0"
                Style="{StaticResource CardStyle}"
                Padding="0"
                ClipToBounds="True">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border
                        Padding="18,15"
                        Background="{StaticResource SidebarBrush}"
                        BorderBrush="#6A4C27"
                        BorderThickness="0,0,0,1">

                        <StackPanel>

                            <TextBlock
                                Text="BỘ LỌC NGHIỆP VỤ"
                                Foreground="{StaticResource GoldHoverBrush}"
                                FontFamily="Georgia"
                                FontSize="16"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="Thu hẹp dữ liệu theo sản phẩm và thời gian."
                                Foreground="{StaticResource SidebarMutedBrush}"
                                FontSize="10"
                                Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">

                        <StackPanel Margin="18,17">

                            <TextBlock
                                Text="Tìm sản phẩm"
                                Style="{StaticResource HistoryFormLabelStyle}" />

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="72" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    Text="{Binding ProductSearchTerm,
                                        UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource HistoryTextBoxStyle}" />

                                <Button
                                    Grid.Column="2"
                                    Content="Tìm"
                                    Command="{Binding SearchProductsCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="41"
                                    Padding="8,0" />
                            </Grid>

                            <TextBlock
                                Text="Sản phẩm"
                                Style="{StaticResource HistoryFormLabelStyle}"
                                Margin="0,14,0,6" />

                            <ComboBox
                                ItemsSource="{Binding ProductOptions}"
                                SelectedItem="{Binding SelectedProductFilter,
                                    Mode=TwoWay}"
                                DisplayMemberPath="DisplayName"
                                Style="{StaticResource HistoryComboBoxStyle}"
                                MaxDropDownHeight="300" />

                            <TextBlock
                                Text="Loại biến động"
                                Style="{StaticResource HistoryFormLabelStyle}"
                                Margin="0,14,0,6" />

                            <ComboBox
                                ItemsSource="{Binding MovementFilters}"
                                SelectedItem="{Binding SelectedMovementFilter,
                                    Mode=TwoWay}"
                                DisplayMemberPath="DisplayName"
                                Style="{StaticResource HistoryComboBoxStyle}" />

                            <Grid Margin="0,14,0,0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock
                                        Text="Từ ngày"
                                        Style="{StaticResource HistoryFormLabelStyle}" />

                                    <DatePicker
                                        SelectedDate="{Binding FromDate,
                                            Mode=TwoWay}"
                                        Style="{StaticResource HistoryDatePickerStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">

                                    <TextBlock
                                        Text="Đến ngày"
                                        Style="{StaticResource HistoryFormLabelStyle}" />

                                    <DatePicker
                                        SelectedDate="{Binding ToDate,
                                            Mode=TwoWay}"
                                        Style="{StaticResource HistoryDatePickerStyle}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock
                                Text="Loại chứng từ"
                                Style="{StaticResource HistoryFormLabelStyle}"
                                Margin="0,14,0,6" />

                            <TextBox
                                Text="{Binding ReferenceType,
                                    UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource HistoryTextBoxStyle}"
                                MaxLength="100" />

                            <TextBlock
                                Text="Ví dụ: ORDER, RECEIPT, REFUND. Có thể bỏ trống."
                                Style="{StaticResource CaptionTextStyle}"
                                TextWrapping="Wrap"
                                Margin="2,6,0,0" />

                            <Border
                                Margin="0,16,0,0"
                                Padding="11,9"
                                Background="{StaticResource DangerSoftBrush}"
                                BorderBrush="#F0C8CA"
                                BorderThickness="1"
                                CornerRadius="9"
                                Visibility="{Binding HasError,
                                    Converter={StaticResource BooleanToVisibilityConverter}}">

                                <TextBlock
                                    Text="{Binding ErrorMessage}"
                                    Foreground="{StaticResource DangerBrush}"
                                    FontSize="10"
                                    TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel
                        Grid.Row="2"
                        Margin="18,10,18,18">

                        <Button
                            Command="{Binding SearchCommand}"
                            Style="{StaticResource PrimaryButtonStyle}">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE721;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="12"
                                    Margin="0,0,7,0" />

                                <TextBlock Text="Lọc lịch sử" />
                            </StackPanel>
                        </Button>

                        <Grid Margin="0,9,0,0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button
                                Content="Đặt lại"
                                Command="{Binding ResetFiltersCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />

                            <Button
                                Grid.Column="2"
                                Content="Tải lại"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- =================================================
                 HISTORY WORKSPACE
                 ================================================= -->

            <Grid Grid.Column="2">

                <Grid.RowDefinitions>
                    <RowDefinition Height="88" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="112" />
                    <RowDefinition Height="58" />
                </Grid.RowDefinitions>

                <!-- KPI -->

                <UniformGrid
                    Grid.Row="0"
                    Columns="4">

                    <Border
                        Style="{StaticResource CardStyle}"
                        Padding="14"
                        Margin="0,0,7,0">

                        <StackPanel>

                            <TextBlock
                                Text="TỔNG BIẾN ĐỘNG"
                                Style="{StaticResource CaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding TotalMovementsText}"
                                Style="{StaticResource CardValueTextStyle}"
                                FontSize="22"
                                Margin="0,5,0,0" />

                            <TextBlock
                                Text="Theo bộ lọc hiện tại"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <Border
                        Style="{StaticResource CardStyle}"
                        Padding="14"
                        Margin="3,0,4,0">

                        <StackPanel>

                            <TextBlock
                                Text="TĂNG KHO TRÊN TRANG"
                                Style="{StaticResource CaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding IncreasesOnPageText}"
                                FontFamily="Georgia"
                                FontSize="22"
                                FontWeight="Bold"
                                Foreground="{StaticResource SuccessBrush}"
                                Margin="0,5,0,0" />

                            <TextBlock
                                Text="Movement có delta dương"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <Border
                        Style="{StaticResource CardStyle}"
                        Padding="14"
                        Margin="4,0,3,0">

                        <StackPanel>

                            <TextBlock
                                Text="GIẢM KHO TRÊN TRANG"
                                Style="{StaticResource CaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding DecreasesOnPageText}"
                                FontFamily="Georgia"
                                FontSize="22"
                                FontWeight="Bold"
                                Foreground="{StaticResource DangerBrush}"
                                Margin="0,5,0,0" />

                            <TextBlock
                                Text="Movement có delta âm"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <Border
                        Style="{StaticResource CardStyle}"
                        Padding="14"
                        Margin="7,0,0,0">

                        <StackPanel>

                            <TextBlock
                                Text="CHÊNH LỆCH TRÊN TRANG"
                                Style="{StaticResource CaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding NetChangeOnPageText}"
                                FontFamily="Georgia"
                                FontSize="22"
                                FontWeight="Bold"
                                Foreground="{StaticResource GoldBrush}"
                                Margin="0,5,0,0" />

                            <TextBlock
                                Text="Tổng delta của trang"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Data table -->

                <Border
                    Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Padding="0"
                    Margin="0,14,0,12"
                    ClipToBounds="True">

                    <Grid>

                        <DataGrid
                            ItemsSource="{Binding Movements}"
                            SelectedItem="{Binding SelectedMovement,
                                Mode=TwoWay}"
                            Style="{StaticResource ModernDataGridStyle}"
                            EnableRowVirtualization="True"
                            EnableColumnVirtualization="True"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling"
                            ScrollViewer.CanContentScroll="True">

                            <DataGrid.Columns>

                                <DataGridTemplateColumn
                                    Header="THỜI GIAN"
                                    Width="1.05*">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <StackPanel>

                                                <TextBlock
                                                    Text="{Binding OccurredDateText}"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    FontSize="11"
                                                    FontWeight="SemiBold" />

                                                <TextBlock
                                                    Text="{Binding OccurredTimeText}"
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Margin="0,2,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn
                                    Header="SẢN PHẨM"
                                    Width="2*">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <StackPanel>

                                                <TextBlock
                                                    Text="{Binding ProductName}"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    TextTrimming="CharacterEllipsis" />

                                                <TextBlock
                                                    Text="{Binding ProductCode}"
                                                    Foreground="{StaticResource GoldBrush}"
                                                    FontSize="10"
                                                    FontWeight="SemiBold"
                                                    Margin="0,2,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn
                                    Header="NGHIỆP VỤ"
                                    Width="1.15*">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Border
                                                HorizontalAlignment="Left"
                                                Padding="8,4"
                                                CornerRadius="7">

                                                <Border.Style>

                                                    <Style TargetType="{x:Type Border}">

                                                        <Setter
                                                            Property="Background"
                                                            Value="{StaticResource GoldSoftBrush}" />

                                                        <Style.Triggers>

                                                            <DataTrigger
                                                                Binding="{Binding IsIncrease}"
                                                                Value="True">

                                                                <Setter
                                                                    Property="Background"
                                                                    Value="{StaticResource SuccessSoftBrush}" />
                                                            </DataTrigger>

                                                            <DataTrigger
                                                                Binding="{Binding IsDecrease}"
                                                                Value="True">

                                                                <Setter
                                                                    Property="Background"
                                                                    Value="{StaticResource DangerSoftBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <TextBlock
                                                    Text="{Binding MovementTypeText}"
                                                    FontSize="10"
                                                    FontWeight="SemiBold">

                                                    <TextBlock.Style>

                                                        <Style TargetType="{x:Type TextBlock}">

                                                            <Setter
                                                                Property="Foreground"
                                                                Value="{StaticResource GoldBrush}" />

                                                            <Style.Triggers>

                                                                <DataTrigger
                                                                    Binding="{Binding IsIncrease}"
                                                                    Value="True">

                                                                    <Setter
                                                                        Property="Foreground"
                                                                        Value="{StaticResource SuccessBrush}" />
                                                                </DataTrigger>

                                                                <DataTrigger
                                                                    Binding="{Binding IsDecrease}"
                                                                    Value="True">

                                                                    <Setter
                                                                        Property="Foreground"
                                                                        Value="{StaticResource DangerBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn
                                    Header="TỒN TRƯỚC"
                                    Binding="{Binding QuantityBeforeText}"
                                    Width="1.05*" />

                                <DataGridTemplateColumn
                                    Header="THAY ĐỔI"
                                    Width="1.05*">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <TextBlock
                                                Text="{Binding QuantityDeltaText}"
                                                FontFamily="Georgia"
                                                FontSize="12"
                                                FontWeight="Bold">

                                                <TextBlock.Style>

                                                    <Style TargetType="{x:Type TextBlock}">

                                                        <Setter
                                                            Property="Foreground"
                                                            Value="{StaticResource GoldBrush}" />

                                                        <Style.Triggers>

                                                            <DataTrigger
                                                                Binding="{Binding IsIncrease}"
                                                                Value="True">

                                                                <Setter
                                                                    Property="Foreground"
                                                                    Value="{StaticResource SuccessBrush}" />
                                                            </DataTrigger>

                                                            <DataTrigger
                                                                Binding="{Binding IsDecrease}"
                                                                Value="True">

                                                                <Setter
                                                                    Property="Foreground"
                                                                    Value="{StaticResource DangerBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn
                                    Header="TỒN SAU"
                                    Binding="{Binding QuantityAfterText}"
                                    Width="1.05*" />

                                <DataGridTextColumn
                                    Header="CHỨNG TỪ"
                                    Binding="{Binding ReferenceText}"
                                    Width="1.35*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty state -->

                        <Border
                            Background="{StaticResource SurfaceBrush}">

                            <Border.Style>

                                <Style TargetType="{x:Type Border}">

                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />

                                    <Style.Triggers>

                                        <MultiDataTrigger>

                                            <MultiDataTrigger.Conditions>

                                                <Condition
                                                    Binding="{Binding Movements.Count}"
                                                    Value="0" />

                                                <Condition
                                                    Binding="{Binding IsLoading}"
                                                    Value="False" />
                                            </MultiDataTrigger.Conditions>

                                            <Setter
                                                Property="Visibility"
                                                Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                                <Border
                                    Width="58"
                                    Height="58"
                                    Background="{StaticResource GoldSoftBrush}"
                                    BorderBrush="{StaticResource GoldBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18">

                                    <TextBlock
                                        Text="&#xE9D2;"
                                        FontFamily="Segoe MDL2 Assets"
                                        Foreground="{StaticResource GoldBrush}"
                                        FontSize="24"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>

                                <TextBlock
                                    Text="Chưa có biến động phù hợp"
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,13,0,0" />

                                <TextBlock
                                    Text="Thử thay đổi sản phẩm, ngày hoặc loại nghiệp vụ."
                                    Style="{StaticResource SecondaryTextStyle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,5,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Selected detail -->

                <Border
                    Grid.Row="2"
                    Style="{StaticResource CardStyle}"
                    Padding="16">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1.25*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock
                                Text="{Binding SelectedMovementTitle}"
                                Style="{StaticResource SectionTitleTextStyle}"
                                FontSize="15" />

                            <TextBlock
                                Text="{Binding SelectedMovementReason}"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                FontSize="11"
                                TextWrapping="Wrap"
                                Margin="0,7,20,0" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="13"
                            Background="{StaticResource SurfaceMutedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">

                            <StackPanel>

                                <TextBlock
                                    Text="{Binding SelectedMovementReference}"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis" />

                                <TextBlock
                                    Text="{Binding SelectedMovementAuditText}"
                                    Style="{StaticResource CaptionTextStyle}"
                                    TextWrapping="Wrap"
                                    Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Footer -->

                <Grid
                    Grid.Row="3"
                    Margin="2,9,2,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Text="{Binding StatusMessage}"
                        Style="{StaticResource CaptionTextStyle}"
                        VerticalAlignment="Center" />

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal">

                        <Button
                            Content="Trước"
                            Command="{Binding PreviousPageCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="78" />

                        <Border
                            Height="42"
                            Padding="15,0"
                            Margin="9,0"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="8">

                            <TextBlock
                                Text="{Binding PageText}"
                                Foreground="White"
                                FontSize="11"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center" />
                        </Border>

                        <Button
                            Content="Sau"
                            Command="{Binding NextPageCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="78" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <!-- Loading overlay -->

        <Border
            Grid.RowSpan="2"
            Background="#BFFFFFFB"
            Visibility="{Binding IsLoading,
                Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border
                Width="310"
                Padding="24"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource GoldBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <Border.Effect>
                    <DropShadowEffect
                        Color="#3B271D"
                        BlurRadius="20"
                        ShadowDepth="3"
                        Opacity="0.18" />
                </Border.Effect>

                <StackPanel>

                    <ProgressBar
                        Height="5"
                        IsIndeterminate="True"
                        Foreground="{StaticResource AccentBrush}" />

                    <TextBlock
                        Text="Đang tải và đối chiếu lịch sử kho..."
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="12"
                        HorizontalAlignment="Center"
                        Margin="0,14,0,0" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>