<Window
    x:Class="POS.Wpf.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Language="vi-VN"
    Title="POS Enterprise - Đăng nhập"
    Width="1080"
    Height="680"
    MinWidth="940"
    MinHeight="600"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    ShowInTaskbar="True"
    Background="{StaticResource AppBackgroundBrush}"
    FontFamily="Segoe UI"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <Window.Resources>

        <Style
            x:Key="LoginLabelStyle"
            TargetType="{x:Type TextBlock}">

            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>

        <Style
            x:Key="LoginTextBoxStyle"
            TargetType="{x:Type TextBox}"
            BasedOn="{StaticResource SearchTextBoxStyle}">

            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="LoginPasswordBoxStyle"
            TargetType="{x:Type PasswordBox}">

            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style
            x:Key="LoginErrorStyle"
            TargetType="{x:Type TextBlock}">

            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="2,5,0,0" />

            <Style.Triggers>

                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>

                <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>

            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="455" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel -->

        <Border
            Grid.Column="0"
            Background="{StaticResource SidebarBrush}">

            <Grid Margin="44">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>

                    <Grid Width="82" Height="82">

                        <Ellipse
                            Stroke="{StaticResource GoldBrush}"
                            StrokeThickness="1.5" />

                        <Border
                            Width="53"
                            Height="53"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderBrush="{StaticResource GoldHoverBrush}"
                            BorderThickness="1.3"
                            CornerRadius="6"
                            RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <RotateTransform Angle="45" />
                            </Border.RenderTransform>
                        </Border>

                        <TextBlock
                            Text="P"
                            FontFamily="Georgia"
                            FontSize="34"
                            Foreground="{StaticResource GoldHoverBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock
                        Text="POS ENTERPRISE"
                        Foreground="{StaticResource GoldHoverBrush}"
                        FontFamily="Georgia"
                        FontSize="23"
                        FontWeight="SemiBold"
                        Margin="0,21,0,0" />

                    <TextBlock
                        Text="RESTAURANT SOLUTIONS"
                        Foreground="{StaticResource SidebarMutedBrush}"
                        FontSize="9"
                        FontWeight="SemiBold"
                        Margin="0,7,0,0" />
                </StackPanel>

                <StackPanel
                    Grid.Row="1"
                    VerticalAlignment="Center">

                    <TextBlock
                        Text="Chào mừng trở lại"
                        Foreground="{StaticResource GoldHoverBrush}"
                        FontFamily="Georgia"
                        FontSize="31"
                        FontWeight="SemiBold"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Text="Đăng nhập để tiếp tục quản lý sản phẩm, danh mục, tồn kho và hoạt động cửa hàng."
                        Foreground="#E1D2C2"
                        FontSize="13"
                        TextWrapping="Wrap"
                        LineHeight="22"
                        Margin="0,17,0,0" />

                    <Border
                        Margin="0,29,0,0"
                        Padding="18"
                        Background="{StaticResource SidebarSurfaceBrush}"
                        BorderBrush="#725333"
                        BorderThickness="1"
                        CornerRadius="14">

                        <StackPanel>

                            <TextBlock
                                Text="PHIÊN LÀM VIỆC BẢO MẬT"
                                Foreground="{StaticResource GoldBrush}"
                                FontSize="10"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="Tài khoản sẽ bị khóa tạm thời sau nhiều lần nhập sai mật khẩu."
                                Foreground="{StaticResource SidebarMutedBrush}"
                                FontSize="11"
                                TextWrapping="Wrap"
                                LineHeight="19"
                                Margin="0,9,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel
                    Grid.Row="2"
                    Orientation="Horizontal">

                    <Ellipse
                        Width="7"
                        Height="7"
                        Fill="{StaticResource SuccessBrush}"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center" />

                    <TextBlock
                        Text="SQLite đã sẵn sàng"
                        Foreground="{StaticResource SidebarMutedBrush}"
                        FontSize="10" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Login form -->

        <Grid
            Grid.Column="1"
            Background="{StaticResource AppBackgroundBrush}">

            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">

                <StackPanel
                    Width="470"
                    Margin="54,58"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                    <TextBlock
                        Text="Đăng nhập hệ thống"
                        Style="{StaticResource PageTitleTextStyle}" />

                    <TextBlock
                        Text="Nhập tài khoản được cấp để mở phiên làm việc."
                        Style="{StaticResource SecondaryTextStyle}"
                        TextWrapping="Wrap"
                        Margin="0,7,0,30" />

                    <!-- Username -->

                    <TextBlock
                        Text="Tên đăng nhập"
                        Style="{StaticResource LoginLabelStyle}" />

                    <TextBox
                        x:Name="UsernameInput"
                        Text="{Binding Username,
                            UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource LoginTextBoxStyle}"
                        MaxLength="50" />

                    <TextBlock
                        Text="{Binding UsernameError}"
                        Style="{StaticResource LoginErrorStyle}" />

                    <!-- Password -->

                    <TextBlock
                        Text="Mật khẩu"
                        Style="{StaticResource LoginLabelStyle}"
                        Margin="0,20,0,7" />

                    <Grid>

                        <PasswordBox
                            x:Name="PasswordInput"
                            Style="{StaticResource LoginPasswordBoxStyle}"
                            PasswordChanged="OnPasswordChanged" />

                        <TextBox
                            x:Name="VisiblePasswordInput"
                            Visibility="Collapsed"
                            Style="{StaticResource LoginTextBoxStyle}"
                            TextChanged="OnVisiblePasswordChanged" />
                    </Grid>

                    <TextBlock
                        Text="{Binding PasswordError}"
                        Style="{StaticResource LoginErrorStyle}" />

                    <StackPanel
                        Orientation="Horizontal"
                        Margin="1,13,0,0">

                        <CheckBox
                         x:Name="ShowPasswordCheckBox"
                         Content="Hiện mật khẩu"
                         Checked="OnShowPasswordChecked"
                         Unchecked="OnShowPasswordUnchecked"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="11" />

                        <CheckBox
                         Content="Duy trì đăng nhập trong 30 ngày"
                         IsChecked="{Binding RememberLogin,
                         Mode=TwoWay,
                         UpdateSourceTrigger=PropertyChanged}"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="11"
                         Margin="24,0,0,0"
                         ToolTip="Chỉ nên bật trên máy POS riêng của cửa hàng." />
                    </StackPanel>

                    <!-- Status -->

                    <Border
                        Margin="0,20,0,0"
                        Padding="14,12"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="{Binding HasStatusMessage,
                            Converter={StaticResource BooleanToVisibilityConverter}}">

                        <Border.Style>

                            <Style TargetType="{x:Type Border}">

                                <Setter
                                    Property="Background"
                                    Value="{StaticResource SuccessSoftBrush}" />

                                <Setter
                                    Property="BorderBrush"
                                    Value="{StaticResource SuccessBrush}" />

                                <Style.Triggers>

                                    <DataTrigger
                                        Binding="{Binding IsStatusError}"
                                        Value="True">

                                        <Setter
                                            Property="Background"
                                            Value="{StaticResource DangerSoftBrush}" />

                                        <Setter
                                            Property="BorderBrush"
                                            Value="{StaticResource DangerBrush}" />
                                    </DataTrigger>

                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <TextBlock
                            Text="{Binding StatusMessage}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            FontSize="11"
                            TextWrapping="Wrap" />
                    </Border>

                    <!-- Actions -->

                    <Button
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="48"
                        Margin="0,23,0,0"
                        IsDefault="True">

                        <StackPanel
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">

                            <TextBlock
                                Text="&#xE72E;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                Margin="0,0,8,0" />

                            <TextBlock
                                Text="Đăng nhập"
                                FontSize="13"
                                FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>

                    <Button
                        Content="Thoát ứng dụng"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="44"
                        Margin="0,10,0,0"
                        IsCancel="True" />

                    <TextBlock
                        Text="Liên hệ quản trị viên khi tài khoản bị khóa hoặc ngừng hoạt động."
                        Style="{StaticResource CaptionTextStyle}"
                        TextWrapping="Wrap"
                        TextAlignment="Center"
                        Margin="0,20,0,0" />
                </StackPanel>
            </ScrollViewer>

            <!-- Busy overlay -->

            <Border
                Background="#C9FFFEFB"
                Visibility="{Binding IsBusy,
                    Converter={StaticResource BooleanToVisibilityConverter}}">

                <Border
                    Width="300"
                    Padding="24"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource GoldBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="15"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                    <StackPanel>

                        <ProgressBar
                            Height="5"
                            IsIndeterminate="True"
                            Foreground="{StaticResource AccentBrush}" />

                        <TextBlock
                            Text="Đang xác thực tài khoản..."
                            Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="12"
                            HorizontalAlignment="Center"
                            Margin="0,14,0,0" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>