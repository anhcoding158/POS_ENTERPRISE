<Window
    x:Class="POS.Wpf.Views.CategoryManagementWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Language="vi-VN"
    Title="Quản lý danh mục"
    Width="1180"
    Height="760"
    MinWidth="980"
    MinHeight="640"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    Background="{StaticResource AppBackgroundBrush}"
    FontFamily="Segoe UI"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <Window.Resources>

        <Style
            x:Key="CategoryFilterLabelStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="{StaticResource TextSecondaryBrush}" />

            <Setter
                Property="FontSize"
                Value="10" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />

            <Setter
                Property="Margin"
                Value="0,0,0,6" />
        </Style>

        <Style
            x:Key="CategoryFilterComboBoxStyle"
            TargetType="{x:Type ComboBox}">

            <Setter
                Property="Height"
                Value="42" />

            <Setter
                Property="MinWidth"
                Value="190" />

            <Setter
                Property="Padding"
                Value="11,6" />

            <Setter
                Property="Background"
                Value="{StaticResource SurfaceBrush}" />

            <Setter
                Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}" />

            <Setter
                Property="BorderBrush"
                Value="{StaticResource BorderStrongBrush}" />

            <Setter
                Property="BorderThickness"
                Value="1" />

            <Setter
                Property="FontSize"
                Value="12" />

            <Setter
                Property="VerticalContentAlignment"
                Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">

        <Grid.RowDefinitions>

            <!-- Header -->
            <RowDefinition Height="94" />

            <!-- Workspace -->
            <RowDefinition Height="*" />

        </Grid.RowDefinitions>

        <!-- =================================================
             HEADER
             ================================================= -->

        <Border
            Grid.Row="0"
            Background="{StaticResource SidebarBrush}"
            BorderBrush="#6A4C27"
            BorderThickness="0,0,0,1">

            <Grid Margin="28,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <Border
                        Width="48"
                        Height="48"
                        Background="{StaticResource SidebarSurfaceBrush}"
                        BorderBrush="{StaticResource GoldBrush}"
                        BorderThickness="1"
                        CornerRadius="14">

                        <TextBlock
                            Text="&#xE8EC;"
                            FontFamily="Segoe MDL2 Assets"
                            Foreground="{StaticResource GoldHoverBrush}"
                            FontSize="21"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>

                    <StackPanel
                        Margin="14,0,0,0"
                        VerticalAlignment="Center">

                        <TextBlock
                            Text="QUẢN LÝ DANH MỤC"
                            Foreground="{StaticResource GoldHoverBrush}"
                            FontFamily="Georgia"
                            FontSize="21"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="Sắp xếp nhóm sản phẩm, trạng thái và thứ tự hiển thị."
                            Foreground="{StaticResource SidebarMutedBrush}"
                            FontSize="11"
                            Margin="0,5,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right">

                    <TextBlock
                        Text="CATEGORY MASTER DATA"
                        Foreground="{StaticResource GoldHoverBrush}"
                        FontSize="9"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Right" />

                    <TextBlock
                        Text="{Binding LastUpdatedText}"
                        Foreground="{StaticResource SidebarMutedBrush}"
                        FontSize="10"
                        Margin="0,5,0,0"
                        HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- =================================================
             WORKSPACE
             ================================================= -->

        <Grid
            Grid.Row="1"
            Margin="20">

            <Grid.RowDefinitions>

                <!-- Filter and actions -->
                <RowDefinition Height="Auto" />

                <!-- KPI -->
                <RowDefinition Height="Auto" />

                <!-- Table -->
                <RowDefinition Height="*" />

                <!-- Selected detail -->
                <RowDefinition Height="Auto" />

                <!-- Footer -->
                <RowDefinition Height="Auto" />

            </Grid.RowDefinitions>

            <!-- =================================================
                 FILTER + ACTIONS
                 ================================================= -->

            <Border
                Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Padding="18">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Filters -->

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock
                                Text="TÌM DANH MỤC"
                                Style="{StaticResource CategoryFilterLabelStyle}" />

                            <TextBox
                                Text="{Binding SearchTerm,
                                    UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource SearchTextBoxStyle}"
                                Height="42"
                                Padding="13,0"
                                FontSize="12" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">

                            <TextBlock
                                Text="TRẠNG THÁI"
                                Style="{StaticResource CategoryFilterLabelStyle}" />

                            <ComboBox
                                ItemsSource="{Binding StatusFilters}"
                                SelectedItem="{Binding SelectedStatusFilter,
                                    Mode=TwoWay}"
                                DisplayMemberPath="DisplayName"
                                Style="{StaticResource CategoryFilterComboBoxStyle}" />
                        </StackPanel>

                        <StackPanel
                            Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom">

                            <Button
                                Command="{Binding SearchCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                MinWidth="110">

                                <StackPanel Orientation="Horizontal">

                                    <TextBlock
                                        Text="&#xE721;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="12"
                                        Margin="0,0,7,0" />

                                    <TextBlock Text="Tìm kiếm" />
                                </StackPanel>
                            </Button>

                            <Button
                                Content="Đặt lại"
                                Command="{Binding ResetFiltersCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="92"
                                Margin="8,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <!-- Main actions -->

                    <StackPanel
                        Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom">

                        <Button
                            Content="Tải lại"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="88" />

                        <Button
                            Content="Sửa"
                            Command="{Binding EditCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="82"
                            Margin="8,0,0,0" />

                        <Button
                            Content="{Binding ToggleActiveButtonText}"
                            Command="{Binding ToggleActiveCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="126"
                            Margin="8,0,0,0" />

                        <Button
                            Command="{Binding AddCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="142"
                            Margin="8,0,0,0">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE710;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="12"
                                    Margin="0,0,7,0" />

                                <TextBlock Text="Thêm danh mục" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- =================================================
                 KPI
                 ================================================= -->

            <UniformGrid
                Grid.Row="1"
                Columns="3"
                MinHeight="88"
                Margin="0,14,0,0">

                <Border
                    Style="{StaticResource CardStyle}"
                    Padding="16,13"
                    Margin="0,0,7,0">

                    <StackPanel>

                        <TextBlock
                            Text="TỔNG DANH MỤC"
                            Style="{StaticResource CaptionTextStyle}"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="{Binding TotalCountText}"
                            FontFamily="Georgia"
                            FontSize="23"
                            FontWeight="Bold"
                            Foreground="{StaticResource GoldBrush}"
                            Margin="0,5,0,0" />

                        <TextBlock
                            Text="Theo bộ lọc hiện tại"
                            Style="{StaticResource CaptionTextStyle}"
                            Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border
                    Style="{StaticResource CardStyle}"
                    Padding="16,13"
                    Margin="3,0,4,0">

                    <StackPanel>

                        <TextBlock
                            Text="ĐANG HOẠT ĐỘNG TRÊN TRANG"
                            Style="{StaticResource CaptionTextStyle}"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="{Binding ActiveOnPageText}"
                            FontFamily="Georgia"
                            FontSize="23"
                            FontWeight="Bold"
                            Foreground="{StaticResource SuccessBrush}"
                            Margin="0,5,0,0" />

                        <TextBlock
                            Text="Có thể chọn cho sản phẩm"
                            Style="{StaticResource CaptionTextStyle}"
                            Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border
                    Style="{StaticResource CardStyle}"
                    Padding="16,13"
                    Margin="7,0,0,0">

                    <StackPanel>

                        <TextBlock
                            Text="NGỪNG HOẠT ĐỘNG TRÊN TRANG"
                            Style="{StaticResource CaptionTextStyle}"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="{Binding InactiveOnPageText}"
                            FontFamily="Georgia"
                            FontSize="23"
                            FontWeight="Bold"
                            Foreground="{StaticResource DangerBrush}"
                            Margin="0,5,0,0" />

                        <TextBlock
                            Text="Được giữ lại để bảo toàn dữ liệu"
                            Style="{StaticResource CaptionTextStyle}"
                            Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- =================================================
                 DATA TABLE
                 ================================================= -->

            <Border
                Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Padding="0"
                Margin="0,14,0,12"
                ClipToBounds="True">

                <Grid>

                    <DataGrid
                        ItemsSource="{Binding Categories}"
                        SelectedItem="{Binding SelectedCategory,
                            Mode=TwoWay}"
                        Style="{StaticResource ModernDataGridStyle}"
                        EnableRowVirtualization="True"
                        EnableColumnVirtualization="True"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling"
                        ScrollViewer.CanContentScroll="True">

                        <DataGrid.Columns>

                            <DataGridTextColumn
                                Header="THỨ TỰ"
                                Binding="{Binding DisplayOrderText}"
                                Width="0.8*" />

                            <DataGridTemplateColumn
                                Header="DANH MỤC"
                                Width="2.3*">

                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <StackPanel>

                                            <TextBlock
                                                Text="{Binding Name}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                TextTrimming="CharacterEllipsis"
                                                ToolTip="{Binding Name}" />

                                            <TextBlock
                                                Text="{Binding DescriptionText}"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                FontSize="10"
                                                TextTrimming="CharacterEllipsis"
                                                ToolTip="{Binding DescriptionText}"
                                                Margin="0,3,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn
                                Header="TRẠNG THÁI"
                                Width="1.25*">

                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <Border
                                            HorizontalAlignment="Left"
                                            Padding="9,4"
                                            CornerRadius="7">

                                            <Border.Style>

                                                <Style TargetType="{x:Type Border}">

                                                    <Setter
                                                        Property="Background"
                                                        Value="{StaticResource DangerSoftBrush}" />

                                                    <Style.Triggers>

                                                        <DataTrigger
                                                            Binding="{Binding IsActive}"
                                                            Value="True">

                                                            <Setter
                                                                Property="Background"
                                                                Value="{StaticResource SuccessSoftBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <TextBlock
                                                Text="{Binding StatusText}"
                                                FontSize="10"
                                                FontWeight="SemiBold">

                                                <TextBlock.Style>

                                                    <Style TargetType="{x:Type TextBlock}">

                                                        <Setter
                                                            Property="Foreground"
                                                            Value="{StaticResource DangerBrush}" />

                                                        <Style.Triggers>

                                                            <DataTrigger
                                                                Binding="{Binding IsActive}"
                                                                Value="True">

                                                                <Setter
                                                                    Property="Foreground"
                                                                    Value="{StaticResource SuccessBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Header="CẬP NHẬT"
                                Binding="{Binding UpdatedAtText}"
                                Width="1.3*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->

                    <Border
                        Background="{StaticResource SurfaceBrush}">

                        <Border.Style>

                            <Style TargetType="{x:Type Border}">

                                <Setter
                                    Property="Visibility"
                                    Value="Collapsed" />

                                <Style.Triggers>

                                    <MultiDataTrigger>

                                        <MultiDataTrigger.Conditions>

                                            <Condition
                                                Binding="{Binding Categories.Count}"
                                                Value="0" />

                                            <Condition
                                                Binding="{Binding IsBusy}"
                                                Value="False" />
                                        </MultiDataTrigger.Conditions>

                                        <Setter
                                            Property="Visibility"
                                            Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                            <Border
                                Width="58"
                                Height="58"
                                Background="{StaticResource GoldSoftBrush}"
                                BorderBrush="{StaticResource GoldBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18">

                                <TextBlock
                                    Text="&#xE8EC;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Foreground="{StaticResource GoldBrush}"
                                    FontSize="24"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>

                            <TextBlock
                                Text="Chưa có danh mục phù hợp"
                                Style="{StaticResource SectionTitleTextStyle}"
                                HorizontalAlignment="Center"
                                Margin="0,13,0,0" />

                            <TextBlock
                                Text="Thử thay đổi từ khóa hoặc bộ lọc trạng thái."
                                Style="{StaticResource CaptionTextStyle}"
                                HorizontalAlignment="Center"
                                Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- =================================================
                 SELECTED DETAIL
                 ================================================= -->

            <Border
                Grid.Row="3"
                MinHeight="82"
                Style="{StaticResource CardStyle}"
                Padding="15">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>

                        <TextBlock
                            Text="{Binding SelectedCategoryTitle}"
                            Style="{StaticResource SectionTitleTextStyle}"
                            FontSize="14" />

                        <TextBlock
                            Text="{Binding SelectedCategoryDescription}"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="10"
                            TextWrapping="Wrap"
                            TextTrimming="CharacterEllipsis"
                            Margin="0,6,20,0" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                        <Button
                            Content="Sửa danh mục"
                            Command="{Binding EditCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="108" />

                        <Button
                            Content="{Binding ToggleActiveButtonText}"
                            Command="{Binding ToggleActiveCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="126"
                            Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- =================================================
                 FOOTER
                 ================================================= -->

            <Grid
                Grid.Row="4"
                MinHeight="54"
                Margin="2,9,2,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Text="{Binding StatusMessage}"
                    VerticalAlignment="Center"
                    TextWrapping="Wrap">

                    <TextBlock.Style>

                        <Style
                            TargetType="{x:Type TextBlock}"
                            BasedOn="{StaticResource CaptionTextStyle}">

                            <Style.Triggers>

                                <DataTrigger
                                    Binding="{Binding IsStatusError}"
                                    Value="True">

                                    <Setter
                                        Property="Foreground"
                                        Value="{StaticResource DangerBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <Button
                        Content="Trước"
                        Command="{Binding PreviousPageCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="78" />

                    <Border
                        Height="42"
                        Padding="15,0"
                        Margin="9,0"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="8">

                        <TextBlock
                            Text="{Binding PageText}"
                            Foreground="White"
                            FontSize="11"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center" />
                    </Border>

                    <Button
                        Content="Sau"
                        Command="{Binding NextPageCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="78" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- =================================================
             LOADING OVERLAY
             ================================================= -->

        <Border
            Grid.RowSpan="2"
            Background="#BFFFFFFB"
            Visibility="{Binding IsBusy,
                Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border
                Width="310"
                Padding="24"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource GoldBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <StackPanel>

                    <ProgressBar
                        Height="5"
                        IsIndeterminate="True"
                        Foreground="{StaticResource AccentBrush}" />

                    <TextBlock
                        Text="Đang tải và đối chiếu danh mục..."
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="12"
                        HorizontalAlignment="Center"
                        Margin="0,14,0,0" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>