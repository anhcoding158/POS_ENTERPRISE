<Window
    x:Class="POS.Wpf.Views.ShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="POS Enterprise"
    Width="1366"
    Height="768"
    MinWidth="1100"
    MinHeight="650"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="SingleBorderWindow"
    ResizeMode="CanResize"
    SizeToContent="Manual"
    Background="{StaticResource AppBackgroundBrush}"
    FontFamily="Segoe UI"
    FontSize="12"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <Window.Resources>

        <!-- =================================================
             LOCAL TYPOGRAPHY & ALIGNMENT STYLES
             ================================================= -->

        <Style
            x:Key="ShellCaptionTextStyle"
            TargetType="{x:Type TextBlock}"
            BasedOn="{StaticResource CaptionTextStyle}">

            <Setter
                Property="FontSize"
                Value="11.5" />
        </Style>

        <!-- Đã sửa: HorizontalAlignment="Stretch" để TextAlignment hoạt động đúng trên toàn cột -->
        <Style
            x:Key="CenteredTableTextStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}" />

            <Setter
                Property="FontSize"
                Value="12.5" />

            <Setter
                Property="TextAlignment"
                Value="Center" />

            <Setter
                Property="HorizontalAlignment"
                Value="Stretch" />

            <Setter
                Property="VerticalAlignment"
                Value="Center" />

            <Setter
                Property="TextTrimming"
                Value="CharacterEllipsis" />
        </Style>

        <Style
            x:Key="CenteredTableHeaderTextStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="{StaticResource TextSecondaryBrush}" />

            <Setter
                Property="FontSize"
                Value="11.5" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />

            <Setter
                Property="TextAlignment"
                Value="Center" />

            <Setter
                Property="HorizontalAlignment"
                Value="Stretch" />

            <Setter
                Property="VerticalAlignment"
                Value="Center" />
        </Style>

        <!-- Thêm Style Căn Phải (cho Cột Giá Bán) -->
        <Style
            x:Key="RightAlignedTableTextStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}" />

            <Setter
                Property="FontSize"
                Value="12.5" />

            <Setter
                Property="TextAlignment"
                Value="Right" />

            <Setter
                Property="HorizontalAlignment"
                Value="Stretch" />

            <Setter
                Property="VerticalAlignment"
                Value="Center" />

            <!-- Khoảng cách để không dính sát lề phải -->
            <Setter 
                Property="Margin" 
                Value="0,0,25,0" />
        </Style>

        <Style
            x:Key="RightAlignedTableHeaderTextStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="{StaticResource TextSecondaryBrush}" />

            <Setter
                Property="FontSize"
                Value="11.5" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />

            <Setter
                Property="TextAlignment"
                Value="Right" />

            <Setter
                Property="HorizontalAlignment"
                Value="Stretch" />

            <Setter
                Property="VerticalAlignment"
                Value="Center" />

            <Setter 
                Property="Margin" 
                Value="0,0,25,0" />
        </Style>

        <!-- Thêm Style Căn Trái (Cho cột Tiêu đề Sản Phẩm) -->
        <Style
            x:Key="LeftAlignedTableHeaderTextStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="{StaticResource TextSecondaryBrush}" />

            <Setter
                Property="FontSize"
                Value="11.5" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />

            <Setter
                Property="TextAlignment"
                Value="Left" />

            <Setter
                Property="HorizontalAlignment"
                Value="Stretch" />

            <Setter
                Property="VerticalAlignment"
                Value="Center" />

            <!-- Margin khớp với phần đệm của icon bên dưới -->
            <Setter 
                Property="Margin" 
                Value="15,0,0,0" />
        </Style>

        <!-- =================================================
             INVENTORY ACTION BUTTON
             ================================================= -->

        <Style
            x:Key="InventoryActionButtonStyle"
            TargetType="{x:Type Button}"
            BasedOn="{StaticResource SecondaryButtonStyle}">

            <Setter
                Property="Background"
                Value="{StaticResource GoldSoftBrush}" />

            <Setter
                Property="Foreground"
                Value="#8C611D" />

            <Setter
                Property="BorderBrush"
                Value="{StaticResource GoldBorderBrush}" />

            <Setter
                Property="MinWidth"
                Value="142" />

            <Setter
                Property="FontSize"
                Value="13" />
        </Style>

        <!-- =================================================
             INVENTORY HISTORY BUTTON
             ================================================= -->

        <Style
            x:Key="InventoryHistoryButtonStyle"
            TargetType="{x:Type Button}">

            <Setter
                Property="Background"
                Value="{StaticResource AccentSoftBrush}" />

            <Setter
                Property="Foreground"
                Value="{StaticResource AccentBrush}" />

            <Setter
                Property="BorderBrush"
                Value="{StaticResource AccentBorderBrush}" />

            <Setter
                Property="BorderThickness"
                Value="1" />

            <Setter
                Property="Padding"
                Value="16,0" />

            <Setter
                Property="Height"
                Value="42" />

            <Setter
                Property="MinWidth"
                Value="132" />

            <Setter
                Property="FontFamily"
                Value="Segoe UI" />

            <Setter
                Property="FontSize"
                Value="13" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />

            <Setter
                Property="Cursor"
                Value="Hand" />

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate
                        TargetType="{x:Type Button}">

                        <Border
                            x:Name="HistoryButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9"
                            Padding="{TemplateBinding Padding}">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger
                                Property="IsMouseOver"
                                Value="True">

                                <Setter
                                    TargetName="HistoryButtonBorder"
                                    Property="Background"
                                    Value="{StaticResource AccentBrush}" />

                                <Setter
                                    TargetName="HistoryButtonBorder"
                                    Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}" />

                                <Setter
                                    Property="Foreground"
                                    Value="White" />
                            </Trigger>

                            <Trigger
                                Property="IsPressed"
                                Value="True">

                                <Setter
                                    TargetName="HistoryButtonBorder"
                                    Property="Background"
                                    Value="{StaticResource AccentPressedBrush}" />
                            </Trigger>

                            <Trigger
                                Property="IsEnabled"
                                Value="False">

                                <Setter
                                    TargetName="HistoryButtonBorder"
                                    Property="Opacity"
                                    Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- =================================================
             SIDEBAR
             ================================================= -->

        <Border
            Grid.Column="0"
            Background="{StaticResource SidebarBrush}">

            <Grid Margin="20,20,20,18">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand -->

                <StackPanel HorizontalAlignment="Center">

                    <Grid
                        Width="72"
                        Height="72">

                        <Ellipse
                            Margin="4"
                            Stroke="{StaticResource GoldBrush}"
                            StrokeThickness="1.5" />

                        <Border
                            Width="47"
                            Height="47"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderBrush="{StaticResource GoldHoverBrush}"
                            BorderThickness="1.2"
                            CornerRadius="5"
                            RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <RotateTransform Angle="45" />
                            </Border.RenderTransform>
                        </Border>

                        <TextBlock
                            Text="P"
                            FontFamily="Georgia"
                            FontSize="30"
                            Foreground="{StaticResource GoldGradientBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock
                        Text="P O S   E N T E R P R I S E"
                        Foreground="{StaticResource GoldHoverBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0" />

                    <TextBlock
                        Text="R E S T A U R A N T   S O L U T I O N S"
                        Foreground="{StaticResource SidebarMutedBrush}"
                        FontSize="8.5"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Margin="0,5,0,0" />

                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0">

                        <Border
                            Width="40"
                            Height="1"
                            Background="#705E47"
                            VerticalAlignment="Center" />

                        <TextBlock
                            Text="◆"
                            Foreground="{StaticResource GoldBrush}"
                            FontSize="9"
                            Margin="7,0" />

                        <Border
                            Width="40"
                            Height="1"
                            Background="#705E47"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- Navigation -->

                <ScrollViewer
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    Margin="0,27,0,18">

                    <StackPanel>

                        <Grid Margin="7,0,0,10">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Text="MENU CHÍNH"
                                Foreground="{StaticResource SidebarMutedBrush}"
                                FontSize="11"
                                FontWeight="SemiBold" />

                            <Border
                                Grid.Column="1"
                                Height="1"
                                Margin="10,0,0,0"
                                Background="#4A423D"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Button
                            Style="{StaticResource NavigationButtonStyle}"
                            IsEnabled="False">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE80F;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="17"
                                    Width="32"
                                    VerticalAlignment="Center" />

                                <TextBlock
                                    Text="Tổng quan"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button
                            Style="{StaticResource SelectedNavigationButtonStyle}">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE719;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="17"
                                    Width="32"
                                    VerticalAlignment="Center" />

                                <TextBlock
                                    Text="Sản phẩm và kho"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button
                            Command="{Binding OpenCategoryManagementCommand}"
                            Style="{StaticResource NavigationButtonStyle}"
                            ToolTip="Quản lý danh mục sản phẩm">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE8EC;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="17"
                                    Width="32"
                                    VerticalAlignment="Center" />

                                <TextBlock
                                    Text="Danh mục"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button
                            Style="{StaticResource NavigationButtonStyle}"
                            IsEnabled="False">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE8D4;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="17"
                                    Width="32"
                                    VerticalAlignment="Center" />

                                <TextBlock
                                    Text="Khách hàng"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="SalesNavigationButton"
                            Click="OnOpenSalesClick"
                            Style="{StaticResource NavigationButtonStyle}"
                            ToolTip="Mở quầy bán hàng">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE8A1;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="17"
                                    Width="32"
                                    VerticalAlignment="Center" />

                                <TextBlock
                                    Text="Bán hàng"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button
                            Style="{StaticResource NavigationButtonStyle}"
                            IsEnabled="False">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE9D2;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="17"
                                    Width="32"
                                    VerticalAlignment="Center" />

                                <TextBlock
                                    Text="Báo cáo"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Quote -->

                        <Border
                            Margin="7,34,7,0"
                            Padding="15"
                            Background="{StaticResource SidebarSurfaceBrush}"
                            BorderBrush="#6A4C27"
                            BorderThickness="1"
                            CornerRadius="12">

                            <StackPanel>

                                <TextBlock
                                    Text="◆"
                                    Foreground="{StaticResource GoldBrush}"
                                    FontSize="10"
                                    HorizontalAlignment="Center" />

                                <TextBlock
                                    Text="“Chất lượng tạo nên thương hiệu, dịch vụ làm nên khác biệt.”"
                                    FontFamily="Georgia"
                                    FontSize="12"
                                    FontStyle="Italic"
                                    Foreground="#E5D3B5"
                                    TextWrapping="Wrap"
                                    TextAlignment="Center"
                                    LineHeight="20"
                                    Margin="0,10,0,10" />

                                <StackPanel
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                                    <Border
                                        Width="26"
                                        Height="1"
                                        Background="#785C34"
                                        VerticalAlignment="Center" />

                                    <TextBlock
                                        Text="✦"
                                        Foreground="{StaticResource GoldBrush}"
                                        FontSize="9"
                                        Margin="7,0" />

                                    <Border
                                        Width="26"
                                        Height="1"
                                        Background="#785C34"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Sidebar footer -->

                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Center">

                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">

                        <Ellipse
                            Width="7"
                            Height="7"
                            Fill="{StaticResource SuccessBrush}"
                            Margin="0,0,7,0"
                            VerticalAlignment="Center" />

                        <TextBlock
                            Text="SQLite đã kết nối"
                            Foreground="{StaticResource SidebarMutedBrush}"
                            FontSize="10.5" />
                    </StackPanel>

                    <TextBlock
                        Text="© 2026 POS Enterprise"
                        Foreground="#A0958C"
                        FontSize="10"
                        HorizontalAlignment="Center"
                        Margin="0,9,0,0" />

                    <TextBlock
                        Text="Phiên bản 2.0.0"
                        Foreground="#8A8078"
                        FontSize="10"
                        HorizontalAlignment="Center"
                        Margin="0,3,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- =================================================
             MAIN WORKSPACE
             ================================================= -->

        <Grid
            Grid.Column="1"
            Margin="24,18,24,20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->

            <Grid Grid.Row="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>

                    <TextBlock
                        Text="Sản phẩm và tồn kho"
                        Style="{StaticResource PageTitleTextStyle}" />

                    <TextBlock
                        Text="Quản lý danh mục, giá bán và toàn bộ biến động kho."
                        Style="{StaticResource SecondaryTextStyle}"
                        FontSize="13.5"
                        Margin="0,5,0,0" />

                    <StackPanel
                        Orientation="Horizontal"
                        Margin="0,10,0,0">

                        <Border
                            Width="105"
                            Height="1"
                            Background="{StaticResource GoldBorderBrush}"
                            VerticalAlignment="Center" />

                        <TextBlock
                            Text="◆"
                            Foreground="{StaticResource GoldBrush}"
                            FontSize="9"
                            Margin="7,0" />

                        <Border
                            Width="105"
                            Height="1"
                            Background="{StaticResource GoldBorderBrush}"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- Administrator card -->

                <Border
                    Grid.Column="1"
                    Padding="10,8,14,8"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="13">

                    <Border.Effect>

                        <DropShadowEffect
                            Color="#463026"
                            BlurRadius="12"
                            ShadowDepth="2"
                            Opacity="0.08" />
                    </Border.Effect>

                    <StackPanel Orientation="Horizontal">

                        <Border
                            Width="38"
                            Height="38"
                            Background="{StaticResource AccentGradientBrush}"
                            CornerRadius="19">

                            <TextBlock
                                Text="A"
                                FontFamily="Georgia"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <StackPanel
                            Margin="11,0,14,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                Text="Quản trị viên"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                FontSize="12.5"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding LastUpdatedText}"
                                Foreground="{StaticResource TextMutedBrush}"
                                FontSize="10.5"
                                Margin="0,2,0,0" />
                        </StackPanel>

                        <TextBlock
                            Text="&#xE70D;"
                            FontFamily="Segoe MDL2 Assets"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="11"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- =================================================
                 KPI CARDS
                 ================================================= -->

            <UniformGrid
                Grid.Row="1"
                Columns="4"
                Margin="0,18,0,16">

                <!-- Total products -->

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,10,0"
                    Padding="17">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="43"
                            Height="43"
                            Background="{StaticResource GoldSoftBrush}"
                            BorderBrush="{StaticResource GoldBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22">

                            <TextBlock
                                Text="&#xE719;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="{StaticResource GoldBrush}"
                                FontSize="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <StackPanel
                            Grid.Column="1"
                            Margin="13,0,0,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                Text="TỔNG SẢN PHẨM"
                                Style="{StaticResource ShellCaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding TotalProductsText}"
                                Style="{StaticResource CardValueTextStyle}"
                                Margin="0,4,0,0" />

                            <TextBlock
                                Text="Toàn bộ kết quả tìm kiếm"
                                Style="{StaticResource ShellCaptionTextStyle}"
                                Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Active products -->

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="4,0,6,0"
                    Padding="17">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="43"
                            Height="43"
                            Background="{StaticResource GoldSoftBrush}"
                            BorderBrush="{StaticResource GoldBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22">

                            <TextBlock
                                Text="&#xE73E;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="{StaticResource GoldBrush}"
                                FontSize="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <StackPanel
                            Grid.Column="1"
                            Margin="13,0,0,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                Text="ĐANG BÁN TRÊN TRANG"
                                Style="{StaticResource ShellCaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding ActiveProductsOnPageText}"
                                Style="{StaticResource CardValueTextStyle}"
                                Margin="0,4,0,0" />

                            <TextBlock
                                Text="Sản phẩm đang hoạt động"
                                Style="{StaticResource ShellCaptionTextStyle}"
                                Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Low-stock products -->

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="6,0,4,0"
                    Padding="17">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="43"
                            Height="43"
                            Background="{StaticResource WarningSoftBrush}"
                            BorderBrush="{StaticResource GoldBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22">

                            <TextBlock
                                Text="!"
                                Foreground="{StaticResource WarningBrush}"
                                FontSize="20"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <StackPanel
                            Grid.Column="1"
                            Margin="13,0,0,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                Text="SẮP HẾT TRÊN TRANG"
                                Style="{StaticResource ShellCaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding LowStockProductsOnPageText}"
                                Style="{StaticResource CardValueTextStyle}"
                                Margin="0,4,0,0" />

                            <TextBlock
                                Text="Cần kiểm tra nhập hàng"
                                Style="{StaticResource ShellCaptionTextStyle}"
                                Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Inventory value -->

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="10,0,0,0"
                    Padding="17">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="43"
                            Height="43"
                            Background="{StaticResource GoldSoftBrush}"
                            BorderBrush="{StaticResource GoldBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22">

                            <TextBlock
                                Text="₫"
                                Foreground="{StaticResource GoldBrush}"
                                FontSize="18"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <StackPanel
                            Grid.Column="1"
                            Margin="13,0,0,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                Text="GIÁ TRỊ VỐN TRÊN TRANG"
                                Style="{StaticResource ShellCaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding InventoryValueOnPageText}"
                                FontFamily="Georgia"
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Margin="0,5,0,0" />

                            <TextBlock
                                Text="Tồn dương × giá vốn"
                                Style="{StaticResource ShellCaptionTextStyle}"
                                Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- =================================================
                 PRODUCT WORKSPACE
                 ================================================= -->

            <Border
                Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Padding="0"
                ClipToBounds="True">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- =================================================
                         ROW 0: PRODUCT TITLE AND ACTIONS
                         ================================================= -->

                    <Grid
                        Grid.Row="0"
                        Margin="20,14,20,12">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">

                            <Border
                                Width="42"
                                Height="42"
                                Background="{StaticResource GoldSoftBrush}"
                                BorderBrush="{StaticResource GoldBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="21">

                                <TextBlock
                                    Text="&#xE719;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Foreground="{StaticResource GoldBrush}"
                                    FontSize="18"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>

                            <StackPanel
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">

                                <TextBlock
                                    Text="Danh mục sản phẩm"
                                    Style="{StaticResource SectionTitleTextStyle}" />

                                <TextBlock
                                    Text="Quản lý thông tin, giá bán và trạng thái hoạt động."
                                    Style="{StaticResource ShellCaptionTextStyle}"
                                    Margin="0,3,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal">

                            <Button
                                Command="{Binding AddProductCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                MinWidth="138">

                                <StackPanel Orientation="Horizontal">

                                    <TextBlock
                                        Text="&#xE710;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="13"
                                        Margin="0,0,7,0"
                                        VerticalAlignment="Center" />

                                    <TextBlock
                                        Text="Thêm sản phẩm"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button
                                Command="{Binding EditProductCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="82"
                                Margin="9,0,0,0">

                                <StackPanel Orientation="Horizontal">

                                    <TextBlock
                                        Text="&#xE70F;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="12"
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center" />

                                    <TextBlock
                                        Text="Sửa"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button
                                Content="{Binding ToggleProductButtonText}"
                                Command="{Binding ToggleProductActiveCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="104"
                                Margin="9,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <!-- =================================================
                         ROW 1: INVENTORY OPERATION RAIL
                         ================================================= -->

                    <Border
                        Grid.Row="1"
                        Margin="20,0,20,13"
                        Padding="13"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Width="40"
                                Height="40"
                                Background="{StaticResource GoldSoftBrush}"
                                BorderBrush="{StaticResource GoldBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="11">

                                <TextBlock
                                    Text="±"
                                    FontFamily="Georgia"
                                    Foreground="{StaticResource GoldBrush}"
                                    FontSize="20"
                                    FontWeight="Bold"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>

                            <StackPanel
                                Grid.Column="1"
                                Margin="12,0,16,0"
                                VerticalAlignment="Center">

                                <TextBlock
                                    Text="{Binding SelectedProductHint}"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis" />

                                <WrapPanel Margin="0,7,0,0">

                                    <Border
                                        Padding="8,4"
                                        Margin="0,0,7,4"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7">

                                        <StackPanel Orientation="Horizontal">

                                            <TextBlock
                                                Text="Mã: "
                                                Foreground="{StaticResource TextMutedBrush}"
                                                FontSize="10.5" />

                                            <TextBlock
                                                Text="{Binding SelectedProductCodeText}"
                                                Foreground="{StaticResource GoldBrush}"
                                                FontSize="10.5"
                                                FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Padding="8,4"
                                        Margin="0,0,7,4"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7">

                                        <StackPanel Orientation="Horizontal">

                                            <TextBlock
                                                Text="Tồn: "
                                                Foreground="{StaticResource TextMutedBrush}"
                                                FontSize="10.5" />

                                            <TextBlock
                                                Text="{Binding SelectedProductStockText}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                FontSize="10.5"
                                                FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Padding="8,4"
                                        Margin="0,0,7,4"
                                        Background="{StaticResource WarningSoftBrush}"
                                        BorderBrush="{StaticResource GoldBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7">

                                        <TextBlock
                                            Text="{Binding SelectedProductStockStateText}"
                                            Foreground="{StaticResource WarningBrush}"
                                            FontSize="10.5"
                                            FontWeight="SemiBold" />
                                    </Border>

                                    <Border
                                        Padding="8,4"
                                        Margin="0,0,0,4"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7">

                                        <TextBlock
                                            Text="{Binding SelectedProductPolicyText}"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            FontSize="10.5"
                                            FontWeight="SemiBold" />
                                    </Border>
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel
                                Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                                <Button
                                    Command="{Binding AdjustInventoryCommand}"
                                    Style="{StaticResource InventoryActionButtonStyle}"
                                    ToolTip="{Binding InventoryActionHint}"
                                    ToolTipService.ShowOnDisabled="True">

                                    <StackPanel Orientation="Horizontal">

                                        <TextBlock
                                            Text="±"
                                            FontFamily="Georgia"
                                            FontSize="17"
                                            FontWeight="Bold"
                                            Margin="0,0,7,0"
                                            VerticalAlignment="Center" />

                                        <TextBlock
                                            Text="Điều chỉnh kho"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button
                                    Command="{Binding ViewInventoryHistoryCommand}"
                                    Style="{StaticResource InventoryHistoryButtonStyle}"
                                    Margin="9,0,0,0"
                                    ToolTip="{Binding InventoryHistoryActionHint}">

                                    <StackPanel Orientation="Horizontal">

                                        <TextBlock
                                            Text="&#xE81C;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="14"
                                            Margin="0,0,7,0"
                                            VerticalAlignment="Center" />

                                        <TextBlock
                                            Text="Lịch sử kho"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- =================================================
                         ROW 2: SEARCH TOOLBAR
                         ================================================= -->

                    <Border
                        Grid.Row="2"
                        Padding="20,11"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,1">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid
                                Width="420"
                                HorizontalAlignment="Left">

                                <TextBox
                                    x:Name="SearchBox"
                                    Text="{Binding SearchTerm,
                                        UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource SearchBoxWithIconStyle}"
                                    FontSize="13" />

                                <TextBlock
                                    Text="&#xE721;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    FontSize="14"
                                    Margin="15,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False" />

                                <TextBlock
                                    Text="Tìm theo mã, tên hoặc barcode..."
                                    Foreground="{StaticResource TextMutedBrush}"
                                    FontSize="12.5"
                                    Margin="42,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False">

                                    <TextBlock.Style>

                                        <Style
                                            TargetType="{x:Type TextBlock}">

                                            <Setter
                                                Property="Visibility"
                                                Value="Collapsed" />

                                            <Style.Triggers>

                                                <MultiDataTrigger>

                                                    <MultiDataTrigger.Conditions>

                                                        <Condition
                                                            Binding="{Binding Text.Length,
                                                                ElementName=SearchBox}"
                                                            Value="0" />

                                                        <Condition
                                                            Binding="{Binding IsKeyboardFocusWithin,
                                                                ElementName=SearchBox}"
                                                            Value="False" />
                                                    </MultiDataTrigger.Conditions>

                                                    <Setter
                                                        Property="Visibility"
                                                        Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal">

                                <Button
                                    Command="{Binding SearchCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    MinWidth="100"
                                    IsDefault="True">

                                    <StackPanel Orientation="Horizontal">

                                        <TextBlock
                                            Text="&#xE721;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="12"
                                            Margin="0,0,7,0"
                                            VerticalAlignment="Center" />

                                        <TextBlock
                                            Text="Tìm kiếm"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button
                                    Content="Tải lại"
                                    Command="{Binding RefreshCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinWidth="88"
                                    Margin="9,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- =================================================
                         ROW 3: PRODUCT DATA TABLE
                         ================================================= -->

                    <Grid Grid.Row="3">

                        <DataGrid
                            ItemsSource="{Binding Products}"
                            SelectedItem="{Binding SelectedProduct,
                                Mode=TwoWay}"
                            Style="{StaticResource ModernDataGridStyle}"
                            EnableRowVirtualization="True"
                            EnableColumnVirtualization="True"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling"
                            ScrollViewer.CanContentScroll="True"
                            ScrollViewer.IsDeferredScrollingEnabled="True">

                            <DataGrid.Columns>

                                <!-- SẢN PHẨM: Đã cập nhật HeaderTemplate và CellTemplate Margin để căn trái mượt mà -->
                                <DataGridTemplateColumn
                                    Width="2.4*">

                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="SẢN PHẨM" Style="{StaticResource LeftAlignedTableHeaderTextStyle}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Grid Margin="15,0,0,0">
                                                <!-- Thêm Margin để không sát lề -->

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border
                                                    Width="34"
                                                    Height="34"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="{StaticResource GoldSoftBrush}"
                                                    BorderBrush="{StaticResource GoldBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="9">

                                                    <TextBlock
                                                        Text="&#xE719;"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        Foreground="{StaticResource GoldBrush}"
                                                        FontSize="14"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="9,0,0,0"
                                                    VerticalAlignment="Center">

                                                    <TextBlock
                                                        Text="{Binding Name}"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        FontSize="13.5"
                                                        FontWeight="SemiBold"
                                                        TextTrimming="CharacterEllipsis" />

                                                    <StackPanel
                                                        Orientation="Horizontal"
                                                        Margin="0,3,0,0">

                                                        <TextBlock
                                                            Text="{Binding Code}"
                                                            Foreground="{StaticResource GoldBrush}"
                                                            FontSize="10.5"
                                                            FontWeight="SemiBold" />

                                                        <TextBlock
                                                            Text="  •  "
                                                            Foreground="{StaticResource TextMutedBrush}"
                                                            FontSize="10.5" />

                                                        <TextBlock
                                                            Text="{Binding UnitName}"
                                                            Foreground="{StaticResource TextSecondaryBrush}"
                                                            FontSize="10.5" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- CATEGORY -->

                                <DataGridTextColumn
                                    Binding="{Binding CategoryName}"
                                    Width="1.25*">

                                    <DataGridTextColumn.HeaderTemplate>

                                        <DataTemplate>

                                            <TextBlock
                                                Text="DANH MỤC"
                                                Style="{StaticResource CenteredTableHeaderTextStyle}" />
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>

                                    <DataGridTextColumn.ElementStyle>

                                        <Style
                                            TargetType="{x:Type TextBlock}"
                                            BasedOn="{StaticResource CenteredTableTextStyle}">

                                            <Setter
                                                Property="FontSize"
                                                Value="12.5" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- SALE PRICE: Đổi sang RightAligned (Căn phải chuẩn tiền tệ) -->

                                <DataGridTextColumn
                                    Binding="{Binding SalePriceText}"
                                    Width="1*">

                                    <DataGridTextColumn.HeaderTemplate>

                                        <DataTemplate>

                                            <TextBlock
                                                Text="GIÁ BÁN"
                                                Style="{StaticResource RightAlignedTableHeaderTextStyle}" />
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>

                                    <DataGridTextColumn.ElementStyle>

                                        <Style
                                            TargetType="{x:Type TextBlock}"
                                            BasedOn="{StaticResource RightAlignedTableTextStyle}">

                                            <Setter
                                                Property="FontFamily"
                                                Value="Georgia" />

                                            <Setter
                                                Property="FontSize"
                                                Value="12.5" />

                                            <Setter
                                                Property="FontWeight"
                                                Value="SemiBold" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- STOCK -->

                                <DataGridTemplateColumn
                                    Width="1.3*">

                                    <DataGridTemplateColumn.HeaderTemplate>

                                        <DataTemplate>

                                            <TextBlock
                                                Text="TỒN KHO"
                                                Style="{StaticResource CenteredTableHeaderTextStyle}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <StackPanel
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">

                                                <TextBlock
                                                    Text="{Binding StockDisplay}"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    FontSize="12.5"
                                                    FontWeight="SemiBold"
                                                    HorizontalAlignment="Center"
                                                    TextAlignment="Center" />

                                                <Border
                                                    Height="24"
                                                    MinWidth="62"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Padding="8,0"
                                                    CornerRadius="7"
                                                    Margin="0,4,0,0">

                                                    <Border.Style>

                                                        <Style
                                                            TargetType="{x:Type Border}">

                                                            <Setter
                                                                Property="Background"
                                                                Value="{StaticResource SuccessSoftBrush}" />

                                                            <Style.Triggers>

                                                                <DataTrigger
                                                                    Binding="{Binding TrackInventory}"
                                                                    Value="False">

                                                                    <Setter
                                                                        Property="Background"
                                                                        Value="{StaticResource SurfaceMutedBrush}" />
                                                                </DataTrigger>

                                                                <DataTrigger
                                                                    Binding="{Binding IsLowStock}"
                                                                    Value="True">

                                                                    <Setter
                                                                        Property="Background"
                                                                        Value="{StaticResource WarningSoftBrush}" />
                                                                </DataTrigger>

                                                                <DataTrigger
                                                                    Binding="{Binding IsOutOfStock}"
                                                                    Value="True">

                                                                    <Setter
                                                                        Property="Background"
                                                                        Value="{StaticResource DangerSoftBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <TextBlock
                                                        Text="{Binding StockStateText}"
                                                        FontSize="10.5"
                                                        FontWeight="SemiBold"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        TextAlignment="Center">

                                                        <TextBlock.Style>

                                                            <Style
                                                                TargetType="{x:Type TextBlock}">

                                                                <Setter
                                                                    Property="Foreground"
                                                                    Value="{StaticResource SuccessBrush}" />

                                                                <Style.Triggers>

                                                                    <DataTrigger
                                                                        Binding="{Binding TrackInventory}"
                                                                        Value="False">

                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{StaticResource TextSecondaryBrush}" />
                                                                    </DataTrigger>

                                                                    <DataTrigger
                                                                        Binding="{Binding IsLowStock}"
                                                                        Value="True">

                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{StaticResource WarningBrush}" />
                                                                    </DataTrigger>

                                                                    <DataTrigger
                                                                        Binding="{Binding IsOutOfStock}"
                                                                        Value="True">

                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{StaticResource DangerBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- STATUS -->

                                <DataGridTemplateColumn
                                    Width="1*">

                                    <DataGridTemplateColumn.HeaderTemplate>

                                        <DataTemplate>

                                            <TextBlock
                                                Text="TRẠNG THÁI"
                                                Style="{StaticResource CenteredTableHeaderTextStyle}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Grid>

                                                <Border
                                                    Height="28"
                                                    MinWidth="82"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Padding="11,0"
                                                    CornerRadius="8">

                                                    <Border.Style>

                                                        <Style
                                                            TargetType="{x:Type Border}">

                                                            <Setter
                                                                Property="Background"
                                                                Value="{StaticResource SurfaceMutedBrush}" />

                                                            <Setter
                                                                Property="BorderBrush"
                                                                Value="{StaticResource BorderBrush}" />

                                                            <Setter
                                                                Property="BorderThickness"
                                                                Value="1" />

                                                            <Style.Triggers>

                                                                <DataTrigger
                                                                    Binding="{Binding IsActive}"
                                                                    Value="True">

                                                                    <Setter
                                                                        Property="Background"
                                                                        Value="{StaticResource SuccessSoftBrush}" />

                                                                    <Setter
                                                                        Property="BorderBrush"
                                                                        Value="#C8E5D2" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <TextBlock
                                                        Text="{Binding StatusText}"
                                                        FontSize="10.5"
                                                        FontWeight="SemiBold"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        TextAlignment="Center">

                                                        <TextBlock.Style>

                                                            <Style
                                                                TargetType="{x:Type TextBlock}">

                                                                <Setter
                                                                    Property="Foreground"
                                                                    Value="{StaticResource TextSecondaryBrush}" />

                                                                <Style.Triggers>

                                                                    <DataTrigger
                                                                        Binding="{Binding IsActive}"
                                                                        Value="True">

                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{StaticResource SuccessBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty state -->

                        <Border Background="{StaticResource SurfaceBrush}">

                            <Border.Style>

                                <Style
                                    TargetType="{x:Type Border}">

                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />

                                    <Style.Triggers>

                                        <MultiDataTrigger>

                                            <MultiDataTrigger.Conditions>

                                                <Condition
                                                    Binding="{Binding Products.Count}"
                                                    Value="0" />

                                                <Condition
                                                    Binding="{Binding IsLoading}"
                                                    Value="False" />
                                            </MultiDataTrigger.Conditions>

                                            <Setter
                                                Property="Visibility"
                                                Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                                <Border
                                    Width="62"
                                    Height="62"
                                    Background="{StaticResource GoldSoftBrush}"
                                    BorderBrush="{StaticResource GoldBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20">

                                    <TextBlock
                                        Text="&#xE719;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="26"
                                        Foreground="{StaticResource GoldBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>

                                <TextBlock
                                    Text="Chưa có sản phẩm phù hợp"
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,14,0,0" />

                                <TextBlock
                                    Text="Thử thay đổi từ khóa hoặc tạo sản phẩm mới."
                                    Style="{StaticResource SecondaryTextStyle}"
                                    FontSize="12.5"
                                    HorizontalAlignment="Center"
                                    Margin="0,5,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Loading overlay -->

                        <Border
                            Background="#D9FFFEFB"
                            Visibility="{Binding IsLoading,
                                Converter={StaticResource BooleanToVisibilityConverter}}">

                            <StackPanel
                                Width="255"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                                <ProgressBar
                                    Height="5"
                                    IsIndeterminate="True"
                                    Foreground="{StaticResource AccentBrush}" />

                                <TextBlock
                                    Text="Đang tải dữ liệu sản phẩm..."
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="12.5"
                                    HorizontalAlignment="Center"
                                    Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- =================================================
                         ROW 4: FOOTER AND PAGINATION
                         ================================================= -->

                    <Grid
                        Grid.Row="4"
                        Margin="20,11">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Text="{Binding StatusMessage}"
                            Style="{StaticResource ShellCaptionTextStyle}"
                            VerticalAlignment="Center" />

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal">

                            <Button
                                Content="Trước"
                                Command="{Binding PreviousPageCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="78" />

                            <Border
                                Height="42"
                                Padding="15,0"
                                Margin="9,0"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="8">

                                <TextBlock
                                    Text="{Binding PageText}"
                                    Foreground="White"
                                    FontSize="11.5"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center" />
                            </Border>

                            <Button
                                Content="Sau"
                                Command="{Binding NextPageCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="78" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>