<Window
    x:Class="POS.Wpf.Views.ShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="POS Enterprise"
    Width="1480"
    Height="880"
    MinWidth="1200"
    MinHeight="720"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource AppBackgroundBrush}"
    FontFamily="Segoe UI"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <Grid Background="{StaticResource AppBackgroundBrush}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="252" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- =================================================
             LIGHT NAVIGATION
             ================================================= -->

        <Border
            Grid.Column="0"
            Background="{StaticResource NavigationSurfaceBrush}"
            BorderBrush="{StaticResource NavigationBorderBrush}"
            BorderThickness="0,0,1,0">

            <Grid Margin="18,22">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand -->

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="46"
                        Height="46"
                        Background="{StaticResource BrandGradientBrush}"
                        CornerRadius="15">

                        <Grid>

                            <TextBlock
                                Text="P"
                                Foreground="White"
                                FontSize="22"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />

                            <Ellipse
                                Width="9"
                                Height="5"
                                Fill="#BFFFFFFF"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,8,7,0"
                                RenderTransformOrigin="0.5,0.5">

                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-28" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                    </Border>

                    <StackPanel
                        Grid.Column="1"
                        Margin="11,2,0,0"
                        VerticalAlignment="Center">

                        <TextBlock
                            Text="POS Enterprise"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            FontSize="17"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="Retail &amp; Café"
                            Foreground="{StaticResource NavigationMutedBrush}"
                            FontSize="11"
                            Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>

                <!-- Store context -->

                <Border
                    Grid.Row="1"
                    Margin="0,22,0,18"
                    Padding="13,11"
                    Background="{StaticResource AccentSoftBrush}"
                    BorderBrush="{StaticResource AccentBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="29"
                            Height="29"
                            Background="{StaticResource SurfaceBrush}"
                            CornerRadius="9">

                            <TextBlock
                                Text="&#xE80F;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="{StaticResource AccentBrush}"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <StackPanel
                            Grid.Column="1"
                            Margin="9,0,0,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                Text="Cửa hàng trung tâm"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                FontSize="11"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="Chi nhánh mặc định"
                                Foreground="{StaticResource TextMutedBrush}"
                                FontSize="9"
                                Margin="0,2,0,0" />
                        </StackPanel>

                        <TextBlock
                            Grid.Column="2"
                            Text="&#xE70D;"
                            FontFamily="Segoe MDL2 Assets"
                            Foreground="{StaticResource AccentBrush}"
                            FontSize="11"
                            VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Navigation -->

                <StackPanel Grid.Row="2">

                    <TextBlock
                        Text="ĐIỀU HƯỚNG"
                        Foreground="{StaticResource NavigationMutedBrush}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Margin="12,0,0,8" />

                    <Button
                        Style="{StaticResource NavigationButtonStyle}"
                        IsEnabled="False">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock
                                Text="&#xE80F;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                Width="30"
                                VerticalAlignment="Center" />

                            <TextBlock
                                Text="Tổng quan"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button
                        Style="{StaticResource SelectedNavigationButtonStyle}">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock
                                Text="&#xE719;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                Width="30"
                                VerticalAlignment="Center" />

                            <TextBlock
                                Text="Sản phẩm"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button
                        Style="{StaticResource NavigationButtonStyle}"
                        IsEnabled="False">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock
                                Text="&#xE8D4;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                Width="30"
                                VerticalAlignment="Center" />

                            <TextBlock
                                Text="Khách hàng"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button
                        Style="{StaticResource NavigationButtonStyle}"
                        IsEnabled="False">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock
                                Text="&#xE8A1;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                Width="30"
                                VerticalAlignment="Center" />

                            <TextBlock
                                Text="Bán hàng"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button
                        Style="{StaticResource NavigationButtonStyle}"
                        IsEnabled="False">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock
                                Text="&#xE9D2;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                Width="30"
                                VerticalAlignment="Center" />

                            <TextBlock
                                Text="Báo cáo"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Border
                        Height="1"
                        Margin="10,18,10,18"
                        Background="{StaticResource NavigationBorderBrush}" />

                    <TextBlock
                        Text="HỆ THỐNG"
                        Foreground="{StaticResource NavigationMutedBrush}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Margin="12,0,0,8" />

                    <Button
                        Style="{StaticResource NavigationButtonStyle}"
                        IsEnabled="False">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock
                                Text="&#xE713;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                Width="30"
                                VerticalAlignment="Center" />

                            <TextBlock
                                Text="Thiết lập"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Connection status -->

                <Border
                    Grid.Row="3"
                    Padding="14"
                    Background="{StaticResource SurfaceMutedBrush}"
                    BorderBrush="{StaticResource NavigationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="13">

                    <StackPanel>

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Text="HỆ THỐNG"
                                Foreground="{StaticResource NavigationMutedBrush}"
                                FontSize="9"
                                FontWeight="SemiBold" />

                            <Border
                                Grid.Column="1"
                                Padding="7,3"
                                Background="{StaticResource SuccessSoftBrush}"
                                CornerRadius="7">

                                <TextBlock
                                    Text="ONLINE"
                                    Foreground="{StaticResource SuccessBrush}"
                                    FontSize="8"
                                    FontWeight="Bold" />
                            </Border>
                        </Grid>

                        <StackPanel
                            Orientation="Horizontal"
                            Margin="0,11,0,0">

                            <Ellipse
                                Width="8"
                                Height="8"
                                Fill="{StaticResource SuccessBrush}"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center" />

                            <TextBlock
                                Text="SQLite đã kết nối"
                                Foreground="{StaticResource NavigationTextBrush}"
                                FontSize="11"
                                FontWeight="SemiBold" />
                        </StackPanel>

                        <TextBlock
                            Text=".NET 10  •  Local database"
                            Foreground="{StaticResource NavigationMutedBrush}"
                            FontSize="9"
                            Margin="16,5,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- =================================================
             MAIN WORKSPACE
             ================================================= -->

        <Grid
            Grid.Column="1"
            Margin="26,21,26,22">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Page header -->

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>

                    <StackPanel Orientation="Horizontal">

                        <TextBlock
                            Text="Kho hàng"
                            Foreground="{StaticResource AccentBrush}"
                            FontSize="11"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="  /  "
                            Foreground="{StaticResource TextMutedBrush}"
                            FontSize="11" />

                        <TextBlock
                            Text="Sản phẩm"
                            Foreground="{StaticResource TextMutedBrush}"
                            FontSize="11" />
                    </StackPanel>

                    <TextBlock
                        Text="Danh mục sản phẩm"
                        Style="{StaticResource PageTitleTextStyle}"
                        Margin="0,7,0,0" />

                    <TextBlock
                        Text="Quản lý thông tin, giá bán và trạng thái tồn kho."
                        Style="{StaticResource SecondaryTextStyle}"
                        Margin="0,5,0,0" />
                </StackPanel>

                <!-- User -->

                <Border
                    Grid.Column="1"
                    Padding="8,7,13,7"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="13">

                    <StackPanel Orientation="Horizontal">

                        <Border
                            Width="36"
                            Height="36"
                            Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="11">

                            <TextBlock
                                Text="A"
                                Foreground="{StaticResource AccentBrush}"
                                FontWeight="Bold"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <StackPanel
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                Text="Quản trị viên"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                FontSize="12"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding LastUpdatedText}"
                                Foreground="{StaticResource TextMutedBrush}"
                                FontSize="9"
                                Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- KPI cards -->

            <UniformGrid
                Grid.Row="1"
                Columns="4"
                Margin="0,20,0,17">

                <!-- Total -->

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,10,0">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="48" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock
                                Text="TỔNG SẢN PHẨM"
                                Style="{StaticResource CaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding TotalProductsText}"
                                Style="{StaticResource CardValueTextStyle}"
                                Margin="0,8,0,0" />

                            <TextBlock
                                Text="Theo kết quả đang lọc"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,4,0,0" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Width="44"
                            Height="44"
                            Background="{StaticResource PurpleSoftBrush}"
                            CornerRadius="13">

                            <TextBlock
                                Text="&#xE719;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="{StaticResource PurpleBrush}"
                                FontSize="19"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Active -->

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="4,0,6,0">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="48" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock
                                Text="ĐANG BÁN TRÊN TRANG"
                                Style="{StaticResource CaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding ActiveProductsOnPageText}"
                                Style="{StaticResource CardValueTextStyle}"
                                Margin="0,8,0,0" />

                            <TextBlock
                                Text="Sản phẩm đang hoạt động"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,4,0,0" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Width="44"
                            Height="44"
                            Background="{StaticResource SuccessSoftBrush}"
                            CornerRadius="13">

                            <TextBlock
                                Text="&#xE73E;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="{StaticResource SuccessBrush}"
                                FontSize="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Low stock -->

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="6,0,4,0">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="48" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock
                                Text="SẮP HẾT TRÊN TRANG"
                                Style="{StaticResource CaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding LowStockProductsOnPageText}"
                                Style="{StaticResource CardValueTextStyle}"
                                Margin="0,8,0,0" />

                            <TextBlock
                                Text="Cần kiểm tra nhập hàng"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,4,0,0" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Width="44"
                            Height="44"
                            Background="{StaticResource WarningSoftBrush}"
                            CornerRadius="13">

                            <TextBlock
                                Text="!"
                                Foreground="{StaticResource WarningBrush}"
                                FontSize="20"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Inventory value -->

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="10,0,0,0">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="48" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock
                                Text="GIÁ TRỊ VỐN TRÊN TRANG"
                                Style="{StaticResource CaptionTextStyle}"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{Binding InventoryValueOnPageText}"
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Margin="0,10,0,0" />

                            <TextBlock
                                Text="Tồn kho × giá vốn"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,4,0,0" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Width="44"
                            Height="44"
                            Background="{StaticResource BlueSoftBrush}"
                            CornerRadius="13">

                            <TextBlock
                                Text="₫"
                                Foreground="{StaticResource BlueBrush}"
                                FontSize="18"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Product workspace -->

            <Border
                Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Padding="0">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Actions -->

                    <Grid Margin="20,17,20,15">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock
                                Text="Danh sách sản phẩm"
                                Style="{StaticResource SectionTitleTextStyle}" />

                            <TextBlock
                                Text="{Binding SelectedProductHint}"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal">

                            <Button
                                Command="{Binding AddProductCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                MinWidth="148">

                                <StackPanel Orientation="Horizontal">

                                    <TextBlock
                                        Text="&#xE710;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="13"
                                        Margin="0,0,7,0"
                                        VerticalAlignment="Center" />

                                    <TextBlock
                                        Text="Thêm sản phẩm"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button
                                Content="Sửa"
                                Command="{Binding EditProductCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="80"
                                Margin="8,0,0,0" />

                            <Button
                                Content="{Binding ToggleProductButtonText}"
                                Command="{Binding ToggleProductActiveCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="108"
                                Margin="8,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <!-- Search toolbar -->

                    <Border
                        Grid.Row="1"
                        Padding="20,12"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,1">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid
                                Width="440"
                                HorizontalAlignment="Left">

                                <TextBox
                                    x:Name="SearchBox"
                                    Text="{Binding SearchTerm,
                                        UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource SearchTextBoxStyle}" />

                                <TextBlock
                                    Text="&#xE721;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    FontSize="15"
                                    Margin="15,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False" />

                                <TextBlock
                                    Text="Tìm theo mã, tên hoặc barcode..."
                                    Foreground="{StaticResource TextMutedBrush}"
                                    FontSize="12"
                                    Margin="42,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False">

                                    <TextBlock.Style>

                                        <Style
                                            TargetType="{x:Type TextBlock}">

                                            <Setter
                                                Property="Visibility"
                                                Value="Collapsed" />

                                            <Style.Triggers>

                                                <MultiDataTrigger>

                                                    <MultiDataTrigger.Conditions>

                                                        <Condition
                                                            Binding="{Binding Text.Length,
                                                                ElementName=SearchBox}"
                                                            Value="0" />

                                                        <Condition
                                                            Binding="{Binding IsKeyboardFocusWithin,
                                                                ElementName=SearchBox}"
                                                            Value="False" />

                                                    </MultiDataTrigger.Conditions>

                                                    <Setter
                                                        Property="Visibility"
                                                        Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal">

                                <Button
                                    Content="Tìm kiếm"
                                    Command="{Binding SearchCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    MinWidth="98"
                                    IsDefault="True" />

                                <Button
                                    Content="Tải lại"
                                    Command="{Binding RefreshCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinWidth="88"
                                    Margin="8,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Product table -->

                    <Grid Grid.Row="2">

                        <DataGrid
                            ItemsSource="{Binding Products}"
                            SelectedItem="{Binding SelectedProduct,
                                Mode=TwoWay}"
                            Style="{StaticResource ModernDataGridStyle}"
                            EnableRowVirtualization="True"
                            EnableColumnVirtualization="True"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling"
                            ScrollViewer.CanContentScroll="True"
                            ScrollViewer.IsDeferredScrollingEnabled="True">

                            <DataGrid.Columns>

                                <DataGridTemplateColumn
                                    Header="SẢN PHẨM"
                                    Width="2.3*">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <StackPanel VerticalAlignment="Center">

                                                <TextBlock
                                                    Text="{Binding Name}"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    FontSize="13"
                                                    FontWeight="SemiBold" />

                                                <StackPanel
                                                    Orientation="Horizontal"
                                                    Margin="0,4,0,0">

                                                    <TextBlock
                                                        Text="{Binding Code}"
                                                        Foreground="{StaticResource AccentBrush}"
                                                        FontSize="10"
                                                        FontWeight="SemiBold" />

                                                    <TextBlock
                                                        Text="  •  "
                                                        Foreground="{StaticResource TextMutedBrush}"
                                                        FontSize="10" />

                                                    <TextBlock
                                                        Text="{Binding UnitName}"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        FontSize="10" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn
                                    Header="DANH MỤC"
                                    Binding="{Binding CategoryName}"
                                    Width="1.25*" />

                                <DataGridTextColumn
                                    Header="GIÁ BÁN"
                                    Binding="{Binding SalePriceText}"
                                    Width="1*" />

                                <DataGridTemplateColumn
                                    Header="TỒN KHO"
                                    Width="1.35*">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <StackPanel VerticalAlignment="Center">

                                                <TextBlock
                                                    Text="{Binding StockDisplay}"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    FontSize="12"
                                                    FontWeight="SemiBold" />

                                                <Border
                                                    HorizontalAlignment="Left"
                                                    Padding="7,2"
                                                    CornerRadius="7"
                                                    Margin="0,4,0,0">

                                                    <Border.Style>

                                                        <Style
                                                            TargetType="{x:Type Border}">

                                                            <Setter
                                                                Property="Background"
                                                                Value="{StaticResource SuccessSoftBrush}" />

                                                            <Style.Triggers>

                                                                <DataTrigger
                                                                    Binding="{Binding TrackInventory}"
                                                                    Value="False">

                                                                    <Setter
                                                                        Property="Background"
                                                                        Value="{StaticResource SurfaceMutedBrush}" />
                                                                </DataTrigger>

                                                                <DataTrigger
                                                                    Binding="{Binding IsLowStock}"
                                                                    Value="True">

                                                                    <Setter
                                                                        Property="Background"
                                                                        Value="{StaticResource WarningSoftBrush}" />
                                                                </DataTrigger>

                                                                <DataTrigger
                                                                    Binding="{Binding IsOutOfStock}"
                                                                    Value="True">

                                                                    <Setter
                                                                        Property="Background"
                                                                        Value="{StaticResource DangerSoftBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <TextBlock
                                                        Text="{Binding StockStateText}"
                                                        FontSize="9"
                                                        FontWeight="SemiBold">

                                                        <TextBlock.Style>

                                                            <Style
                                                                TargetType="{x:Type TextBlock}">

                                                                <Setter
                                                                    Property="Foreground"
                                                                    Value="{StaticResource SuccessBrush}" />

                                                                <Style.Triggers>

                                                                    <DataTrigger
                                                                        Binding="{Binding TrackInventory}"
                                                                        Value="False">

                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{StaticResource TextSecondaryBrush}" />
                                                                    </DataTrigger>

                                                                    <DataTrigger
                                                                        Binding="{Binding IsLowStock}"
                                                                        Value="True">

                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{StaticResource WarningBrush}" />
                                                                    </DataTrigger>

                                                                    <DataTrigger
                                                                        Binding="{Binding IsOutOfStock}"
                                                                        Value="True">

                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{StaticResource DangerBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn
                                    Header="TRẠNG THÁI"
                                    Width="1*">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Border
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Padding="9,4"
                                                CornerRadius="8">

                                                <Border.Style>

                                                    <Style
                                                        TargetType="{x:Type Border}">

                                                        <Setter
                                                            Property="Background"
                                                            Value="{StaticResource SurfaceMutedBrush}" />

                                                        <Style.Triggers>

                                                            <DataTrigger
                                                                Binding="{Binding IsActive}"
                                                                Value="True">

                                                                <Setter
                                                                    Property="Background"
                                                                    Value="{StaticResource SuccessSoftBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <StackPanel Orientation="Horizontal">

                                                    <Ellipse
                                                        Width="6"
                                                        Height="6"
                                                        Margin="0,0,6,0"
                                                        VerticalAlignment="Center">

                                                        <Ellipse.Style>

                                                            <Style
                                                                TargetType="{x:Type Ellipse}">

                                                                <Setter
                                                                    Property="Fill"
                                                                    Value="{StaticResource TextMutedBrush}" />

                                                                <Style.Triggers>

                                                                    <DataTrigger
                                                                        Binding="{Binding IsActive}"
                                                                        Value="True">

                                                                        <Setter
                                                                            Property="Fill"
                                                                            Value="{StaticResource SuccessBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>

                                                    <TextBlock
                                                        Text="{Binding StatusText}"
                                                        FontSize="10"
                                                        FontWeight="SemiBold">

                                                        <TextBlock.Style>

                                                            <Style
                                                                TargetType="{x:Type TextBlock}">

                                                                <Setter
                                                                    Property="Foreground"
                                                                    Value="{StaticResource TextSecondaryBrush}" />

                                                                <Style.Triggers>

                                                                    <DataTrigger
                                                                        Binding="{Binding IsActive}"
                                                                        Value="True">

                                                                        <Setter
                                                                            Property="Foreground"
                                                                            Value="{StaticResource SuccessBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty state -->

                        <Border
                            Background="{StaticResource SurfaceBrush}">

                            <Border.Style>

                                <Style
                                    TargetType="{x:Type Border}">

                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />

                                    <Style.Triggers>

                                        <MultiDataTrigger>

                                            <MultiDataTrigger.Conditions>

                                                <Condition
                                                    Binding="{Binding Products.Count}"
                                                    Value="0" />

                                                <Condition
                                                    Binding="{Binding IsLoading}"
                                                    Value="False" />
                                            </MultiDataTrigger.Conditions>

                                            <Setter
                                                Property="Visibility"
                                                Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                                <Border
                                    Width="64"
                                    Height="64"
                                    Background="{StaticResource AccentSoftBrush}"
                                    CornerRadius="20">

                                    <TextBlock
                                        Text="&#xE719;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="27"
                                        Foreground="{StaticResource AccentBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>

                                <TextBlock
                                    Text="Chưa có sản phẩm phù hợp"
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,15,0,0" />

                                <TextBlock
                                    Text="Thử thay đổi từ khóa hoặc tạo sản phẩm mới."
                                    Style="{StaticResource SecondaryTextStyle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Loading overlay -->

                        <Border
                            Background="#D9FFFFFF"
                            Visibility="{Binding IsLoading,
                                Converter={StaticResource BooleanToVisibilityConverter}}">

                            <StackPanel
                                Width="260"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                                <ProgressBar
                                    Height="5"
                                    IsIndeterminate="True"
                                    Foreground="{StaticResource AccentBrush}" />

                                <TextBlock
                                    Text="Đang tải dữ liệu sản phẩm..."
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="12"
                                    HorizontalAlignment="Center"
                                    Margin="0,13,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Footer -->

                    <Grid
                        Grid.Row="3"
                        Margin="20,12">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Text="{Binding StatusMessage}"
                            Style="{StaticResource CaptionTextStyle}"
                            VerticalAlignment="Center" />

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal">

                            <Button
                                Content="Trước"
                                Command="{Binding PreviousPageCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="80" />

                            <Border
                                Margin="9,0"
                                Padding="14,0"
                                Height="42"
                                Background="{StaticResource SurfaceMutedBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">

                                <TextBlock
                                    Text="{Binding PageText}"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center" />
                            </Border>

                            <Button
                                Content="Sau"
                                Command="{Binding NextPageCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="80" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>