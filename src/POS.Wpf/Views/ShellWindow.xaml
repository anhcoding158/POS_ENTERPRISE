<Window
    x:Class="POS.Wpf.Views.ShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="POS Enterprise"
    Width="1440"
    Height="860"
    MinWidth="1180"
    MinHeight="700"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource AppBackgroundBrush}"
    FontFamily="Segoe UI">

    <Grid Background="{StaticResource AppBackgroundBrush}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->

        <Border
            Grid.Column="0"
            Background="{StaticResource SidebarBrush}">

            <Grid Margin="20,26">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">

                    <Border
                        Width="46"
                        Height="46"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="14">

                        <TextBlock
                            Text="P"
                            Foreground="White"
                            FontSize="22"
                            FontWeight="Bold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>

                    <StackPanel
                        Margin="12,2,0,0"
                        VerticalAlignment="Center">

                        <TextBlock
                            Text="POS Enterprise"
                            Foreground="{StaticResource SidebarTextBrush}"
                            FontSize="17"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="Retail Management"
                            Foreground="{StaticResource SidebarMutedBrush}"
                            FontSize="11"
                            Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Grid.Row="1"
                    Margin="0,42,0,0">

                    <TextBlock
                        Text="KHÔNG GIAN LÀM VIỆC"
                        Foreground="{StaticResource SidebarMutedBrush}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Margin="12,0,0,10" />

                    <Button
                        Style="{StaticResource NavigationButtonStyle}"
                        IsEnabled="False">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Text="&#xE80F;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="17"
                                Width="30" />

                            <TextBlock
                                Text="Tổng quan"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button
                        Style="{StaticResource SelectedNavigationButtonStyle}">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Text="&#xE719;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="17"
                                Width="30" />

                            <TextBlock
                                Text="Sản phẩm"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button
                        Style="{StaticResource NavigationButtonStyle}"
                        IsEnabled="False">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Text="&#xE8D4;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="17"
                                Width="30" />

                            <TextBlock
                                Text="Khách hàng"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button
                        Style="{StaticResource NavigationButtonStyle}"
                        IsEnabled="False">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Text="&#xE8A1;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="17"
                                Width="30" />

                            <TextBlock
                                Text="Bán hàng"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button
                        Style="{StaticResource NavigationButtonStyle}"
                        IsEnabled="False">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Text="&#xE9D2;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="17"
                                Width="30" />

                            <TextBlock
                                Text="Báo cáo"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border
                    Grid.Row="2"
                    Background="#172033"
                    CornerRadius="12"
                    Padding="14">

                    <StackPanel>

                        <TextBlock
                            Text="LOCAL DATABASE"
                            Foreground="{StaticResource SidebarMutedBrush}"
                            FontSize="10"
                            FontWeight="SemiBold" />

                        <StackPanel
                            Orientation="Horizontal"
                            Margin="0,8,0,0">

                            <Ellipse
                                Width="8"
                                Height="8"
                                Fill="{StaticResource SuccessBrush}"
                                Margin="0,0,8,0" />

                            <TextBlock
                                Text="SQLite đã kết nối"
                                Foreground="{StaticResource SidebarTextBrush}"
                                FontSize="12" />
                        </StackPanel>

                        <TextBlock
                            Text=".NET 10 • Clean Architecture"
                            Foreground="{StaticResource SidebarMutedBrush}"
                            FontSize="10"
                            Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main content -->

        <Grid
            Grid.Column="1"
            Margin="30,26,30,24">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>

                    <TextBlock
                        Text="Danh mục sản phẩm"
                        Style="{StaticResource PageTitleTextStyle}" />

                    <TextBlock
                        Text="Quản lý sản phẩm, giá bán và trạng thái tồn kho."
                        Style="{StaticResource SecondaryTextStyle}"
                        Margin="0,6,0,0" />
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12,8">

                    <StackPanel Orientation="Horizontal">

                        <Border
                            Width="36"
                            Height="36"
                            Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="11">

                            <TextBlock
                                Text="A"
                                Foreground="{StaticResource AccentBrush}"
                                FontWeight="Bold"
                                FontSize="15"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <StackPanel
                            Margin="10,0,4,0"
                            VerticalAlignment="Center">

                            <TextBlock
                                Text="Quản trị viên"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}" />

                            <TextBlock
                                Text="{Binding LastUpdatedText}"
                                FontSize="10"
                                Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Statistics -->

            <UniformGrid
                Grid.Row="1"
                Columns="4"
                Margin="0,24,0,18">

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,12,0">

                    <StackPanel>

                        <TextBlock
                            Text="TỔNG SẢN PHẨM"
                            Style="{StaticResource CaptionTextStyle}"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="{Binding TotalProductsText}"
                            Style="{StaticResource CardValueTextStyle}"
                            Margin="0,8,0,0" />

                        <TextBlock
                            Text="Toàn bộ kết quả tìm kiếm"
                            Style="{StaticResource CaptionTextStyle}"
                            Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="4,0,8,0">

                    <StackPanel>

                        <TextBlock
                            Text="ĐANG BÁN TRÊN TRANG"
                            Style="{StaticResource CaptionTextStyle}"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="{Binding ActiveProductsOnPageText}"
                            Style="{StaticResource CardValueTextStyle}"
                            Margin="0,8,0,0" />

                        <TextBlock
                            Text="Sản phẩm đang hoạt động"
                            Style="{StaticResource CaptionTextStyle}"
                            Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="8,0,4,0">

                    <StackPanel>

                        <TextBlock
                            Text="SẮP HẾT TRÊN TRANG"
                            Style="{StaticResource CaptionTextStyle}"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="{Binding LowStockProductsOnPageText}"
                            Style="{StaticResource CardValueTextStyle}"
                            Margin="0,8,0,0" />

                        <TextBlock
                            Text="Cần kiểm tra nhập hàng"
                            Style="{StaticResource CaptionTextStyle}"
                            Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border
                    Style="{StaticResource CardStyle}"
                    Margin="12,0,0,0">

                    <StackPanel>

                        <TextBlock
                            Text="GIÁ TRỊ VỐN TRÊN TRANG"
                            Style="{StaticResource CaptionTextStyle}"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="{Binding InventoryValueOnPageText}"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Margin="0,10,0,0" />

                        <TextBlock
                            Text="Tồn kho × giá vốn"
                            Style="{StaticResource CaptionTextStyle}"
                            Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Product card -->

            <Border
                Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Padding="0">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->

                    <Grid Margin="20,18">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock
                                Text="Sản phẩm"
                                Style="{StaticResource SectionTitleTextStyle}" />

                            <TextBlock
                                Text="{Binding SelectedProductHint}"
                                Style="{StaticResource CaptionTextStyle}"
                                Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal">

                            <Button
                                Content="+ Thêm sản phẩm"
                                Command="{Binding AddProductCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                MinWidth="140" />

                            <Button
                                Content="Sửa"
                                Command="{Binding EditProductCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="82"
                                Margin="8,0,0,0" />

                            <Button
                                Content="{Binding ToggleProductButtonText}"
                                Command="{Binding ToggleProductActiveCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="105"
                                Margin="8,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <!-- Search -->

                    <Border
                        Grid.Row="1"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,1"
                        Padding="20,13">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid MaxWidth="440">

                                <TextBox
                                    x:Name="SearchBox"
                                    Text="{Binding SearchTerm,
                                        UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource SearchTextBoxStyle}" />

                                <TextBlock
                                    Text="Tìm theo mã, tên hoặc barcode..."
                                    Foreground="{StaticResource TextMutedBrush}"
                                    FontSize="13"
                                    Margin="14,0"
                                    IsHitTestVisible="False"
                                    VerticalAlignment="Center">

                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">

                                            <Setter
                                                Property="Visibility"
                                                Value="Collapsed" />

                                            <Style.Triggers>

                                                <MultiDataTrigger>

                                                    <MultiDataTrigger.Conditions>

                                                        <Condition
                                                            Binding="{Binding Text.Length,
                                                                ElementName=SearchBox}"
                                                            Value="0" />

                                                        <Condition
                                                            Binding="{Binding IsKeyboardFocusWithin,
                                                                ElementName=SearchBox}"
                                                            Value="False" />

                                                    </MultiDataTrigger.Conditions>

                                                    <Setter
                                                        Property="Visibility"
                                                        Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal">

                                <Button
                                    Content="Tìm kiếm"
                                    Command="{Binding SearchCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    IsDefault="True"
                                    MinWidth="100" />

                                <Button
                                    Content="Tải lại"
                                    Command="{Binding RefreshCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinWidth="90"
                                    Margin="8,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Grid -->

                    <Grid Grid.Row="2">

                        <DataGrid
                            ItemsSource="{Binding Products}"
                            SelectedItem="{Binding SelectedProduct,
                                Mode=TwoWay}"
                            Style="{StaticResource ModernDataGridStyle}"
                            EnableRowVirtualization="True"
                            EnableColumnVirtualization="True"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling"
                            ScrollViewer.CanContentScroll="True"
                            ScrollViewer.IsDeferredScrollingEnabled="True">

                            <DataGrid.Columns>

                                <DataGridTemplateColumn
                                    Header="SẢN PHẨM"
                                    Width="2*">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <StackPanel VerticalAlignment="Center">

                                                <TextBlock
                                                    Text="{Binding Name}"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    FontSize="14"
                                                    FontWeight="SemiBold" />

                                                <StackPanel
                                                    Orientation="Horizontal"
                                                    Margin="0,4,0,0">

                                                    <TextBlock
                                                        Text="{Binding Code}"
                                                        Foreground="{StaticResource AccentBrush}"
                                                        FontSize="11"
                                                        FontWeight="SemiBold" />

                                                    <TextBlock
                                                        Text="  •  "
                                                        Foreground="{StaticResource TextMutedBrush}"
                                                        FontSize="11" />

                                                    <TextBlock
                                                        Text="{Binding UnitName}"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        FontSize="11" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn
                                    Header="DANH MỤC"
                                    Binding="{Binding CategoryName}"
                                    Width="1.2*" />

                                <DataGridTextColumn
                                    Header="GIÁ BÁN"
                                    Binding="{Binding SalePriceText}"
                                    Width="1*" />

                                <DataGridTemplateColumn
                                    Header="TỒN KHO"
                                    Width="1.3*">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <StackPanel VerticalAlignment="Center">

                                                <TextBlock
                                                    Text="{Binding StockDisplay}"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    FontWeight="SemiBold"
                                                    FontSize="13" />

                                                <Border
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Padding="8,3"
                                                    CornerRadius="8"
                                                    Margin="0,5,0,0">

                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}">

                                                            <Setter
                                                                Property="Background"
                                                                Value="{StaticResource SuccessSoftBrush}" />

                                                            <Style.Triggers>

                                                                <DataTrigger
                                                                    Binding="{Binding TrackInventory}"
                                                                    Value="False">

                                                                    <Setter
                                                                        Property="Background"
                                                                        Value="{StaticResource SurfaceMutedBrush}" />
                                                                </DataTrigger>

                                                                <DataTrigger
                                                                    Binding="{Binding IsLowStock}"
                                                                    Value="True">

                                                                    <Setter
                                                                        Property="Background"
                                                                        Value="{StaticResource WarningSoftBrush}" />
                                                                </DataTrigger>

                                                                <DataTrigger
                                                                    Binding="{Binding IsOutOfStock}"
                                                                    Value="True">

                                                                    <Setter
                                                                        Property="Background"
                                                                        Value="{StaticResource DangerSoftBrush}" />
                                                                </DataTrigger>

                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <TextBlock
                                                        Text="{Binding StockStateText}"
                                                        FontSize="10"
                                                        FontWeight="SemiBold" />
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn
                                    Header="TRẠNG THÁI"
                                    Width="1*">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Border
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Padding="10,5"
                                                CornerRadius="9">

                                                <Border.Style>
                                                    <Style TargetType="{x:Type Border}">

                                                        <Setter
                                                            Property="Background"
                                                            Value="{StaticResource SurfaceMutedBrush}" />

                                                        <Style.Triggers>

                                                            <DataTrigger
                                                                Binding="{Binding IsActive}"
                                                                Value="True">

                                                                <Setter
                                                                    Property="Background"
                                                                    Value="{StaticResource SuccessSoftBrush}" />
                                                            </DataTrigger>

                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <TextBlock
                                                    Text="{Binding StatusText}"
                                                    FontSize="11"
                                                    FontWeight="SemiBold">

                                                    <TextBlock.Style>
                                                        <Style TargetType="{x:Type TextBlock}">

                                                            <Setter
                                                                Property="Foreground"
                                                                Value="{StaticResource TextSecondaryBrush}" />

                                                            <Style.Triggers>

                                                                <DataTrigger
                                                                    Binding="{Binding IsActive}"
                                                                    Value="True">

                                                                    <Setter
                                                                        Property="Foreground"
                                                                        Value="{StaticResource SuccessBrush}" />
                                                                </DataTrigger>

                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty state -->

                        <Border
                            Background="{StaticResource SurfaceBrush}">

                            <Border.Style>
                                <Style TargetType="{x:Type Border}">

                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />

                                    <Style.Triggers>

                                        <MultiDataTrigger>

                                            <MultiDataTrigger.Conditions>

                                                <Condition
                                                    Binding="{Binding Products.Count}"
                                                    Value="0" />

                                                <Condition
                                                    Binding="{Binding IsLoading}"
                                                    Value="False" />

                                            </MultiDataTrigger.Conditions>

                                            <Setter
                                                Property="Visibility"
                                                Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                                <Border
                                    Width="64"
                                    Height="64"
                                    Background="{StaticResource AccentSoftBrush}"
                                    CornerRadius="20">

                                    <TextBlock
                                        Text="&#xE719;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="28"
                                        Foreground="{StaticResource AccentBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>

                                <TextBlock
                                    Text="Chưa có sản phẩm phù hợp"
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,16,0,0" />

                                <TextBlock
                                    Text="Thử thay đổi từ khóa hoặc tạo sản phẩm mới."
                                    Style="{StaticResource SecondaryTextStyle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Loading -->

                        <Border
                            Background="#D9FFFFFF"
                            Visibility="{Binding IsLoading,
                                Converter={StaticResource BooleanToVisibilityConverter}}">

                            <StackPanel
                                Width="260"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                                <ProgressBar
                                    Height="5"
                                    IsIndeterminate="True"
                                    Foreground="{StaticResource AccentBrush}" />

                                <TextBlock
                                    Text="Đang đồng bộ dữ liệu sản phẩm..."
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="13"
                                    HorizontalAlignment="Center"
                                    Margin="0,14,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Footer -->

                    <Grid
                        Grid.Row="3"
                        Margin="20,14">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Text="{Binding StatusMessage}"
                            Style="{StaticResource CaptionTextStyle}"
                            VerticalAlignment="Center" />

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal">

                            <Button
                                Content="Trước"
                                Command="{Binding PreviousPageCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="82" />

                            <TextBlock
                                Text="{Binding PageText}"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                FontSize="12"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Margin="16,0" />

                            <Button
                                Content="Sau"
                                Command="{Binding NextPageCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="82" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>