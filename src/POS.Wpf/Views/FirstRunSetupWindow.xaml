<Window
    x:Class="POS.Wpf.Views.FirstRunSetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Language="vi-VN"
    Title="POS Enterprise - Thiết lập ban đầu"
    Width="1120"
    Height="720"
    MinWidth="980"
    MinHeight="640"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    ShowInTaskbar="True"
    Background="{StaticResource AppBackgroundBrush}"
    FontFamily="Segoe UI"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <Window.Resources>

        <Style
            x:Key="AuthLabelStyle"
            TargetType="{x:Type TextBlock}">

            <Setter
                Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}" />

            <Setter
                Property="FontSize"
                Value="12" />

            <Setter
                Property="FontWeight"
                Value="SemiBold" />

            <Setter
                Property="Margin"
                Value="0,0,0,7" />
        </Style>

        <Style
            x:Key="AuthTextBoxStyle"
            TargetType="{x:Type TextBox}"
            BasedOn="{StaticResource SearchTextBoxStyle}">

            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="AuthPasswordBoxStyle"
            TargetType="{x:Type PasswordBox}">

            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style
            x:Key="AuthErrorStyle"
            TargetType="{x:Type TextBlock}">

            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="2,5,0,0" />

            <Style.Triggers>

                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>

                <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>

            </Style.Triggers>
        </Style>

        <Style
            x:Key="PasswordRequirementStyle"
            TargetType="{x:Type TextBlock}">

            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="TextWrapping" Value="Wrap" />

            <Style.Triggers>

                <DataTrigger
                    Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}"
                    Value="True">

                    <Setter
                        Property="Foreground"
                        Value="{StaticResource SuccessBrush}" />

                    <Setter
                        Property="FontWeight"
                        Value="SemiBold" />
                </DataTrigger>

            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Brand panel -->

        <Border
            Grid.Column="0"
            Background="{StaticResource SidebarBrush}">

            <Grid Margin="42">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>

                    <Grid Width="86" Height="86">

                        <Ellipse
                            Stroke="{StaticResource GoldBrush}"
                            StrokeThickness="1.5" />

                        <Border
                            Width="55"
                            Height="55"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderBrush="{StaticResource GoldHoverBrush}"
                            BorderThickness="1.3"
                            CornerRadius="6"
                            RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <RotateTransform Angle="45" />
                            </Border.RenderTransform>
                        </Border>

                        <TextBlock
                            Text="P"
                            FontFamily="Georgia"
                            FontSize="36"
                            Foreground="{StaticResource GoldHoverBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock
                        Text="POS ENTERPRISE"
                        Foreground="{StaticResource GoldHoverBrush}"
                        FontFamily="Georgia"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Margin="0,22,0,0" />

                    <TextBlock
                        Text="RESTAURANT SOLUTIONS"
                        Foreground="{StaticResource SidebarMutedBrush}"
                        FontSize="9"
                        FontWeight="SemiBold"
                        Margin="0,7,0,0" />
                </StackPanel>

                <StackPanel
                    Grid.Row="1"
                    VerticalAlignment="Center">

                    <TextBlock
                        Text="Thiết lập cửa hàng"
                        Foreground="{StaticResource GoldHoverBrush}"
                        FontFamily="Georgia"
                        FontSize="30"
                        FontWeight="SemiBold"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Text="Tạo tài khoản quản trị viên đầu tiên để bảo vệ dữ liệu, cấu hình và nghiệp vụ bán hàng."
                        Foreground="#E1D2C2"
                        FontSize="13"
                        TextWrapping="Wrap"
                        LineHeight="22"
                        Margin="0,16,0,0" />

                    <Border
                        Margin="0,28,0,0"
                        Padding="18"
                        Background="{StaticResource SidebarSurfaceBrush}"
                        BorderBrush="#725333"
                        BorderThickness="1"
                        CornerRadius="14">

                        <StackPanel>

                            <TextBlock
                                Text="BẢO MẬT NGAY TỪ ĐẦU"
                                Foreground="{StaticResource GoldBrush}"
                                FontSize="10"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="Mật khẩu được băm bằng BCrypt. Hệ thống không lưu mật khẩu gốc và không tạo tài khoản mặc định."
                                Foreground="{StaticResource SidebarMutedBrush}"
                                FontSize="11"
                                TextWrapping="Wrap"
                                LineHeight="19"
                                Margin="0,9,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock
                    Grid.Row="2"
                    Text="Bước 1 / 1  •  Khởi tạo quản trị viên"
                    Foreground="{StaticResource SidebarMutedBrush}"
                    FontSize="10" />
            </Grid>
        </Border>

        <!-- Form panel -->

        <Grid
            Grid.Column="1"
            Background="{StaticResource AppBackgroundBrush}">

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="78" />
            </Grid.RowDefinitions>

            <ScrollViewer
                Grid.Row="0"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">

                <StackPanel
                    MaxWidth="590"
                    Margin="52,38,52,34"
                    HorizontalAlignment="Center">

                    <TextBlock
                        Text="Tạo Administrator đầu tiên"
                        Style="{StaticResource PageTitleTextStyle}" />

                    <TextBlock
                        Text="Tài khoản này có toàn quyền quản lý hệ thống. Hãy sử dụng thông tin riêng và dễ nhớ."
                        Style="{StaticResource SecondaryTextStyle}"
                        TextWrapping="Wrap"
                        Margin="0,7,0,26" />

                    <!-- Full name -->

                    <TextBlock
                        Text="Họ tên quản trị viên *"
                        Style="{StaticResource AuthLabelStyle}" />

                    <TextBox
                        Text="{Binding FullName,
                            UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource AuthTextBoxStyle}"
                        MaxLength="150" />

                    <TextBlock
                        Text="{Binding FullNameError}"
                        Style="{StaticResource AuthErrorStyle}" />

                    <!-- Username -->

                    <TextBlock
                        Text="Tên đăng nhập *"
                        Style="{StaticResource AuthLabelStyle}"
                        Margin="0,18,0,7" />

                    <TextBox
                        x:Name="UsernameInput"
                        Text="{Binding Username,
                            UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource AuthTextBoxStyle}"
                        MaxLength="50" />

                    <TextBlock
                        Text="{Binding UsernameError}"
                        Style="{StaticResource AuthErrorStyle}" />

                    <TextBlock
                        Text="Dùng chữ, số, dấu chấm, gạch dưới hoặc gạch ngang."
                        Style="{StaticResource CaptionTextStyle}"
                        TextWrapping="Wrap"
                        Margin="2,6,0,0" />

                    <!-- Password -->

                    <TextBlock
                        Text="Mật khẩu *"
                        Style="{StaticResource AuthLabelStyle}"
                        Margin="0,18,0,7" />

                    <Grid>

                        <PasswordBox
                            x:Name="PasswordInput"
                            Style="{StaticResource AuthPasswordBoxStyle}"
                            PasswordChanged="OnPasswordChanged" />

                        <TextBox
                            x:Name="VisiblePasswordInput"
                            Visibility="Collapsed"
                            Style="{StaticResource AuthTextBoxStyle}"
                            TextChanged="OnVisiblePasswordChanged" />
                    </Grid>

                    <TextBlock
                        Text="{Binding PasswordError}"
                        Style="{StaticResource AuthErrorStyle}" />

                    <!-- Confirm password -->

                    <TextBlock
                        Text="Xác nhận mật khẩu *"
                        Style="{StaticResource AuthLabelStyle}"
                        Margin="0,18,0,7" />

                    <Grid>

                        <PasswordBox
                            x:Name="ConfirmPasswordInput"
                            Style="{StaticResource AuthPasswordBoxStyle}"
                            PasswordChanged="OnConfirmPasswordChanged" />

                        <TextBox
                            x:Name="VisibleConfirmPasswordInput"
                            Visibility="Collapsed"
                            Style="{StaticResource AuthTextBoxStyle}"
                            TextChanged="OnVisibleConfirmPasswordChanged" />
                    </Grid>

                    <TextBlock
                        Text="{Binding ConfirmPasswordError}"
                        Style="{StaticResource AuthErrorStyle}" />

                    <CheckBox
                        x:Name="ShowPasswordsCheckBox"
                        Content="Hiện mật khẩu"
                        Checked="OnShowPasswordsChecked"
                        Unchecked="OnShowPasswordsUnchecked"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="11"
                        Margin="1,13,0,0" />

                    <!-- Requirements -->

                    <Border
                        Margin="0,20,0,0"
                        Padding="16"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>

                                <TextBlock
                                    Text="YÊU CẦU MẬT KHẨU"
                                    Style="{StaticResource CaptionTextStyle}"
                                    FontWeight="SemiBold"
                                    Margin="0,0,0,10" />

                                <TextBlock
                                    Text="● Ít nhất 10 ký tự"
                                    Tag="{Binding PasswordHasMinimumLength}"
                                    Style="{StaticResource PasswordRequirementStyle}" />

                                <TextBlock
                                    Text="● Có chữ hoa"
                                    Tag="{Binding PasswordHasUppercase}"
                                    Style="{StaticResource PasswordRequirementStyle}" />

                                <TextBlock
                                    Text="● Có chữ thường"
                                    Tag="{Binding PasswordHasLowercase}"
                                    Style="{StaticResource PasswordRequirementStyle}" />

                                <TextBlock
                                    Text="● Có chữ số"
                                    Tag="{Binding PasswordHasDigit}"
                                    Style="{StaticResource PasswordRequirementStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">

                                <TextBlock
                                    Text="&#160;"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Margin="0,0,0,10" />

                                <TextBlock
                                    Text="● Có ký tự đặc biệt"
                                    Tag="{Binding PasswordHasSpecialCharacter}"
                                    Style="{StaticResource PasswordRequirementStyle}" />

                                <TextBlock
                                    Text="● Không có khoảng trắng"
                                    Tag="{Binding PasswordHasNoWhitespace}"
                                    Style="{StaticResource PasswordRequirementStyle}" />

                                <TextBlock
                                    Text="● Không chứa tên đăng nhập"
                                    Tag="{Binding PasswordDoesNotContainUsername}"
                                    Style="{StaticResource PasswordRequirementStyle}" />

                                <TextBlock
                                    Text="● Hai mật khẩu trùng nhau"
                                    Tag="{Binding PasswordConfirmationMatches}"
                                    Style="{StaticResource PasswordRequirementStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Status -->

                    <Border
                        Margin="0,18,0,0"
                        Padding="14,12"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="{Binding HasStatusMessage,
                            Converter={StaticResource BooleanToVisibilityConverter}}">

                        <Border.Style>

                            <Style TargetType="{x:Type Border}">

                                <Setter
                                    Property="Background"
                                    Value="{StaticResource SuccessSoftBrush}" />

                                <Setter
                                    Property="BorderBrush"
                                    Value="{StaticResource SuccessBrush}" />

                                <Style.Triggers>

                                    <DataTrigger
                                        Binding="{Binding IsStatusError}"
                                        Value="True">

                                        <Setter
                                            Property="Background"
                                            Value="{StaticResource DangerSoftBrush}" />

                                        <Setter
                                            Property="BorderBrush"
                                            Value="{StaticResource DangerBrush}" />
                                    </DataTrigger>

                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <TextBlock
                            Text="{Binding StatusMessage}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            FontSize="11"
                            TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->

            <Border
                Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">

                <Grid Margin="38,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Text="Các trường có dấu * là bắt buộc."
                        Style="{StaticResource CaptionTextStyle}"
                        VerticalAlignment="Center" />

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                        <Button
                            Content="Thoát"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="100"
                            IsCancel="True" />

                        <Button
                            Command="{Binding CreateAdministratorCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="200"
                            Margin="10,0,0,0"
                            IsDefault="True">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Text="&#xE72E;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="13"
                                    Margin="0,0,8,0" />

                                <TextBlock
                                    Text="Tạo Administrator" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Busy overlay -->

            <Border
                Grid.RowSpan="2"
                Background="#C9FFFEFB"
                Visibility="{Binding IsBusy,
                    Converter={StaticResource BooleanToVisibilityConverter}}">

                <Border
                    Width="330"
                    Padding="24"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource GoldBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="15"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                    <StackPanel>

                        <ProgressBar
                            Height="5"
                            IsIndeterminate="True"
                            Foreground="{StaticResource AccentBrush}" />

                        <TextBlock
                            Text="Đang tạo tài khoản và bảo vệ mật khẩu..."
                            Foreground="{StaticResource TextSecondaryBrush}"
                            FontSize="12"
                            HorizontalAlignment="Center"
                            Margin="0,14,0,0" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>