<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- App surfaces -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F8F4" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#F7FAF7" />
    <SolidColorBrush x:Key="BorderBrush" Color="#D9E4DA" />

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#0E2A1D" />
    <SolidColorBrush x:Key="SidebarTextBrush" Color="#F5FFF6" />
    <SolidColorBrush x:Key="SidebarMutedBrush" Color="#9AB7A1" />

    <!-- Accent / Brand green -->
    <SolidColorBrush x:Key="AccentBrush" Color="#2F8F46" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#26753A" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#1F5E2E" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#E5F5E8" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1C2B22" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#55695C" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#829184" />

    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#2F8F46" />
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="#E8F7EB" />

    <SolidColorBrush x:Key="WarningBrush" Color="#D38B17" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="#FFF4DE" />

    <SolidColorBrush x:Key="DangerBrush" Color="#D14545" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#FDECEC" />

    <SolidColorBrush x:Key="InfoBrush" Color="#0F766E" />
    <SolidColorBrush x:Key="InfoSoftBrush" Color="#E7F7F5" />
</ResourceDictionary>