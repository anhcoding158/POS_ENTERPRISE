<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Core colors -->

    <Color x:Key="Color.AppBackground">#F4F7FB</Color>
    <Color x:Key="Color.Surface">#FFFFFFFF</Color>
    <Color x:Key="Color.SurfaceMuted">#F8FAFC</Color>
    <Color x:Key="Color.Border">#E5EAF2</Color>

    <Color x:Key="Color.TextPrimary">#172033</Color>
    <Color x:Key="Color.TextSecondary">#667085</Color>
    <Color x:Key="Color.TextMuted">#98A2B3</Color>

    <Color x:Key="Color.Sidebar">#111827</Color>
    <Color x:Key="Color.SidebarHover">#1F2937</Color>
    <Color x:Key="Color.SidebarSelected">#303A52</Color>
    <Color x:Key="Color.SidebarText">#F9FAFB</Color>
    <Color x:Key="Color.SidebarMuted">#A7B0C0</Color>

    <Color x:Key="Color.Accent">#6366F1</Color>
    <Color x:Key="Color.AccentHover">#5558E8</Color>
    <Color x:Key="Color.AccentPressed">#4749D1</Color>
    <Color x:Key="Color.AccentSoft">#EEF2FF</Color>

    <Color x:Key="Color.Success">#12B76A</Color>
    <Color x:Key="Color.SuccessSoft">#ECFDF3</Color>

    <Color x:Key="Color.Warning">#F79009</Color>
    <Color x:Key="Color.WarningSoft">#FFF7E8</Color>

    <Color x:Key="Color.Danger">#F04438</Color>
    <Color x:Key="Color.DangerSoft">#FEF3F2</Color>

    <Color x:Key="Color.Info">#2E90FA</Color>
    <Color x:Key="Color.InfoSoft">#EFF8FF</Color>

    <!-- Brushes -->

    <SolidColorBrush
        x:Key="AppBackgroundBrush"
        Color="{StaticResource Color.AppBackground}" />

    <SolidColorBrush
        x:Key="SurfaceBrush"
        Color="{StaticResource Color.Surface}" />

    <SolidColorBrush
        x:Key="SurfaceMutedBrush"
        Color="{StaticResource Color.SurfaceMuted}" />

    <SolidColorBrush
        x:Key="BorderBrush"
        Color="{StaticResource Color.Border}" />

    <SolidColorBrush
        x:Key="TextPrimaryBrush"
        Color="{StaticResource Color.TextPrimary}" />

    <SolidColorBrush
        x:Key="TextSecondaryBrush"
        Color="{StaticResource Color.TextSecondary}" />

    <SolidColorBrush
        x:Key="TextMutedBrush"
        Color="{StaticResource Color.TextMuted}" />

    <SolidColorBrush
        x:Key="SidebarBrush"
        Color="{StaticResource Color.Sidebar}" />

    <SolidColorBrush
        x:Key="SidebarHoverBrush"
        Color="{StaticResource Color.SidebarHover}" />

    <SolidColorBrush
        x:Key="SidebarSelectedBrush"
        Color="{StaticResource Color.SidebarSelected}" />

    <SolidColorBrush
        x:Key="SidebarTextBrush"
        Color="{StaticResource Color.SidebarText}" />

    <SolidColorBrush
        x:Key="SidebarMutedBrush"
        Color="{StaticResource Color.SidebarMuted}" />

    <SolidColorBrush
        x:Key="AccentBrush"
        Color="{StaticResource Color.Accent}" />

    <SolidColorBrush
        x:Key="AccentHoverBrush"
        Color="{StaticResource Color.AccentHover}" />

    <SolidColorBrush
        x:Key="AccentPressedBrush"
        Color="{StaticResource Color.AccentPressed}" />

    <SolidColorBrush
        x:Key="AccentSoftBrush"
        Color="{StaticResource Color.AccentSoft}" />

    <SolidColorBrush
        x:Key="SuccessBrush"
        Color="{StaticResource Color.Success}" />

    <SolidColorBrush
        x:Key="SuccessSoftBrush"
        Color="{StaticResource Color.SuccessSoft}" />

    <SolidColorBrush
        x:Key="WarningBrush"
        Color="{StaticResource Color.Warning}" />

    <SolidColorBrush
        x:Key="WarningSoftBrush"
        Color="{StaticResource Color.WarningSoft}" />

    <SolidColorBrush
        x:Key="DangerBrush"
        Color="{StaticResource Color.Danger}" />

    <SolidColorBrush
        x:Key="DangerSoftBrush"
        Color="{StaticResource Color.DangerSoft}" />

    <SolidColorBrush
        x:Key="InfoBrush"
        Color="{StaticResource Color.Info}" />

    <SolidColorBrush
        x:Key="InfoSoftBrush"
        Color="{StaticResource Color.InfoSoft}" />

</ResourceDictionary>